(load "git@github.com:carpentry-org/rc@0.3.0")

(doc Persistent "Generic persistent (immutable) data structures backed by `Rc`.

Each structure is a fully generic type (e.g. `(Persistent.List a)`,
`(Persistent.HashMap k v)`) sharing structure through reference counting.")

(defmodule Pair
  (defn = [p q] (and (= (Pair.a p) (Pair.a q)) (= (Pair.b p) (Pair.b q))))
  (implements = Pair.=))

(defmodule Persistent
  
  (hidden popcount)
  (deftemplate popcount (Fn [Int] Int)
    "int $NAME(int x)"
    "$DECL { return __builtin_popcount((unsigned int)x); }")

  
  (hidden array-reserve!)
  (deftemplate array-reserve! (Fn [(Ref (Array a)) Int] ())
    "void $NAME(Array *aRef, int n)"
    "$DECL { if(aRef->capacity < n) { aRef->capacity = n; aRef->data = CARP_REALLOC(aRef->data, sizeof($a) * n); } }"))

(defmodule Persistent
  (deftype (ListNode a) [value a
                         next (Maybe (Rc (Persistent.ListNode a)))])
  (hidden ListNode)
  
  (deftype (List a) [root (Maybe (Rc (Persistent.ListNode a)))
                     count Long])
  
  (defmodule List
    (doc empty "Create an empty persistent list.")
    (sig empty (Fn [] (Persistent.List a)))
    (defn empty [] (Persistent.List.init (Maybe.Nothing) 0l))
  
    (doc singleton "Create a singleton list.")
    (sig singleton (Fn [a] (Persistent.List a)))
    (defn singleton [value]
      (let [node (Persistent.ListNode.init value (Maybe.Nothing))
            head-rc (Rc.new node)]
        (Persistent.List.init (Maybe.Just head-rc) 1l)))
  
    (doc prepend
      "Prepend a value, returning a new list that shares the old tail.")
    (sig prepend (Fn [a (Ref (Persistent.List a) q)] (Persistent.List a)))
    (defn prepend [value list-ref]
      (let [old-head @(Persistent.List.root list-ref)
            old-len @(Persistent.List.count list-ref)
            node (Persistent.ListNode.init value old-head)
            head-rc (Rc.new node)]
        (Persistent.List.init (Maybe.Just head-rc) (Long.inc old-len))))
  
    (doc length "Return the logical length in O(1).")
    (sig length (Fn [(Ref (Persistent.List a) q)] Long))
    (defn length [list-ref] @(Persistent.List.count list-ref))
  
    (doc empty? "Returns `true` when list contains no elements.")
    (sig empty? (Fn [(Ref (Persistent.List a) q)] Bool))
    (defn empty? [list-ref] (= (length list-ref) 0l))
  
    (private head-node)
    (hidden head-node)
    (sig head-node (Fn [(Ref (Persistent.List a) q)] (Maybe (Persistent.ListNode a))))
    (defn head-node [list-ref]
      (match @(Persistent.List.root list-ref)
        (Maybe.Nothing) (Maybe.Nothing)
        (Maybe.Just head-rc) (Maybe.Just (Rc.get &head-rc))))
  
    (doc head "Read the first value, if any.")
    (sig head (Fn [(Ref (Persistent.List a) q)] (Maybe a)))
    (defn head [list-ref]
      (match (head-node list-ref)
        (Maybe.Nothing) (Maybe.Nothing)
        (Maybe.Just node) (Maybe.Just @(Persistent.ListNode.value &node))))
  
    (doc tail
      "Return the tail list, if any. Shares nodes with original list.")
    (sig tail (Fn [(Ref (Persistent.List a) q)] (Maybe (Persistent.List a))))
    (defn tail [list-ref]
      (match (head-node list-ref)
        (Maybe.Nothing) (Maybe.Nothing)
        (Maybe.Just node)
          (Maybe.Just
            (Persistent.List.init @(Persistent.ListNode.next &node)
                       (Long.dec @(Persistent.List.count list-ref))))))
  
    (doc drop-n "Drop up to `count` elements from the front.")
    (sig drop-n (Fn [Long (Ref (Persistent.List a) q)] (Persistent.List a)))
    (defn drop-n [count list-ref]
      (let-do [current @list-ref
               remaining count]
        (while-do (> remaining 0l)
          (match (tail &current)
            (Maybe.Nothing)
              (do (set! current (empty)) (set! remaining 0l))
            (Maybe.Just next-list)
              (do
                (set! current next-list)
                (set! remaining (Long.dec remaining)))))
        current))
  
    (doc reduce "Reduce the list head-to-tail with accumulator.")
    (sig reduce (Fn [(Ref (Fn [b a] b) q) b (Ref (Persistent.List a) r)] b))
    (defn reduce [f init list-ref]
      (let-do [current @(Persistent.List.root list-ref)
               acc init
               keep-going true]
        (while-do keep-going
          (match-ref &current
            (Maybe.Nothing) (set! keep-going false)
            (Maybe.Just node-rc)
              (let [node (Rc.get node-rc)]
                (do
                  (set! acc (~f acc @(Persistent.ListNode.value &node)))
                  (set! current @(Persistent.ListNode.next &node))))))
        acc))
  
    (doc each
      "Invoke a side-effecting function on each element in list order.")
    (sig each (Fn [(Ref (Fn [a] ()) q) (Ref (Persistent.List a) r)] ()))
    (defn each [f list-ref]
      (let-do [current @(Persistent.List.root list-ref)
               keep-going true]
        (while-do keep-going
          (match-ref &current
            (Maybe.Nothing) (set! keep-going false)
            (Maybe.Just node-rc)
              (let [node (Rc.get node-rc)]
                (do
                  (~f @(Persistent.ListNode.value &node))
                  (set! current @(Persistent.ListNode.next &node))))))))
  
    (doc to-array "Copy all values into an `Array` in list order.")
    (sig to-array (Fn [(Ref (Persistent.List a) q)] (Array a)))
    (defn to-array [list-ref]
      (reduce &(fn [acc x] (Array.push-back acc x)) [] list-ref))
  
    (doc from-array
      "Build a list from an `Array`, preserving element order.")
    (sig from-array (Fn [(Ref (Array a) q)] (Persistent.List a)))
    (defn from-array [arr-ref]
      (let-do [acc (empty)
               i (- (Array.length arr-ref) 1)]
        (while-do (>= i 0)
          (set! acc (prepend @(Array.unsafe-nth arr-ref i) &acc))
          (set! i (- i 1)))
        acc))
  
    (doc = "Structural equality: same length and pairwise equal elements.")
    (sig = (Fn [(Ref (Persistent.List a) q) (Ref (Persistent.List a) q)] Bool))
    (defn = [a-ref b-ref]
      (if (/= @(Persistent.List.count a-ref) @(Persistent.List.count b-ref))
        false
        (let-do [a-cur @(Persistent.List.root a-ref)
                 b-cur @(Persistent.List.root b-ref)
                 equal true
                 keep-going true]
          (while-do keep-going
            (match-ref &a-cur
              (Maybe.Nothing) (set! keep-going false)
              (Maybe.Just a-rc)
                (match-ref &b-cur
                  (Maybe.Nothing)
                    (do (set! equal false) (set! keep-going false))
                  (Maybe.Just b-rc)
                    (let [a-node (Rc.get a-rc)
                          b-node (Rc.get b-rc)]
                      (if (/= @(Persistent.ListNode.value &a-node)
                              @(Persistent.ListNode.value &b-node))
                        (do (set! equal false) (set! keep-going false))
                        (do
                          (set! a-cur @(Persistent.ListNode.next &a-node))
                          (set! b-cur @(Persistent.ListNode.next &b-node))))))))
          equal)))
    (implements = Persistent.List.=)
  
    (doc ptr-eq "Checks whether two lists share the exact same head node.")
    (sig ptr-eq (Fn [(Ref (Persistent.List a) q) (Ref (Persistent.List a) r)] Bool))
    (defn ptr-eq [a-ref b-ref]
      (match @(Persistent.List.root a-ref)
        (Maybe.Nothing)
          (match @(Persistent.List.root b-ref)
            (Maybe.Nothing) true
            (Maybe.Just _) false)
        (Maybe.Just a-head)
          (match @(Persistent.List.root b-ref)
            (Maybe.Just b-head) (Rc.ptr-eq &a-head &b-head)
            (Maybe.Nothing) false)))
  
    (doc reverse "Return a reversed copy of the list.")
    (sig reverse (Fn [(Ref (Persistent.List a) q)] (Persistent.List a)))
    (defn reverse [list-ref]
      (reduce &(fn [acc x] (prepend x &acc)) (empty) list-ref))
  
    (doc map
      "Apply a function to each element, returning a new list in the same order.")
    (sig map
         (Fn [(Ref (Fn [a] a) q) (Ref (Persistent.List a) r)] (Persistent.List a)))
    (defn map [f list-ref]
      (let [rev (reduce &(fn [acc x] (prepend (~f x) &acc))
                        (empty)
                        list-ref)]
        (reverse &rev)))
  
    (doc filter
      "Keep only elements satisfying a predicate, preserving order.")
    (sig filter
         (Fn [(Ref (Fn [(Ref a q)] Bool) r) (Ref (Persistent.List a) s)] (Persistent.List a)))
    (defn filter [pred list-ref]
      (let [rev (reduce
              &(fn [acc x] (if (~pred &x) (prepend x &acc) acc))
              (empty)
              list-ref)]
        (reverse &rev)))
  
    (doc any? "Return true if any element satisfies the predicate.")
    (sig any?
         (Fn [(Ref (Fn [(Ref a q)] Bool) r) (Ref (Persistent.List a) s)] Bool))
    (defn any? [pred coll-ref]
      (reduce &(fn [acc x] (or acc (~pred &x))) false coll-ref))
  
    (doc all? "Return true if all elements satisfy the predicate.")
    (sig all?
         (Fn [(Ref (Fn [(Ref a q)] Bool) r) (Ref (Persistent.List a) s)] Bool))
    (defn all? [pred coll-ref]
      (reduce &(fn [acc x] (and acc (~pred &x))) true coll-ref))
  
    (doc str "Diagnostic formatting for a list.")
    (sig str (Fn [(Ref (Persistent.List a) q)] String))
    (defn str [list-ref]
      (fmt "(Persistent.List length=%ld)" (length list-ref)))
  
    (sig prn (Fn [(Ref (Persistent.List a) q)] String))
    (defn prn [list-ref] (str list-ref)))
)

(defmodule Persistent
        (deftype (Queue a) [front (Persistent.List a)
                        rear (Persistent.List a)
                        count Long])

        (defmodule Queue
          (doc empty "Create an empty queue.")
          (sig empty (Fn [] (Persistent.Queue a)))
          (defn empty [] (Persistent.Queue.init (Persistent.List.empty) (Persistent.List.empty) 0l))

          (doc singleton "Create a singleton queue.")
          (sig singleton (Fn [a] (Persistent.Queue a)))
          (defn singleton [value]
            (Persistent.Queue.init (Persistent.List.singleton value) (Persistent.List.empty) 1l))

          (private reverse-list)
          (hidden reverse-list)
          (sig reverse-list (Fn [(Ref (Persistent.List a) q)] (Persistent.List a)))
          (defn reverse-list [src-ref]
            (let-do [current @src-ref
                     acc (Persistent.List.empty)
                     keep-going true]
              (while-do keep-going
                (match (Persistent.List.head &current)
                  (Maybe.Nothing) (set! keep-going false)
                  (Maybe.Just value)
                    (do
                      (set! acc (Persistent.List.prepend value &acc))
                      (match (Persistent.List.tail &current)
                        (Maybe.Just next-src) (set! current next-src)
                        (Maybe.Nothing) (set! keep-going false)))))
              acc))

          (private normalize)
          (hidden normalize)
          (sig normalize (Fn [(Ref (Persistent.List a) q) (Ref (Persistent.List a) r) Long] (Persistent.Queue a)))
          (defn normalize [front-ref rear-ref count]
            (if (Persistent.List.empty? front-ref)
              (if (Persistent.List.empty? rear-ref)
                (Persistent.Queue.init @front-ref @rear-ref count)
                (let [new-front (reverse-list rear-ref)
                      empty-rear (Persistent.List.empty)]
                  (Persistent.Queue.init new-front empty-rear count)))
              (Persistent.Queue.init @front-ref @rear-ref count)))

          (doc length "Return the logical queue length in O(1).")
          (sig length (Fn [(Ref (Persistent.Queue a) q)] Long))
          (defn length [q-ref] @(Persistent.Queue.count q-ref))

          (doc empty? "Returns `true` when queue has no elements.")
          (sig empty? (Fn [(Ref (Persistent.Queue a) q)] Bool))
          (defn empty? [q-ref] (= (length q-ref) 0l))

          (doc enqueue "Enqueue at the rear, returning a new queue.")
          (sig enqueue (Fn [a (Ref (Persistent.Queue a) q)] (Persistent.Queue a)))
          (defn enqueue [value q-ref]
            (let [rear2 (Persistent.List.prepend value (Persistent.Queue.rear q-ref))
                  count2 (Long.inc @(Persistent.Queue.count q-ref))]
              (normalize (Persistent.Queue.front q-ref) &rear2 count2)))

          (doc peek "Read the front value, if any.")
          (sig peek (Fn [(Ref (Persistent.Queue a) q)] (Maybe a)))
          (defn peek [q-ref]
            (if (Persistent.Queue.empty? q-ref)
              (Maybe.Nothing)
              (Persistent.List.head (Persistent.Queue.front q-ref))))

          (doc dequeue
            "Dequeue front value, returning `(Maybe (Pair value next-queue))`.")
          (sig dequeue (Fn [(Ref (Persistent.Queue a) q)] (Maybe (Pair a (Persistent.Queue a)))))
          (defn dequeue [q-ref]
            (match (Persistent.Queue.peek q-ref)
              (Maybe.Nothing) (Maybe.Nothing)
              (Maybe.Just value)
                (let [count2 (Long.dec @(Persistent.Queue.count q-ref))]
                  (match (Persistent.List.tail (Persistent.Queue.front q-ref))
                    (Maybe.Just next-front)
                      (let [q2 (normalize &next-front (Persistent.Queue.rear q-ref) count2)]
                        (Maybe.Just (Pair.init value q2)))
                    (Maybe.Nothing)
                      (let [front0 (Persistent.List.empty)
                            q2 (normalize &front0 (Persistent.Queue.rear q-ref) count2)]
                        (Maybe.Just (Pair.init value q2)))))))

          (doc ptr-eq
            "Pointer identity check for queue front and rear list roots plus count equality.")
          (sig ptr-eq (Fn [(Ref (Persistent.Queue a) q) (Ref (Persistent.Queue a) r)] Bool))
          (defn ptr-eq [a-ref b-ref]
            (and
              (= @(Persistent.Queue.count a-ref) @(Persistent.Queue.count b-ref))
              (Persistent.List.ptr-eq (Persistent.Queue.front a-ref) (Persistent.Queue.front b-ref))
              (Persistent.List.ptr-eq (Persistent.Queue.rear a-ref) (Persistent.Queue.rear b-ref))))

          (doc reduce "Reduce the queue in FIFO order with accumulator.")
          (sig reduce (Fn [(Ref (Fn [b a] b) q) b (Ref (Persistent.Queue a) r)] b))
          (defn reduce [f init q-ref]
            (let [after-front (Persistent.List.reduce f init (Persistent.Queue.front q-ref))
                  rear-rev (reverse-list (Persistent.Queue.rear q-ref))]
              (Persistent.List.reduce f after-front &rear-rev)))

          (doc each
            "Invoke a side-effecting function on each element in FIFO order.")
          (sig each (Fn [(Ref (Fn [a] ()) q) (Ref (Persistent.Queue a) r)] ()))
          (defn each [f q-ref]
            (do
              (Persistent.List.each f (Persistent.Queue.front q-ref))
              (let [rear-rev (reverse-list (Persistent.Queue.rear q-ref))]
                (Persistent.List.each f &rear-rev))))

          (doc to-array "Copy all values into an `Array` in FIFO order.")
          (sig to-array (Fn [(Ref (Persistent.Queue a) q)] (Array a)))
          (defn to-array [q-ref]
            (reduce &(fn [acc x] (Array.push-back acc x)) [] q-ref))

          (doc from-array
            "Build a queue from an `Array`, preserving FIFO order.")
          (sig from-array (Fn [(Ref (Array a) q)] (Persistent.Queue a)))
          (defn from-array [arr-ref]
            (Array.reduce &(fn [acc x] (enqueue @x &acc)) (empty) arr-ref))

          (doc =
            "Structural equality: same length and pairwise equal FIFO sequence.")
          (sig = (Fn [(Ref (Persistent.Queue a) q) (Ref (Persistent.Queue a) q)] Bool))
          (defn = [a-ref b-ref]
            (if (/= @(Persistent.Queue.count a-ref) @(Persistent.Queue.count b-ref))
              false
              (let [aa (to-array a-ref)
                    ab (to-array b-ref)] (= &aa &ab))))
          (implements = Persistent.Queue.=)

          (doc map
            "Apply a function to each element, returning a new queue in FIFO order.")
          (sig map
               (Fn [(Ref (Fn [a] a) q) (Ref (Persistent.Queue a) r)] (Persistent.Queue a)))
          (defn map [f q-ref]
            (reduce &(fn [acc x] (enqueue (~f x) &acc)) (empty) q-ref))

          (doc filter
            "Keep only elements satisfying a predicate, preserving FIFO order.")
          (sig filter
               (Fn [(Ref (Fn [(Ref a q)] Bool) r) (Ref (Persistent.Queue a) s)] (Persistent.Queue a)))
          (defn filter [pred q-ref]
            (reduce
              &(fn [acc x] (if (~pred &x) (enqueue x &acc) acc))
              (empty)
              q-ref))

          (doc any? "Return true if any element satisfies the predicate.")
          (sig any?
               (Fn [(Ref (Fn [(Ref a q)] Bool) r) (Ref (Persistent.Queue a) s)] Bool))
          (defn any? [pred coll-ref]
            (reduce &(fn [acc x] (or acc (~pred &x))) false coll-ref))

          (doc all? "Return true if all elements satisfy the predicate.")
          (sig all?
               (Fn [(Ref (Fn [(Ref a q)] Bool) r) (Ref (Persistent.Queue a) s)] Bool))
          (defn all? [pred coll-ref]
            (reduce &(fn [acc x] (and acc (~pred &x))) true coll-ref))

          (doc str "Diagnostic formatting for a queue.")
          (sig str (Fn [(Ref (Persistent.Queue a) q)] String))
          (defn str [q-ref] (fmt "(PersistentQueue length=%ld)" (length q-ref)))

          (sig prn (Fn [(Ref (Persistent.Queue a) q)] String))
          (defn prn [q-ref] (str q-ref)))
)

(defmodule Persistent
        (deftype (TrieNode k v)
          [label (Maybe k)
           value (Maybe v)
           child (Maybe (Rc (Persistent.TrieNode k v)))
           sibling (Maybe (Rc (Persistent.TrieNode k v)))])
        (hidden TrieNode)

        (deftype (Trie k v) [root (Rc (Persistent.TrieNode k v))
                        count Long])

        (defmodule Trie
          (private empty-node)
          (hidden empty-node)
          (sig empty-node (Fn [] (Persistent.TrieNode k v)))
          (defn empty-node []
            (Persistent.TrieNode.init (Maybe.Nothing)
                        (Maybe.Nothing)
                        (Maybe.Nothing)
                        (Maybe.Nothing)))

          (private node-empty?)
          (hidden node-empty?)
          (sig node-empty? (Fn [(Ref (Persistent.TrieNode k v) q)] Bool))
          (defn node-empty? [node-ref]
            (and (Maybe.nothing? (Persistent.TrieNode.value node-ref))
                 (Maybe.nothing? (Persistent.TrieNode.child node-ref))))

          (private node-label-matches?)
          (hidden node-label-matches?)
          (sig node-label-matches? (Fn [k (Ref (Persistent.TrieNode k v) q)] Bool))
          (defn node-label-matches? [label node-ref]
            (match @(Persistent.TrieNode.label node-ref)
              (Maybe.Just node-label) (= label node-label)
              (Maybe.Nothing) false))

          (private sibling-find)
          (hidden sibling-find)
          (sig sibling-find
               (Fn
                 [k (Ref (Maybe (Rc (Persistent.TrieNode k v))) q)]
                 (Maybe (Rc (Persistent.TrieNode k v)))))
          (defn sibling-find [label siblings-ref]
            (let-do [stack (the (Array (Rc (Persistent.TrieNode k v))) [])
                     result (the (Maybe (Rc (Persistent.TrieNode k v))) (Maybe.Nothing))]
              (match-ref siblings-ref
                (Maybe.Nothing) ()
                (Maybe.Just first-rc)
                  (set! stack (Array.push-back stack @first-rc)))
              (while-do (and (Maybe.nothing? &result) (> (Array.length &stack) 0))
                (let [top-rc (Array.pop-back! &stack)
                      top-ref (Rc.value-ref &top-rc)]
                  (if (node-label-matches? @&label top-ref)
                    (set! result (Maybe.Just @&top-rc))
                    (match-ref (Persistent.TrieNode.sibling top-ref)
                      (Maybe.Nothing) ()
                      (Maybe.Just next-rc)
                        (set! stack (Array.push-back stack @next-rc))))))
              result))

          (private sibling-upsert)
          (hidden sibling-upsert)
          (sig sibling-upsert
               (Fn
                 [k
                  (Ref (Rc (Persistent.TrieNode k v)) q)
                  (Ref (Maybe (Rc (Persistent.TrieNode k v))) r)]
                 (Pair (Maybe (Rc (Persistent.TrieNode k v))) Bool)))
          (defn sibling-upsert [label child-rc-ref siblings-ref]
            (let-do [spine (the (Array (Rc (Persistent.TrieNode k v))) [])
                     stack (the (Array (Rc (Persistent.TrieNode k v))) [])
                     found false
                     tail (the (Maybe (Rc (Persistent.TrieNode k v))) (Maybe.Nothing))]
              (match-ref siblings-ref
                (Maybe.Nothing) ()
                (Maybe.Just first-rc)
                  (set! stack (Array.push-back stack @first-rc)))
              (while-do (and (not found) (> (Array.length &stack) 0))
                (let [top-rc (Array.pop-back! &stack)
                      head-ref (Rc.value-ref &top-rc)]
                  (if (node-label-matches? @&label head-ref)
                    (let-do [child-node (Rc.get child-rc-ref)
                             repl-node (Persistent.TrieNode.init @(Persistent.TrieNode.label &child-node)
                                          @(Persistent.TrieNode.value &child-node)
                                          @(Persistent.TrieNode.child &child-node)
                                          @(Persistent.TrieNode.sibling head-ref))]
                      (set! tail (Maybe.Just (Rc.new repl-node)))
                      (set! found true))
                    (do
                      (match-ref (Persistent.TrieNode.sibling head-ref)
                        (Maybe.Nothing) ()
                        (Maybe.Just next-rc)
                          (set! stack (Array.push-back stack @next-rc)))
                      (set! spine (Array.push-back spine @&top-rc))))))
              (unless found (set! tail (Maybe.Just @child-rc-ref)))
              (let-do [i (Int.dec (Array.length &spine))]
                (while-do (>= i 0)
                  (let-do [node-ref (Rc.value-ref (Array.unsafe-nth &spine i))
                           rebuilt (Persistent.TrieNode.init @(Persistent.TrieNode.label node-ref)
                                      @(Persistent.TrieNode.value node-ref)
                                      @(Persistent.TrieNode.child node-ref)
                                      @&tail)]
                    (set! tail (Maybe.Just (Rc.new rebuilt)))
                    (set! i (Int.dec i)))))
              (Pair.init tail found)))

          (private sibling-remove)
          (hidden sibling-remove)
          (sig sibling-remove
               (Fn
                 [k (Ref (Maybe (Rc (Persistent.TrieNode k v))) q)]
                 (Pair (Maybe (Rc (Persistent.TrieNode k v))) Bool)))
          (defn sibling-remove [label siblings-ref]
            (let-do [spine (the (Array (Rc (Persistent.TrieNode k v))) [])
                     stack (the (Array (Rc (Persistent.TrieNode k v))) [])
                     found false
                     tail (the (Maybe (Rc (Persistent.TrieNode k v))) (Maybe.Nothing))]
              (match-ref siblings-ref
                (Maybe.Nothing) ()
                (Maybe.Just first-rc)
                  (set! stack (Array.push-back stack @first-rc)))
              (while-do (and (not found) (> (Array.length &stack) 0))
                (let [top-rc (Array.pop-back! &stack)
                      head-ref (Rc.value-ref &top-rc)]
                  (if (node-label-matches? @&label head-ref)
                    (do (set! tail @(Persistent.TrieNode.sibling head-ref)) (set! found true))
                    (do
                      (match-ref (Persistent.TrieNode.sibling head-ref)
                        (Maybe.Nothing) ()
                        (Maybe.Just next-rc)
                          (set! stack (Array.push-back stack @next-rc)))
                      (set! spine (Array.push-back spine @&top-rc))))))
              (if (not found)
                (Pair.init @siblings-ref false)
                (do
                  (let-do [i (Int.dec (Array.length &spine))]
                    (while-do (>= i 0)
                      (let-do [node-ref (Rc.value-ref (Array.unsafe-nth &spine i))
                               rebuilt (Persistent.TrieNode.init @(Persistent.TrieNode.label node-ref)
                                          @(Persistent.TrieNode.value node-ref)
                                          @(Persistent.TrieNode.child node-ref)
                                          @&tail)]
                        (set! tail (Maybe.Just (Rc.new rebuilt)))
                        (set! i (Int.dec i)))))
                  (Pair.init tail true)))))

          (private build-branch)
          (hidden build-branch)
          (sig build-branch
               (Fn
                 [(Ref (Array k) q) Int v]
                 (Rc (Persistent.TrieNode k v))))
          (defn build-branch [key-ref index value]
            (let-do [last-idx (Int.dec (Array.length key-ref))
                     last-part @(Array.unsafe-nth key-ref last-idx)
                     node (Rc.new
                       (Persistent.TrieNode.init (Maybe.Just last-part)
                                   (Maybe.Just value)
                                   (Maybe.Nothing)
                                   (Maybe.Nothing)))
                     i (Int.dec last-idx)]
              (while-do (>= i index)
                (let [part @(Array.unsafe-nth key-ref i)
                      new-node (Rc.new
                        (Persistent.TrieNode.init (Maybe.Just part)
                                    (Maybe.Nothing)
                                    (Maybe.Just @&node)
                                    (Maybe.Nothing)))]
                  (do (set! node new-node) (set! i (Int.dec i)))))
              node))

          (private insert-node)
          (hidden insert-node)
          (sig insert-node
               (Fn
                 [(Ref (Rc (Persistent.TrieNode k v)) q)
                  (Ref (Array k) r)
                  Int
                  v]
                 (Pair (Rc (Persistent.TrieNode k v)) Bool)))
          (defn insert-node [node-rc-ref key-ref index value]
            (let [node-ref (Rc.value-ref node-rc-ref)]
              (if (>= index (Array.length key-ref))
                (let [had-value (match-ref (Persistent.TrieNode.value node-ref)
                        (Maybe.Just _) true
                        (Maybe.Nothing) false)
                      node2 (Persistent.TrieNode.init @(Persistent.TrieNode.label node-ref)
                                        (Maybe.Just value)
                                        @(Persistent.TrieNode.child node-ref)
                                        @(Persistent.TrieNode.sibling node-ref))]
                  (Pair.init (Rc.new node2) (not had-value)))
                (let [part @(Array.unsafe-nth key-ref index)]
                  (match (sibling-find @&part (Persistent.TrieNode.child node-ref))
                    (Maybe.Just child-rc)
                      (let [rec (insert-node &child-rc
                                             key-ref
                                             (Int.inc index)
                                             value)
                            upsert-rec (sibling-upsert part
                                                       (Pair.a &rec)
                                                       (Persistent.TrieNode.child node-ref))
                            node2 (Persistent.TrieNode.init @(Persistent.TrieNode.label node-ref)
                                              @(Persistent.TrieNode.value node-ref)
                                              @(Pair.a &upsert-rec)
                                              @(Persistent.TrieNode.sibling node-ref))]
                        (Pair.init (Rc.new node2) @(Pair.b &rec)))
                    (Maybe.Nothing)
                      (let [branch (build-branch key-ref index value)
                            upsert-rec (sibling-upsert part
                                                       &branch
                                                       (Persistent.TrieNode.child node-ref))
                            node2 (Persistent.TrieNode.init @(Persistent.TrieNode.label node-ref)
                                              @(Persistent.TrieNode.value node-ref)
                                              @(Pair.a &upsert-rec)
                                              @(Persistent.TrieNode.sibling node-ref))]
                        (Pair.init (Rc.new node2) true)))))))

          (private get-in-siblings)
          (hidden get-in-siblings)
          (sig get-in-siblings
               (Fn
                 [k
                  (Ref (Maybe (Rc (Persistent.TrieNode k v))) q)
                  (Ref (Array k) r)
                  Int]
                 (Maybe v)))
          (defn get-in-siblings [part siblings-ref key-ref index]
            (let-do [cur-part part
                     cur-index index
                     stack (the (Array (Rc (Persistent.TrieNode k v))) [])
                     result (the (Maybe v) (Maybe.Nothing))
                     done false]
              (match-ref siblings-ref
                (Maybe.Nothing) (set! done true)
                (Maybe.Just first-rc)
                  (set! stack (Array.push-back stack @first-rc)))
              (while-do (and (not done) (> (Array.length &stack) 0))
                (let [top-rc (Array.pop-back! &stack)
                      head-ref (Rc.value-ref &top-rc)]
                  (if (node-label-matches? @&cur-part head-ref)
                    (let [next-i (Int.inc cur-index)]
                      (if (>= next-i (Array.length key-ref))
                        (do
                          (set! result @(Persistent.TrieNode.value head-ref))
                          (set! done true))
                        (do
                          (set! cur-part @(Array.unsafe-nth key-ref next-i))
                          (set! cur-index next-i)
                          (match-ref (Persistent.TrieNode.child head-ref)
                            (Maybe.Nothing) (set! done true)
                            (Maybe.Just child-rc)
                              (set! stack (Array.push-back stack @child-rc))))))
                    (match-ref (Persistent.TrieNode.sibling head-ref)
                      (Maybe.Nothing) (set! done true)
                      (Maybe.Just next-rc)
                        (set! stack (Array.push-back stack @next-rc))))))
              result))

          (private get-node)
          (hidden get-node)
          (sig get-node
               (Fn
                 [(Ref (Rc (Persistent.TrieNode k v)) q) (Ref (Array k) r) Int]
                 (Maybe v)))
          (defn get-node [node-rc-ref key-ref index]
            (let [node-ref (Rc.value-ref node-rc-ref)]
              (if (>= index (Array.length key-ref))
                @(Persistent.TrieNode.value node-ref)
                (get-in-siblings @(Array.unsafe-nth key-ref index)
                                 (Persistent.TrieNode.child node-ref)
                                 key-ref
                                 index))))

          (private remove-node)
          (hidden remove-node)
          (sig remove-node
               (Fn
                 [(Ref (Rc (Persistent.TrieNode k v)) q) (Ref (Array k) r) Int]
                 (Pair (Rc (Persistent.TrieNode k v)) (Pair Bool Bool))))
          (defn remove-node [node-rc-ref key-ref index]
            (let [node-ref (Rc.value-ref node-rc-ref)]
              (if (>= index (Array.length key-ref))
                (match-ref (Persistent.TrieNode.value node-ref)
                  (Maybe.Nothing)
                    (Pair.init @node-rc-ref
                               (Pair.init false (node-empty? node-ref)))
                  (Maybe.Just _)
                    (let [node2 (Persistent.TrieNode.init @(Persistent.TrieNode.label node-ref)
                                            (Maybe.Nothing)
                                            @(Persistent.TrieNode.child node-ref)
                                            @(Persistent.TrieNode.sibling node-ref))
                          empty2 (node-empty? &node2)]
                      (Pair.init (Rc.new node2)
                                 (Pair.init true empty2))))
                (let [part @(Array.unsafe-nth key-ref index)]
                  (match (sibling-find @&part (Persistent.TrieNode.child node-ref))
                    (Maybe.Nothing)
                      (Pair.init @node-rc-ref
                                 (Pair.init false (node-empty? node-ref)))
                    (Maybe.Just child-rc)
                      (let [rec (remove-node &child-rc key-ref (Int.inc index))]
                        (if (not @(Pair.a (Pair.b &rec)))
                          (Pair.init @node-rc-ref @(Pair.b &rec))
                          (let [child-empty @(Pair.b (Pair.b &rec))
                                children2 (if child-empty
                                  @(Pair.a &(sibling-remove part
                                                            (Persistent.TrieNode.child node-ref)))
                                  @(Pair.a &(sibling-upsert part
                                                            (Pair.a &rec)
                                                            (Persistent.TrieNode.child node-ref))))
                                rebuilt (Persistent.TrieNode.init @(Persistent.TrieNode.label node-ref)
                                                    @(Persistent.TrieNode.value node-ref)
                                                    children2
                                                    @(Persistent.TrieNode.sibling node-ref))
                                empty2 (node-empty? &rebuilt)]
                            (Pair.init (Rc.new rebuilt)
                                       (Pair.init true empty2))))))))))

          (private subtree-has-entry?)
          (hidden subtree-has-entry?)
          (sig subtree-has-entry? (Fn [(Ref (Rc (Persistent.TrieNode k v)) q)] Bool))
          (defn subtree-has-entry? [node-rc-ref]
            (let-do [stack (the (Array (Rc (Persistent.TrieNode k v))) [])
                     found false]
              (let [node-ref (Rc.value-ref node-rc-ref)]
                (match-ref (Persistent.TrieNode.value node-ref)
                  (Maybe.Just _) (set! found true)
                  (Maybe.Nothing)
                    (match-ref (Persistent.TrieNode.child node-ref)
                      (Maybe.Nothing) ()
                      (Maybe.Just c) (set! stack (Array.push-back stack @c)))))
              (while-do (and (not found) (> (Array.length &stack) 0))
                (let [top-rc (Array.pop-back! &stack)
                      node-ref (Rc.value-ref &top-rc)]
                  (do
                    (match-ref (Persistent.TrieNode.value node-ref)
                      (Maybe.Just _) (set! found true)
                      (Maybe.Nothing) ())
                    (when (not found)
                      (do
                        (match-ref (Persistent.TrieNode.child node-ref)
                          (Maybe.Nothing) ()
                          (Maybe.Just c) (set! stack (Array.push-back stack @c)))
                        (match-ref (Persistent.TrieNode.sibling node-ref)
                          (Maybe.Nothing) ()
                          (Maybe.Just s) (set! stack (Array.push-back stack @s))))))))
              found))

          (private find-prefix-node)
          (hidden find-prefix-node)
          (sig find-prefix-node
               (Fn
                 [(Ref (Rc (Persistent.TrieNode k v)) q) (Ref (Array k) r) Int]
                 (Maybe (Rc (Persistent.TrieNode k v)))))
          (defn find-prefix-node [node-rc-ref prefix-ref index]
            (if (>= index (Array.length prefix-ref))
              (Maybe.Just @node-rc-ref)
              (let [node-ref (Rc.value-ref node-rc-ref)
                    part @(Array.unsafe-nth prefix-ref index)]
                (match (sibling-find part (Persistent.TrieNode.child node-ref))
                  (Maybe.Nothing) (Maybe.Nothing)
                  (Maybe.Just child-rc)
                    (find-prefix-node &child-rc prefix-ref (Int.inc index))))))

          (doc empty "Create an empty trie.")
          (sig empty (Fn [] (Persistent.Trie k v)))
          (defn empty []
            (let [root (Rc.new (empty-node))] (Persistent.Trie.init root 0l)))

          (doc singleton "Create a trie containing one key/value pair.")
          (sig singleton (Fn [(Ref (Array k) q) v] (Persistent.Trie k v)))
          (defn singleton [key-ref value]
            (let [root0 (Rc.new (empty-node))
                  result (insert-node &root0 key-ref 0 value)
                  root1 @(Pair.a &result)]
              (Persistent.Trie.init root1 1l)))

          (doc length "Return number of stored key/value pairs.")
          (sig length (Fn [(Ref (Persistent.Trie k v) q)] Long))
          (defn length [trie-ref] @(Persistent.Trie.count trie-ref))

          (doc empty? "Returns `true` when trie contains no entries.")
          (sig empty? (Fn [(Ref (Persistent.Trie k v) q)] Bool))
          (defn empty? [trie-ref] (= (length trie-ref) 0l))

          (doc insert "Insert or replace value for key, returning a new trie.")
          (sig insert
               (Fn
                 [(Ref (Array k) q) v (Ref (Persistent.Trie k v) r)]
                 (Persistent.Trie k v)))
          (defn insert [key-ref value trie-ref]
            (let [root @(Persistent.Trie.root trie-ref)
                  result (insert-node &root key-ref 0 value)
                  root2 @(Pair.a &result)
                  inserted? @(Pair.b &result)
                  count2 (if inserted?
                    (Long.inc @(Persistent.Trie.count trie-ref))
                    @(Persistent.Trie.count trie-ref))]
              (Persistent.Trie.init root2 count2)))

          (doc get "Lookup key, returning `Maybe` value.")
          (sig get
               (Fn
                 [(Ref (Array k) q) (Ref (Persistent.Trie k v) r)]
                 (Maybe v)))
          (defn get [key-ref trie-ref]
            (get-node (Persistent.Trie.root trie-ref) key-ref 0))

          (doc contains? "Returns `true` when key exists in trie.")
          (sig contains?
               (Fn [(Ref (Array k) q) (Ref (Persistent.Trie k v) r)] Bool))
          (defn contains? [key-ref trie-ref]
            (match (get key-ref trie-ref)
              (Maybe.Just _) true
              (Maybe.Nothing) false))

          (doc remove "Remove key (if present), returning a new trie.")
          (sig remove (Fn [(Ref (Array k) q) (Ref (Persistent.Trie k v) r)] (Persistent.Trie k v)))
          (defn remove [key-ref trie-ref]
            (let [root @(Persistent.Trie.root trie-ref)
                  result (remove-node &root key-ref 0)
                  root2 @(Pair.a &result)
                  flags @(Pair.b &result)
                  removed? @(Pair.a &flags)
                  count2 (if removed?
                    (Long.dec @(Persistent.Trie.count trie-ref))
                    @(Persistent.Trie.count trie-ref))]
              (Persistent.Trie.init root2 count2)))

          (doc contains-prefix?
            "Returns `true` if any entry exists under this key prefix.")
          (sig contains-prefix?
               (Fn [(Ref (Array k) q) (Ref (Persistent.Trie k v) r)] Bool))
          (defn contains-prefix? [prefix-ref trie-ref]
            (match (find-prefix-node (Persistent.Trie.root trie-ref) prefix-ref 0)
              (Maybe.Nothing) false
              (Maybe.Just node-rc) (subtree-has-entry? &node-rc)))

          (doc ptr-eq
            "Pointer identity check for root node plus count equality.")
          (sig ptr-eq (Fn [(Ref (Persistent.Trie k v) q) (Ref (Persistent.Trie k v) r)] Bool))
          (defn ptr-eq [a-ref b-ref]
            (and
              (= @(Persistent.Trie.count a-ref) @(Persistent.Trie.count b-ref))
              (Rc.ptr-eq (Persistent.Trie.root a-ref) (Persistent.Trie.root b-ref))))

          (doc reduce-values
            "Reduce over values only, skipping key path reconstruction.")
          (sig reduce-values
               (Fn [(Ref (Fn [a v] a) q) a (Ref (Persistent.Trie k v) r)] a))
          (defn reduce-values [f init trie-ref]
            (let-do [stack (the (Array (Maybe (Rc (Persistent.TrieNode k v)))) [])
                     acc init]
              (set! stack
                    (Array.push-back stack (Maybe.Just @(Persistent.Trie.root trie-ref))))
              (while-do (> (Array.length &stack) 0)
                (match (Array.pop-back! &stack)
                  (Maybe.Nothing) ()
                  (Maybe.Just top-rc)
                    (let [node-ref (Rc.value-ref &top-rc)]
                      (do
                        (match-ref (Persistent.TrieNode.value node-ref)
                          (Maybe.Nothing) ()
                          (Maybe.Just v) (set! acc (~f acc @v)))
                        (set! stack (Array.push-back stack @(Persistent.TrieNode.child node-ref)))
                        (set! stack
                              (Array.push-back stack @(Persistent.TrieNode.sibling node-ref)))))))
              acc))

          (doc reduce
            "Reduce over `(Pair key value)` entries in DFS sibling-insertion order.")
          (sig reduce
               (Fn
                 [(Ref (Fn [a (Pair (Array k) v)] a) q)
                  a
                  (Ref (Persistent.Trie k v) r)]
                 a))
          (defn reduce [f init trie-ref]
            (let-do [stack (the (Array (Pair (Maybe (Rc (Persistent.TrieNode k v))) Bool)) [])
                     path (the (Array k) [])
                     acc init]
              (set! stack
                    (Array.push-back stack
                                     (Pair.init (Maybe.Just @(Persistent.Trie.root trie-ref))
                                                false)))
              (while-do (> (Array.length &stack) 0)
                (let [frame (Array.pop-back! &stack)
                      maybe-rc (Pair.a &frame)
                      is-exit @(Pair.b &frame)]
                  (match-ref maybe-rc
                    (Maybe.Nothing) ()
                    (Maybe.Just rc)
                      (let [node-ref (Rc.value-ref rc)]
                        (if is-exit
                          (match-ref (Persistent.TrieNode.label node-ref)
                            (Maybe.Nothing) ()
                            (Maybe.Just _) (ignore (Array.pop-back! &path)))
                          (do
                            (set! stack
                                  (Array.push-back stack
                                                   (Pair.init @(Persistent.TrieNode.sibling node-ref)
                                                              false)))
                            (set! stack
                                  (Array.push-back stack
                                                   (Pair.init (Maybe.Just @rc)
                                                              true)))
                            (match-ref (Persistent.TrieNode.label node-ref)
                              (Maybe.Nothing) ()
                              (Maybe.Just l)
                                (set! path (Array.push-back path @l)))
                            (match-ref (Persistent.TrieNode.value node-ref)
                              (Maybe.Nothing) ()
                              (Maybe.Just v)
                                (set! acc (~f acc (Pair.init @&path @v))))
                            (set! stack
                                  (Array.push-back stack
                                                   (Pair.init @(Persistent.TrieNode.child node-ref)
                                                              false)))))))))
              acc))

          (doc each
            "Invoke a side-effecting function on each `(Pair key value)` entry.")
          (sig each
               (Fn
                 [(Ref (Fn [(Pair (Array k) v)] ()) q)
                  (Ref (Persistent.Trie k v) r)]
                 ()))
          (defn each [f trie-ref]
            (let-do [stack (the (Array (Pair (Maybe (Rc (Persistent.TrieNode k v))) Bool)) [])
                     path (the (Array k) [])]
              (set! stack
                    (Array.push-back stack
                                     (Pair.init (Maybe.Just @(Persistent.Trie.root trie-ref))
                                                false)))
              (while-do (> (Array.length &stack) 0)
                (let [frame (Array.pop-back! &stack)
                      maybe-rc (Pair.a &frame)
                      is-exit @(Pair.b &frame)]
                  (match-ref maybe-rc
                    (Maybe.Nothing) ()
                    (Maybe.Just rc)
                      (let [node-ref (Rc.value-ref rc)]
                        (if is-exit
                          (match-ref (Persistent.TrieNode.label node-ref)
                            (Maybe.Nothing) ()
                            (Maybe.Just _) (ignore (Array.pop-back! &path)))
                          (do
                            (set! stack
                                  (Array.push-back stack
                                                   (Pair.init @(Persistent.TrieNode.sibling node-ref)
                                                              false)))
                            (set! stack
                                  (Array.push-back stack
                                                   (Pair.init (Maybe.Just @rc)
                                                              true)))
                            (match-ref (Persistent.TrieNode.label node-ref)
                              (Maybe.Nothing) ()
                              (Maybe.Just l)
                                (set! path (Array.push-back path @l)))
                            (match-ref (Persistent.TrieNode.value node-ref)
                              (Maybe.Nothing) ()
                              (Maybe.Just v) (~f (Pair.init @&path @v)))
                            (set! stack
                                  (Array.push-back stack
                                                   (Pair.init @(Persistent.TrieNode.child node-ref)
                                                              false))))))))))
)

          (doc to-array
            "Copy all entries into an `Array` of `(Pair key value)`.")
          (sig to-array
               (Fn [(Ref (Persistent.Trie k v) q)]
                   (Array (Pair (Array k) v))))
          (defn to-array [trie-ref]
            (reduce &(fn [acc p] (Array.push-back acc p)) [] trie-ref))

          (doc from-array
            "Build a trie from an `Array` of `(Pair key value)` entries.")
          (sig from-array
               (Fn
                 [(Ref (Array (Pair (Array k) v)) q)]
                 (Persistent.Trie k v)))
          (defn from-array [arr-ref]
            (Array.reduce
              &(fn [acc p] (insert (Pair.a p) @(Pair.b p) &acc))
              (empty)
              arr-ref))

          (doc keys "Collect all keys into an `Array`.")
          (sig keys (Fn [(Ref (Persistent.Trie k v) q)] (Array (Array k))))
          (defn keys [trie-ref]
            (reduce &(fn [acc p] (Array.push-back acc @(Pair.a &p))) [] trie-ref))

          (doc values "Collect all values into an `Array`.")
          (sig values (Fn [(Ref (Persistent.Trie k v) q)] (Array v)))
          (defn values [trie-ref]
            (reduce-values &(fn [acc v] (Array.push-back acc v)) [] trie-ref))

          (doc = "Structural equality: same size and same set of entries.")
          (sig = (Fn [(Ref (Persistent.Trie k v) q) (Ref (Persistent.Trie k v) q)] Bool))
          (defn = [a-ref b-ref]
            (if (/= @(Persistent.Trie.count a-ref) @(Persistent.Trie.count b-ref))
              false
              (reduce
                &(fn [acc p]
                  (and acc
                       (match (get (Pair.a &p) b-ref)
                         (Maybe.Nothing) false
                         (Maybe.Just bv) (= &bv (Pair.b &p)))))
                true
                a-ref)))
          (implements = Persistent.Trie.=)

          (doc map-values
            "Apply a function to each value, returning a new trie with the same keys.")
          (sig map-values
               (Fn [(Ref (Fn [v] v) q) (Ref (Persistent.Trie k v) r)] (Persistent.Trie k v)))
          (defn map-values [f trie-ref]
            (reduce
              &(fn [acc p] (insert (Pair.a &p) (~f @(Pair.b &p)) &acc))
              (empty)
              trie-ref))

          (doc filter
            "Keep only entries whose `(Pair key value)` satisfies a predicate.")
          (sig filter
               (Fn
                 [(Ref
                    (Fn [(Ref (Pair (Array k) v) q)] Bool)
                    r)
                  (Ref (Persistent.Trie k v) s)]
                 (Persistent.Trie k v)))
          (defn filter [pred trie-ref]
            (reduce
              &(fn [acc p]
                (if (~pred &p) (insert (Pair.a &p) @(Pair.b &p) &acc) acc))
              (empty)
              trie-ref))

          (doc any? "Return true if any entry satisfies the predicate.")
          (sig any?
               (Fn
                 [(Ref
                    (Fn [(Ref (Pair (Array k) v) q)] Bool)
                    r)
                  (Ref (Persistent.Trie k v) s)]
                 Bool))
          (defn any? [pred coll-ref]
            (reduce &(fn [acc x] (or acc (~pred &x))) false coll-ref))

          (doc all? "Return true if all entries satisfy the predicate.")
          (sig all?
               (Fn
                 [(Ref
                    (Fn [(Ref (Pair (Array k) v) q)] Bool)
                    r)
                  (Ref (Persistent.Trie k v) s)]
                 Bool))
          (defn all? [pred coll-ref]
            (reduce &(fn [acc x] (and acc (~pred &x))) true coll-ref))

          (doc str "Diagnostic formatting for a trie.")
          (sig str (Fn [(Ref (Persistent.Trie k v) q)] String))
          (defn str [trie-ref]
            (fmt "(PersistentTrie size=%ld)" (length trie-ref)))

          (sig prn (Fn [(Ref (Persistent.Trie k v) q)] String))
          (defn prn [trie-ref] (str trie-ref)))
)

(defmodule Persistent
        (deftype (Deque a) [front (Persistent.List a)
                        rear (Persistent.List a)
                        count Long])

        (defmodule Deque
          (private reverse-list)
          (hidden reverse-list)
          (sig reverse-list (Fn [(Ref (Persistent.List a) q)] (Persistent.List a)))
          (defn reverse-list [src-ref]
            (let-do [current @src-ref
                     acc (Persistent.List.empty)
                     keep-going true]
              (while-do keep-going
                (match (Persistent.List.head &current)
                  (Maybe.Nothing) (set! keep-going false)
                  (Maybe.Just value)
                    (do
                      (set! acc (Persistent.List.prepend value &acc))
                      (match (Persistent.List.tail &current)
                        (Maybe.Just next-src) (set! current next-src)
                        (Maybe.Nothing) (set! keep-going false)))))
              acc))

          (doc empty "Create an empty deque.")
          (sig empty (Fn [] (Persistent.Deque a)))
          (defn empty [] (Persistent.Deque.init (Persistent.List.empty) (Persistent.List.empty) 0l))

          (doc singleton "Create a singleton deque.")
          (sig singleton (Fn [a] (Persistent.Deque a)))
          (defn singleton [value]
            (Persistent.Deque.init (Persistent.List.singleton value) (Persistent.List.empty) 1l))

          (doc length "Return the logical deque length in O(1).")
          (sig length (Fn [(Ref (Persistent.Deque a) q)] Long))
          (defn length [dq-ref] @(Persistent.Deque.count dq-ref))

          (doc empty? "Returns `true` when deque has no elements.")
          (sig empty? (Fn [(Ref (Persistent.Deque a) q)] Bool))
          (defn empty? [dq-ref] (= (length dq-ref) 0l))

          (doc push-front "Push a value onto the front, returning a new deque.")
          (sig push-front (Fn [a (Ref (Persistent.Deque a) q)] (Persistent.Deque a)))
          (defn push-front [value dq-ref]
            (let [front2 (Persistent.List.prepend value (Persistent.Deque.front dq-ref))
                  count2 (Long.inc @(Persistent.Deque.count dq-ref))]
              (Persistent.Deque.init front2 @(Persistent.Deque.rear dq-ref) count2)))

          (doc push-back "Push a value onto the back, returning a new deque.")
          (sig push-back (Fn [a (Ref (Persistent.Deque a) q)] (Persistent.Deque a)))
          (defn push-back [value dq-ref]
            (let [rear2 (Persistent.List.prepend value (Persistent.Deque.rear dq-ref))
                  count2 (Long.inc @(Persistent.Deque.count dq-ref))]
              (Persistent.Deque.init @(Persistent.Deque.front dq-ref) rear2 count2)))

          (doc peek-front "Read the front value, if any.")
          (sig peek-front (Fn [(Ref (Persistent.Deque a) q)] (Maybe a)))
          (defn peek-front [dq-ref]
            (if (Persistent.Deque.empty? dq-ref)
              (Maybe.Nothing)
              (if (Persistent.List.empty? (Persistent.Deque.front dq-ref))
                (let [front2 (reverse-list (Persistent.Deque.rear dq-ref))]
                  (Persistent.List.head &front2))
                (Persistent.List.head (Persistent.Deque.front dq-ref)))))

          (doc peek-back "Read the back value, if any.")
          (sig peek-back (Fn [(Ref (Persistent.Deque a) q)] (Maybe a)))
          (defn peek-back [dq-ref]
            (if (Persistent.Deque.empty? dq-ref)
              (Maybe.Nothing)
              (if (Persistent.List.empty? (Persistent.Deque.rear dq-ref))
                (let [rear2 (reverse-list (Persistent.Deque.front dq-ref))]
                  (Persistent.List.head &rear2))
                (Persistent.List.head (Persistent.Deque.rear dq-ref)))))

          (doc pop-front
            "Pop the front value, returning `(Maybe (Pair value next-deque))`.")
          (sig pop-front (Fn [(Ref (Persistent.Deque a) q)] (Maybe (Pair a (Persistent.Deque a)))))
          (defn pop-front [dq-ref]
            (if (Persistent.Deque.empty? dq-ref)
              (Maybe.Nothing)
              (let [front-empty? (Persistent.List.empty? (Persistent.Deque.front dq-ref))
                    nf (if front-empty?
                         (reverse-list (Persistent.Deque.rear dq-ref))
                         @(Persistent.Deque.front dq-ref))
                    nr (if front-empty?
                         (Persistent.List.empty)
                         @(Persistent.Deque.rear dq-ref))
                    count2 (Long.dec @(Persistent.Deque.count dq-ref))]
                (match (Persistent.List.head &nf)
                  (Maybe.Nothing) (Maybe.Nothing)
                  (Maybe.Just value)
                    (match (Persistent.List.tail &nf)
                      (Maybe.Just next-front)
                        (Maybe.Just (Pair.init value (Persistent.Deque.init next-front nr count2)))
                      (Maybe.Nothing)
                        (Maybe.Just (Pair.init value (Persistent.Deque.init (Persistent.List.empty) nr count2))))))))

          (doc pop-back
            "Pop the back value, returning `(Maybe (Pair value next-deque))`.")
          (sig pop-back (Fn [(Ref (Persistent.Deque a) q)] (Maybe (Pair a (Persistent.Deque a)))))
          (defn pop-back [dq-ref]
            (if (Persistent.Deque.empty? dq-ref)
              (Maybe.Nothing)
              (let [rear-empty? (Persistent.List.empty? (Persistent.Deque.rear dq-ref))
                    nr (if rear-empty?
                         (reverse-list (Persistent.Deque.front dq-ref))
                         @(Persistent.Deque.rear dq-ref))
                    nf (if rear-empty?
                         (Persistent.List.empty)
                         @(Persistent.Deque.front dq-ref))
                    count2 (Long.dec @(Persistent.Deque.count dq-ref))]
                (match (Persistent.List.head &nr)
                  (Maybe.Nothing) (Maybe.Nothing)
                  (Maybe.Just value)
                    (match (Persistent.List.tail &nr)
                      (Maybe.Just next-rear)
                        (Maybe.Just (Pair.init value (Persistent.Deque.init nf next-rear count2)))
                      (Maybe.Nothing)
                        (Maybe.Just (Pair.init value (Persistent.Deque.init nf (Persistent.List.empty) count2))))))))

          (doc ptr-eq
            "Pointer identity check for deque front/rear list roots plus count equality.")
          (sig ptr-eq (Fn [(Ref (Persistent.Deque a) q) (Ref (Persistent.Deque a) r)] Bool))
          (defn ptr-eq [a-ref b-ref]
            (and
              (= @(Persistent.Deque.count a-ref) @(Persistent.Deque.count b-ref))
              (Persistent.List.ptr-eq (Persistent.Deque.front a-ref) (Persistent.Deque.front b-ref))
              (Persistent.List.ptr-eq (Persistent.Deque.rear a-ref) (Persistent.Deque.rear b-ref))))

          (doc reduce "Reduce the deque front-to-back with accumulator.")
          (sig reduce (Fn [(Ref (Fn [b a] b) q) b (Ref (Persistent.Deque a) r)] b))
          (defn reduce [f init dq-ref]
            (let [after-front (Persistent.List.reduce f init (Persistent.Deque.front dq-ref))
                  rear-rev (reverse-list (Persistent.Deque.rear dq-ref))]
              (Persistent.List.reduce f after-front &rear-rev)))

          (doc each
            "Invoke a side-effecting function on each element front-to-back.")
          (sig each (Fn [(Ref (Fn [a] ()) q) (Ref (Persistent.Deque a) r)] ()))
          (defn each [f dq-ref]
            (do
              (Persistent.List.each f (Persistent.Deque.front dq-ref))
              (let [rear-rev (reverse-list (Persistent.Deque.rear dq-ref))]
                (Persistent.List.each f &rear-rev))))

          (doc to-array "Copy all values into an `Array` front-to-back.")
          (sig to-array (Fn [(Ref (Persistent.Deque a) q)] (Array a)))
          (defn to-array [dq-ref]
            (reduce &(fn [acc x] (Array.push-back acc x)) [] dq-ref))

          (doc from-array
            "Build a deque from an `Array`, preserving front-to-back order.")
          (sig from-array (Fn [(Ref (Array a) q)] (Persistent.Deque a)))
          (defn from-array [arr-ref]
            (Array.reduce &(fn [acc x] (push-back @x &acc)) (empty) arr-ref))

          (doc =
            "Structural equality: same length and pairwise equal front-to-back sequence.")
          (sig = (Fn [(Ref (Persistent.Deque a) q) (Ref (Persistent.Deque a) q)] Bool))
          (defn = [a-ref b-ref]
            (if (/= @(Persistent.Deque.count a-ref) @(Persistent.Deque.count b-ref))
              false
              (let [aa (to-array a-ref)
                    ab (to-array b-ref)] (= &aa &ab))))
          (implements = Persistent.Deque.=)

          (doc map
            "Apply a function to each element, returning a new deque in front-to-back order.")
          (sig map
               (Fn [(Ref (Fn [a] a) q) (Ref (Persistent.Deque a) r)] (Persistent.Deque a)))
          (defn map [f dq-ref]
            (reduce &(fn [acc x] (push-back (~f x) &acc)) (empty) dq-ref))

          (doc filter
            "Keep only elements satisfying a predicate, preserving front-to-back order.")
          (sig filter
               (Fn [(Ref (Fn [(Ref a q)] Bool) r) (Ref (Persistent.Deque a) s)] (Persistent.Deque a)))
          (defn filter [pred dq-ref]
            (reduce
              &(fn [acc x] (if (~pred &x) (push-back x &acc) acc))
              (empty)
              dq-ref))

          (doc any? "Return true if any element satisfies the predicate.")
          (sig any?
               (Fn [(Ref (Fn [(Ref a q)] Bool) r) (Ref (Persistent.Deque a) s)] Bool))
          (defn any? [pred coll-ref]
            (reduce &(fn [acc x] (or acc (~pred &x))) false coll-ref))

          (doc all? "Return true if all elements satisfy the predicate.")
          (sig all?
               (Fn [(Ref (Fn [(Ref a q)] Bool) r) (Ref (Persistent.Deque a) s)] Bool))
          (defn all? [pred coll-ref]
            (reduce &(fn [acc x] (and acc (~pred &x))) true coll-ref))

          (doc str "Diagnostic formatting for a deque.")
          (sig str (Fn [(Ref (Persistent.Deque a) q)] String))
          (defn str [dq-ref]
            (fmt "(PersistentDeque length=%ld)" (length dq-ref)))

          (sig prn (Fn [(Ref (Persistent.Deque a) q)] String))
          (defn prn [dq-ref] (str dq-ref)))
)

(defmodule Persistent
        (deftype (OrdMapNode k v)
          [key k
           value v
           left (Maybe (Rc (Persistent.OrdMapNode k v)))
           right (Maybe (Rc (Persistent.OrdMapNode k v)))
           height Int])
        (hidden OrdMapNode)

        (deftype (OrdMap k v) [root (Maybe (Rc (Persistent.OrdMapNode k v)))
                        count Long])

        (defmodule OrdMap
          (private subtree-height)
          (hidden subtree-height)
          (sig subtree-height (Fn [(Ref (Maybe (Rc (Persistent.OrdMapNode k v))) q)] Int))
          (defn subtree-height [maybe-ref]
            (match-ref maybe-ref
              (Maybe.Nothing) 0
              (Maybe.Just rc) @(Persistent.OrdMapNode.height (Rc.value-ref rc))))

          (private make-node)
          (hidden make-node)
          (sig make-node
               (Fn
                 [k
                  v
                  (Maybe (Rc (Persistent.OrdMapNode k v)))
                  (Maybe (Rc (Persistent.OrdMapNode k v)))]
                 (Persistent.OrdMapNode k v)))
          (defn make-node [key value left right]
            (let [h (Int.inc
                    (max (subtree-height &left) (subtree-height &right)))]
              (Persistent.OrdMapNode.init key value left right h)))

          (private rotate-right-node)
          (hidden rotate-right-node)
          (sig rotate-right-node (Fn [(Ref (Persistent.OrdMapNode k v) q)] (Maybe (Rc (Persistent.OrdMapNode k v)))))
          (defn rotate-right-node [z-ref]
            (match-ref (Persistent.OrdMapNode.left z-ref)
              (Maybe.Nothing)
                (Maybe.Just
                  (Rc.new
                    (make-node @(Persistent.OrdMapNode.key z-ref)
                               @(Persistent.OrdMapNode.value z-ref)
                               @(Persistent.OrdMapNode.left z-ref)
                               @(Persistent.OrdMapNode.right z-ref))))
              (Maybe.Just y-rc)
                (let [y (Rc.value-ref y-rc)
                      z-prime (make-node @(Persistent.OrdMapNode.key z-ref)
                                         @(Persistent.OrdMapNode.value z-ref)
                                         @(Persistent.OrdMapNode.right y)
                                         @(Persistent.OrdMapNode.right z-ref))
                      new-root (make-node @(Persistent.OrdMapNode.key y)
                                          @(Persistent.OrdMapNode.value y)
                                          @(Persistent.OrdMapNode.left y)
                                          (Maybe.Just (Rc.new z-prime)))]
                  (Maybe.Just (Rc.new new-root)))))

          (private rotate-left-node)
          (hidden rotate-left-node)
          (sig rotate-left-node (Fn [(Ref (Persistent.OrdMapNode k v) q)] (Maybe (Rc (Persistent.OrdMapNode k v)))))
          (defn rotate-left-node [x-ref]
            (match-ref (Persistent.OrdMapNode.right x-ref)
              (Maybe.Nothing)
                (Maybe.Just
                  (Rc.new
                    (make-node @(Persistent.OrdMapNode.key x-ref)
                               @(Persistent.OrdMapNode.value x-ref)
                               @(Persistent.OrdMapNode.left x-ref)
                               @(Persistent.OrdMapNode.right x-ref))))
              (Maybe.Just y-rc)
                (let [y (Rc.value-ref y-rc)
                      x-prime (make-node @(Persistent.OrdMapNode.key x-ref)
                                         @(Persistent.OrdMapNode.value x-ref)
                                         @(Persistent.OrdMapNode.left x-ref)
                                         @(Persistent.OrdMapNode.left y))
                      new-root (make-node @(Persistent.OrdMapNode.key y)
                                          @(Persistent.OrdMapNode.value y)
                                          (Maybe.Just (Rc.new x-prime))
                                          @(Persistent.OrdMapNode.right y))]
                  (Maybe.Just (Rc.new new-root)))))

          (private balance-node)
          (hidden balance-node)
          (sig balance-node
               (Fn [(Ref (Maybe (Rc (Persistent.OrdMapNode k v))) q)] (Maybe (Rc (Persistent.OrdMapNode k v)))))
          (defn balance-node [maybe-ref]
            (match-ref maybe-ref
              (Maybe.Nothing) (Maybe.Nothing)
              (Maybe.Just rc)
                (let [node (Rc.value-ref rc)
                      lh (subtree-height (Persistent.OrdMapNode.left node))
                      rh (subtree-height (Persistent.OrdMapNode.right node))
                      bf (- lh rh)]
                  (if (> bf 1)
                    (match-ref (Persistent.OrdMapNode.left node)
                      (Maybe.Nothing) @maybe-ref
                      (Maybe.Just left-rc)
                        (let [left (Rc.value-ref left-rc)
                              left-bf (- (subtree-height (Persistent.OrdMapNode.left left))
                                         (subtree-height (Persistent.OrdMapNode.right left)))]
                          (if (< left-bf 0)
                            (let [rotated-left (rotate-left-node left)
                                  adjusted (make-node @(Persistent.OrdMapNode.key node)
                                                      @(Persistent.OrdMapNode.value node)
                                                      rotated-left
                                                      @(Persistent.OrdMapNode.right node))]
                              (rotate-right-node &adjusted))
                            (rotate-right-node node))))
                    (if (< bf -1)
                      (match-ref (Persistent.OrdMapNode.right node)
                        (Maybe.Nothing) @maybe-ref
                        (Maybe.Just right-rc)
                          (let [right (Rc.value-ref right-rc)
                                right-bf (- (subtree-height (Persistent.OrdMapNode.left right))
                                            (subtree-height (Persistent.OrdMapNode.right right)))]
                            (if (> right-bf 0)
                              (let [rotated-right (rotate-right-node right)
                                    adjusted (make-node @(Persistent.OrdMapNode.key node)
                                                        @(Persistent.OrdMapNode.value node)
                                                        @(Persistent.OrdMapNode.left node)
                                                        rotated-right)]
                                (rotate-left-node &adjusted))
                              (rotate-left-node node))))
                      @maybe-ref)))))

          (private get-node)
          (hidden get-node)
          (sig get-node
               (Fn [k (Ref (Maybe (Rc (Persistent.OrdMapNode k v))) q)] (Maybe v)))
          (defn get-node [key root-ref]
            (match-ref root-ref
              (Maybe.Nothing) (Maybe.Nothing)
              (Maybe.Just node-rc)
                (let [node (Rc.value-ref node-rc)
                      k @(Persistent.OrdMapNode.key node)]
                  (if (< key k)
                    (get-node key (Persistent.OrdMapNode.left node))
                    (if (> key k)
                      (get-node key (Persistent.OrdMapNode.right node))
                      (Maybe.Just @(Persistent.OrdMapNode.value node)))))))

          (private insert-node)
          (hidden insert-node)
          (sig insert-node
               (Fn
                 [k v (Ref (Maybe (Rc (Persistent.OrdMapNode k v))) q)]
                 (Pair (Maybe (Rc (Persistent.OrdMapNode k v))) Bool)))
          (defn insert-node [key value root-ref]
            (let-do [current @root-ref
                     path (the (Array (Pair (Rc (Persistent.OrdMapNode k v)) Bool)) [])
                     new-child (Maybe.Nothing)
                     inserted false
                     keep-going true]
              (while-do keep-going
                (match-ref &current
                  (Maybe.Nothing)
                    (do
                      (set! new-child
                            (Maybe.Just
                              (Rc.new
                                (make-node @&key
                                           @&value
                                           (Maybe.Nothing)
                                           (Maybe.Nothing)))))
                      (set! inserted true)
                      (set! keep-going false))
                  (Maybe.Just node-rc)
                    (let [node (Rc.value-ref node-rc)
                          k @(Persistent.OrdMapNode.key node)]
                      (if (< key k)
                        (do
                          (set! path
                                (Array.push-back path (Pair.init @node-rc true)))
                          (set! current @(Persistent.OrdMapNode.left node)))
                        (if (> key k)
                          (do
                            (set! path
                                  (Array.push-back path
                                                   (Pair.init @node-rc false)))
                            (set! current @(Persistent.OrdMapNode.right node)))
                          (do
                            (set! new-child
                                  (Maybe.Just
                                    (Rc.new
                                      (Persistent.OrdMapNode.init @(Persistent.OrdMapNode.key node)
                                                  @&value
                                                  @(Persistent.OrdMapNode.left node)
                                                  @(Persistent.OrdMapNode.right node)
                                                  @(Persistent.OrdMapNode.height node)))))
                            (set! keep-going false)))))))
              (let-do [i (Int.dec (Array.length &path))]
                (while-do (>= i 0)
                  (let-do [frame (Array.unsafe-nth &path i)
                           parent-node (Rc.value-ref (Pair.a frame))
                           went-left @(Pair.b frame)
                           rebuilt (if went-left
                             (make-node @(Persistent.OrdMapNode.key parent-node)
                                        @(Persistent.OrdMapNode.value parent-node)
                                        @&new-child
                                        @(Persistent.OrdMapNode.right parent-node))
                             (make-node @(Persistent.OrdMapNode.key parent-node)
                                        @(Persistent.OrdMapNode.value parent-node)
                                        @(Persistent.OrdMapNode.left parent-node)
                                        @&new-child))
                           wrapped (Maybe.Just (Rc.new rebuilt))]
                    (set! new-child (balance-node &wrapped))
                    (set! i (Int.dec i)))))
              (Pair.init new-child inserted)))

          (private extract-min)
          (hidden extract-min)
          (sig extract-min
               (Fn [(Ref (Rc (Persistent.OrdMapNode k v)) q)]
                   (Pair (Persistent.OrdMapNode k v) (Maybe (Rc (Persistent.OrdMapNode k v))))))
          (defn extract-min [node-rc-ref]
            (let-do [current-rc @node-rc-ref
                     path (the (Array (Rc (Persistent.OrdMapNode k v))) [])
                     new-left (the (Maybe (Rc (Persistent.OrdMapNode k v))) (Maybe.Nothing))
                     keep-going true]
              (while-do keep-going
                (let [node (Rc.get &current-rc)]
                  (match-ref (Persistent.OrdMapNode.left &node)
                    (Maybe.Nothing)
                      (do
                        (set! new-left @(Persistent.OrdMapNode.right &node))
                        (set! keep-going false))
                    (Maybe.Just left-rc)
                      (do
                        (set! path (Array.push-back path @&current-rc))
                        (set! current-rc @left-rc)))))
              (let-do [j (Int.dec (Array.length &path))]
                (while-do (>= j 0)
                  (let-do [parent-rc (Array.unsafe-nth &path j)
                           parent-node (Rc.get parent-rc)
                           rebuilt (make-node @(Persistent.OrdMapNode.key &parent-node)
                                              @(Persistent.OrdMapNode.value &parent-node)
                                              @&new-left
                                              @(Persistent.OrdMapNode.right &parent-node))
                           wrapped (Maybe.Just (Rc.new rebuilt))]
                    (set! new-left (balance-node &wrapped))
                    (set! j (Int.dec j)))))
              (Pair.init (Rc.get &current-rc) new-left)))

          (private remove-node)
          (hidden remove-node)
          (sig remove-node
               (Fn
                 [k (Ref (Maybe (Rc (Persistent.OrdMapNode k v))) q)]
                 (Pair (Maybe (Rc (Persistent.OrdMapNode k v))) Bool)))
          (defn remove-node [key root-ref]
            (let-do [current @root-ref
                     path (the (Array (Pair (Rc (Persistent.OrdMapNode k v)) Bool)) [])
                     new-subtree (the (Maybe (Rc (Persistent.OrdMapNode k v))) (Maybe.Nothing))
                     removed false
                     keep-going true]
              (while-do keep-going
                (match-ref &current
                  (Maybe.Nothing) (set! keep-going false)
                  (Maybe.Just node-rc)
                    (let [node (Rc.get node-rc)
                          k @(Persistent.OrdMapNode.key &node)]
                      (if (< @&key k)
                        (do
                          (set! path
                                (Array.push-back path (Pair.init @node-rc true)))
                          (set! current @(Persistent.OrdMapNode.left &node)))
                        (if (> @&key k)
                          (do
                            (set! path
                                  (Array.push-back path
                                                   (Pair.init @node-rc false)))
                            (set! current @(Persistent.OrdMapNode.right &node)))
                          (do
                            (match-ref (Persistent.OrdMapNode.left &node)
                              (Maybe.Nothing)
                                (set! new-subtree @(Persistent.OrdMapNode.right &node))
                              (Maybe.Just _)
                                (match-ref (Persistent.OrdMapNode.right &node)
                                  (Maybe.Nothing)
                                    (set! new-subtree @(Persistent.OrdMapNode.left &node))
                                  (Maybe.Just right-rc)
                                    (let [rec (extract-min right-rc)
                                          min-node @(Pair.a &rec)
                                          right2 @(Pair.b &rec)
                                          node2 (make-node @(Persistent.OrdMapNode.key &min-node)
                                                           @(Persistent.OrdMapNode.value &min-node)
                                                           @(Persistent.OrdMapNode.left &node)
                                                           right2)
                                          wrapped (Maybe.Just (Rc.new node2))]
                                      (set! new-subtree (balance-node &wrapped)))))
                            (set! removed true)
                            (set! keep-going false)))))))
              (if (not removed)
                (Pair.init @root-ref false)
                (let-do [j (Int.dec (Array.length &path))]
                  (while-do (>= j 0)
                    (let-do [frame (Array.unsafe-nth &path j)
                             parent-rc (Pair.a frame)
                             went-left @(Pair.b frame)
                             parent-node (Rc.get parent-rc)
                             rebuilt (if went-left
                               (make-node @(Persistent.OrdMapNode.key &parent-node)
                                          @(Persistent.OrdMapNode.value &parent-node)
                                          @&new-subtree
                                          @(Persistent.OrdMapNode.right &parent-node))
                               (make-node @(Persistent.OrdMapNode.key &parent-node)
                                          @(Persistent.OrdMapNode.value &parent-node)
                                          @(Persistent.OrdMapNode.left &parent-node)
                                          @&new-subtree))
                             wrapped (Maybe.Just (Rc.new rebuilt))]
                      (set! new-subtree (balance-node &wrapped))
                      (set! j (Int.dec j))))
                  (Pair.init new-subtree true)))))

          (private min-node)
          (hidden min-node)
          (sig min-node (Fn [(Ref (Rc (Persistent.OrdMapNode k v)) q)] (Persistent.OrdMapNode k v)))
          (defn min-node [node-rc-ref]
            (let-do [current-rc @node-rc-ref
                     keep-going true]
              (while-do keep-going
                (let [node (Rc.get &current-rc)]
                  (match-ref (Persistent.OrdMapNode.left &node)
                    (Maybe.Nothing) (set! keep-going false)
                    (Maybe.Just left-rc) (set! current-rc @left-rc))))
              (Rc.get &current-rc)))

          (private max-node)
          (hidden max-node)
          (sig max-node (Fn [(Ref (Rc (Persistent.OrdMapNode k v)) q)] (Persistent.OrdMapNode k v)))
          (defn max-node [node-rc-ref]
            (let-do [current-rc @node-rc-ref
                     keep-going true]
              (while-do keep-going
                (let [node (Rc.get &current-rc)]
                  (match-ref (Persistent.OrdMapNode.right &node)
                    (Maybe.Nothing) (set! keep-going false)
                    (Maybe.Just right-rc) (set! current-rc @right-rc))))
              (Rc.get &current-rc)))

          (doc empty "Create an empty ordered map.")
          (sig empty (Fn [] (Persistent.OrdMap k v)))
          (defn empty [] (Persistent.OrdMap.init (Maybe.Nothing) 0l))

          (doc singleton "Create an ordered map with one key/value pair.")
          (sig singleton (Fn [k v] (Persistent.OrdMap k v)))
          (defn singleton [key value]
            (let [node (make-node key value (Maybe.Nothing) (Maybe.Nothing))]
              (Persistent.OrdMap.init (Maybe.Just (Rc.new node)) 1l)))

          (doc length "Return number of stored key/value pairs.")
          (sig length (Fn [(Ref (Persistent.OrdMap k v) q)] Long))
          (defn length [map-ref] @(Persistent.OrdMap.count map-ref))

          (doc empty? "Returns `true` when map contains no entries.")
          (sig empty? (Fn [(Ref (Persistent.OrdMap k v) q)] Bool))
          (defn empty? [map-ref] (= (length map-ref) 0l))

          (doc height
            "Return the height of the underlying AVL tree (0 for empty).")
          (sig height (Fn [(Ref (Persistent.OrdMap k v) q)] Int))
          (defn height [map-ref] (subtree-height (Persistent.OrdMap.root map-ref)))

          (doc insert "Insert or replace value for key, returning a new map.")
          (sig insert (Fn [k v (Ref (Persistent.OrdMap k v) q)] (Persistent.OrdMap k v)))
          (defn insert [key value map-ref]
            (let [rec (insert-node key value (Persistent.OrdMap.root map-ref))
                  root2 @(Pair.a &rec)
                  inserted? @(Pair.b &rec)
                  count2 (if inserted?
                    (Long.inc @(Persistent.OrdMap.count map-ref))
                    @(Persistent.OrdMap.count map-ref))]
              (Persistent.OrdMap.init root2 count2)))

          (doc get "Lookup key, returning `Maybe` value.")
          (sig get (Fn [k (Ref (Persistent.OrdMap k v) q)] (Maybe v)))
          (defn get [key map-ref] (get-node key (Persistent.OrdMap.root map-ref)))

          (doc contains? "Returns `true` when key exists in map.")
          (sig contains? (Fn [k (Ref (Persistent.OrdMap k v) q)] Bool))
          (defn contains? [key map-ref]
            (match (get key map-ref) (Maybe.Nothing) false (Maybe.Just _) true))

          (doc remove "Remove key (if present), returning a new map.")
          (sig remove (Fn [k (Ref (Persistent.OrdMap k v) q)] (Persistent.OrdMap k v)))
          (defn remove [key map-ref]
            (let [rec (remove-node key (Persistent.OrdMap.root map-ref))
                  root2 @(Pair.a &rec)
                  removed? @(Pair.b &rec)
                  count2 (if removed?
                    (Long.dec @(Persistent.OrdMap.count map-ref))
                    @(Persistent.OrdMap.count map-ref))]
              (Persistent.OrdMap.init root2 count2)))

          (doc min-key "Return minimum key, if any.")
          (sig min-key (Fn [(Ref (Persistent.OrdMap k v) q)] (Maybe k)))
          (defn min-key [map-ref]
            (match @(Persistent.OrdMap.root map-ref)
              (Maybe.Nothing) (Maybe.Nothing)
              (Maybe.Just root-rc)
                (let [node (min-node &root-rc)] (Maybe.Just @(Persistent.OrdMapNode.key &node)))))

          (doc max-key "Return maximum key, if any.")
          (sig max-key (Fn [(Ref (Persistent.OrdMap k v) q)] (Maybe k)))
          (defn max-key [map-ref]
            (match @(Persistent.OrdMap.root map-ref)
              (Maybe.Nothing) (Maybe.Nothing)
              (Maybe.Just root-rc)
                (let [node (max-node &root-rc)] (Maybe.Just @(Persistent.OrdMapNode.key &node)))))

          (doc ptr-eq
            "Pointer identity check for root node plus count equality.")
          (sig ptr-eq (Fn [(Ref (Persistent.OrdMap k v) q) (Ref (Persistent.OrdMap k v) r)] Bool))
          (defn ptr-eq [a-ref b-ref]
            (and
              (= @(Persistent.OrdMap.count a-ref) @(Persistent.OrdMap.count b-ref))
              (match @(Persistent.OrdMap.root a-ref)
                (Maybe.Nothing)
                  (match @(Persistent.OrdMap.root b-ref)
                    (Maybe.Nothing) true
                    (Maybe.Just _) false)
                (Maybe.Just a-root)
                  (match @(Persistent.OrdMap.root b-ref)
                    (Maybe.Just b-root) (Rc.ptr-eq &a-root &b-root)
                    (Maybe.Nothing) false))))

          (doc reduce "Reduce in ascending key order with accumulator.")
          (sig reduce
               (Fn
                 [(Ref (Fn [a (Pair k v)] a) q)
                  a
                  (Ref (Persistent.OrdMap k v) r)]
                 a))
          (defn reduce [f init map-ref]
            (let-do [stack (the (Array (Rc (Persistent.OrdMapNode k v))) [])
                     current @(Persistent.OrdMap.root map-ref)
                     acc init
                     keep-going true]
              (while-do keep-going
                (let-do [descending true]
                  (while-do descending
                    (match-ref &current
                      (Maybe.Nothing) (set! descending false)
                      (Maybe.Just rc)
                        (do
                          (set! stack (Array.push-back stack @rc))
                          (let [node (Rc.get rc)]
                            (set! current @(Persistent.OrdMapNode.left &node)))))))
                (if (= (Array.length &stack) 0)
                  (set! keep-going false)
                  (let [top-rc (Array.pop-back! &stack)
                        node (Rc.get &top-rc)
                        pair (Pair.init @(Persistent.OrdMapNode.key &node) @(Persistent.OrdMapNode.value &node))]
                    (do
                      (set! acc (~f acc pair))
                      (set! current @(Persistent.OrdMapNode.right &node))))))
              acc))

          (doc each
            "Invoke a side-effecting function on each `(Pair key value)` in ascending key order.")
          (sig each
               (Fn
                 [(Ref (Fn [(Pair k v)] ()) q) (Ref (Persistent.OrdMap k v) r)]
                 ()))
          (defn each [f map-ref]
            (let-do [stack (the (Array (Rc (Persistent.OrdMapNode k v))) [])
                     current @(Persistent.OrdMap.root map-ref)
                     keep-going true]
              (while-do keep-going
                (let-do [descending true]
                  (while-do descending
                    (match-ref &current
                      (Maybe.Nothing) (set! descending false)
                      (Maybe.Just rc)
                        (do
                          (set! stack (Array.push-back stack @rc))
                          (let [node (Rc.get rc)]
                            (set! current @(Persistent.OrdMapNode.left &node)))))))
                (if (= (Array.length &stack) 0)
                  (set! keep-going false)
                  (let [top-rc (Array.pop-back! &stack)
                        node (Rc.get &top-rc)]
                    (do
                      (~f (Pair.init @(Persistent.OrdMapNode.key &node) @(Persistent.OrdMapNode.value &node)))
                      (set! current @(Persistent.OrdMapNode.right &node))))))))

          (doc to-array
            "Copy all `(Pair key value)` entries into an `Array` in ascending key order.")
          (sig to-array
               (Fn [(Ref (Persistent.OrdMap k v) q)] (Array (Pair k v))))
          (defn to-array [map-ref]
            (reduce &(fn [acc p] (Array.push-back acc p)) [] map-ref))

          (doc from-array
            "Build an ordered map from an `Array` of `(Pair key value)` entries.")
          (sig from-array
               (Fn [(Ref (Array (Pair k v)) q)] (Persistent.OrdMap k v)))
          (defn from-array [arr-ref]
            (Array.reduce
              &(fn [acc p] (insert @(Pair.a p) @(Pair.b p) &acc))
              (empty)
              arr-ref))

          (doc keys "Collect keys into an `Array` in ascending order.")
          (sig keys (Fn [(Ref (Persistent.OrdMap k v) q)] (Array k)))
          (defn keys [map-ref]
            (reduce &(fn [acc p] (Array.push-back acc @(Pair.a &p))) [] map-ref))

          (doc values "Collect values into an `Array` in ascending key order.")
          (sig values (Fn [(Ref (Persistent.OrdMap k v) q)] (Array v)))
          (defn values [map-ref]
            (reduce &(fn [acc p] (Array.push-back acc @(Pair.b &p))) [] map-ref))

          (doc merge
            "Merge two maps. On key collision the second (right) map wins.")
          (sig merge (Fn [(Ref (Persistent.OrdMap k v) a) (Ref (Persistent.OrdMap k v) b)] (Persistent.OrdMap k v)))
          (defn merge [a-ref b-ref]
            (reduce
              &(fn [acc p] (insert @(Pair.a &p) @(Pair.b &p) &acc))
              @a-ref
              b-ref))

          (doc merge-with
            "Merge two maps with a conflict resolver. For keys in both maps, call the resolver with both values.")
          (sig merge-with
               (Fn
                 [(Ref (Fn [v v] v) q)
                  (Ref (Persistent.OrdMap k v) a)
                  (Ref (Persistent.OrdMap k v) b)]
                 (Persistent.OrdMap k v)))
          (defn merge-with [f a-ref b-ref]
            (reduce
              &(fn [acc p]
                (let [k @(Pair.a &p)
                      bv @(Pair.b &p)]
                  (match (get @&k &acc)
                    (Maybe.Nothing) (insert k bv &acc)
                    (Maybe.Just av) (insert k (~f av bv) &acc))))
              @a-ref
              b-ref))

          (doc =
            "Structural equality: same size and pairwise equal entries in ascending key order.")
          (sig = (Fn [(Ref (Persistent.OrdMap k v) q) (Ref (Persistent.OrdMap k v) q)] Bool))
          (defn = [a-ref b-ref]
            (if (/= @(Persistent.OrdMap.count a-ref) @(Persistent.OrdMap.count b-ref))
              false
              (let [aa (to-array a-ref)
                    ab (to-array b-ref)] (= &aa &ab))))
          (implements = Persistent.OrdMap.=)

          (doc map-values
            "Apply a function to each value, returning a new map with the same keys.")
          (sig map-values
               (Fn [(Ref (Fn [v] v) q) (Ref (Persistent.OrdMap k v) r)] (Persistent.OrdMap k v)))
          (defn map-values [f map-ref]
            (reduce
              &(fn [acc p] (insert @(Pair.a &p) (~f @(Pair.b &p)) &acc))
              (empty)
              map-ref))

          (doc filter
            "Keep only entries whose `(Pair key value)` satisfies a predicate.")
          (sig filter
               (Fn
                 [(Ref (Fn [(Ref (Pair k v) q)] Bool) r)
                  (Ref (Persistent.OrdMap k v) s)]
                 (Persistent.OrdMap k v)))
          (defn filter [pred map-ref]
            (reduce
              &(fn [acc p]
                (if (~pred &p) (insert @(Pair.a &p) @(Pair.b &p) &acc) acc))
              (empty)
              map-ref))

          (doc any? "Return true if any entry satisfies the predicate.")
          (sig any?
               (Fn
                 [(Ref (Fn [(Ref (Pair k v) q)] Bool) r)
                  (Ref (Persistent.OrdMap k v) s)]
                 Bool))
          (defn any? [pred coll-ref]
            (reduce &(fn [acc x] (or acc (~pred &x))) false coll-ref))

          (doc all? "Return true if all entries satisfy the predicate.")
          (sig all?
               (Fn
                 [(Ref (Fn [(Ref (Pair k v) q)] Bool) r)
                  (Ref (Persistent.OrdMap k v) s)]
                 Bool))
          (defn all? [pred coll-ref]
            (reduce &(fn [acc x] (and acc (~pred &x))) true coll-ref))

          (doc str "Diagnostic formatting for an ordered map.")
          (sig str (Fn [(Ref (Persistent.OrdMap k v) q)] String))
          (defn str [map-ref]
            (fmt "(PersistentOrdMap size=%ld)" (length map-ref)))

          (sig prn (Fn [(Ref (Persistent.OrdMap k v) q)] String))
          (defn prn [map-ref] (str map-ref)))
)

(defmodule Persistent
        (deftype (OrdSet a) [impl (Persistent.OrdMap a Bool)])

        (defmodule OrdSet
          (doc empty "Create an empty ordered set.")
          (sig empty (Fn [] (Persistent.OrdSet a)))
          (defn empty [] (Persistent.OrdSet.init (Persistent.OrdMap.empty)))

          (doc singleton "Create a singleton ordered set.")
          (sig singleton (Fn [a] (Persistent.OrdSet a)))
          (defn singleton [value] (Persistent.OrdSet.init (Persistent.OrdMap.singleton value true)))

          (doc length "Return number of stored set entries.")
          (sig length (Fn [(Ref (Persistent.OrdSet a) q)] Long))
          (defn length [set-ref] (Persistent.OrdMap.length (Persistent.OrdSet.impl set-ref)))

          (doc empty? "Returns `true` when set contains no entries.")
          (sig empty? (Fn [(Ref (Persistent.OrdSet a) q)] Bool))
          (defn empty? [set-ref] (Persistent.OrdMap.empty? (Persistent.OrdSet.impl set-ref)))

          (doc height
            "Return the height of the underlying AVL tree (0 for empty).")
          (sig height (Fn [(Ref (Persistent.OrdSet a) q)] Int))
          (defn height [set-ref] (Persistent.OrdMap.height (Persistent.OrdSet.impl set-ref)))

          (doc insert "Insert value, returning a new set.")
          (sig insert (Fn [a (Ref (Persistent.OrdSet a) q)] (Persistent.OrdSet a)))
          (defn insert [value set-ref]
            (Persistent.OrdSet.init (Persistent.OrdMap.insert value true (Persistent.OrdSet.impl set-ref))))

          (doc remove "Remove value (if present), returning a new set.")
          (sig remove (Fn [a (Ref (Persistent.OrdSet a) q)] (Persistent.OrdSet a)))
          (defn remove [value set-ref]
            (Persistent.OrdSet.init (Persistent.OrdMap.remove value (Persistent.OrdSet.impl set-ref))))

          (doc contains? "Returns `true` when value exists in set.")
          (sig contains? (Fn [a (Ref (Persistent.OrdSet a) q)] Bool))
          (defn contains? [value set-ref]
            (Persistent.OrdMap.contains? value (Persistent.OrdSet.impl set-ref)))

          (doc ptr-eq "Pointer identity check for underlying map.")
          (sig ptr-eq (Fn [(Ref (Persistent.OrdSet a) q) (Ref (Persistent.OrdSet a) r)] Bool))
          (defn ptr-eq [a-ref b-ref]
            (Persistent.OrdMap.ptr-eq (Persistent.OrdSet.impl a-ref) (Persistent.OrdSet.impl b-ref)))

          (doc reduce "Reduce in ascending order with accumulator.")
          (sig reduce (Fn [(Ref (Fn [b a] b) q) b (Ref (Persistent.OrdSet a) r)] b))
          (defn reduce [f init set-ref]
            (Persistent.OrdMap.reduce &(fn [acc p] (~f acc @(Pair.a &p)))
                         init
                         (Persistent.OrdSet.impl set-ref)))

          (doc each
            "Invoke a side-effecting function on each element in ascending order.")
          (sig each (Fn [(Ref (Fn [a] ()) q) (Ref (Persistent.OrdSet a) r)] ()))
          (defn each [f set-ref]
            (Persistent.OrdMap.each &(fn [p] (~f @(Pair.a &p))) (Persistent.OrdSet.impl set-ref)))

          (doc to-array "Copy all values into an `Array` in ascending order.")
          (sig to-array (Fn [(Ref (Persistent.OrdSet a) q)] (Array a)))
          (defn to-array [set-ref]
            (reduce &(fn [acc x] (Array.push-back acc x)) [] set-ref))

          (doc from-array "Build an ordered set from an `Array` of values.")
          (sig from-array (Fn [(Ref (Array a) q)] (Persistent.OrdSet a)))
          (defn from-array [arr-ref]
            (Array.reduce &(fn [acc x] (insert @x &acc)) (empty) arr-ref))

          (doc union
            "Return the union of two sets (all elements from either set).")
          (sig union (Fn [(Ref (Persistent.OrdSet a) q) (Ref (Persistent.OrdSet a) r)] (Persistent.OrdSet a)))
          (defn union [a-ref b-ref]
            (reduce &(fn [acc x] (insert x &acc)) @a-ref b-ref))

          (doc intersection
            "Return the intersection of two sets (elements present in both).")
          (sig intersection (Fn [(Ref (Persistent.OrdSet a) q) (Ref (Persistent.OrdSet a) r)] (Persistent.OrdSet a)))
          (defn intersection [a-ref b-ref]
            (reduce
              &(fn [acc x] (if (contains? @&x b-ref) (insert x &acc) acc))
              (empty)
              a-ref))

          (doc difference
            "Return the difference of two sets (elements in the first but not the second).")
          (sig difference (Fn [(Ref (Persistent.OrdSet a) q) (Ref (Persistent.OrdSet a) r)] (Persistent.OrdSet a)))
          (defn difference [a-ref b-ref]
            (reduce
              &(fn [acc x] (if (contains? @&x b-ref) acc (insert x &acc)))
              (empty)
              a-ref))

          (doc =
            "Structural equality: same size and equal members in ascending order.")
          (sig = (Fn [(Ref (Persistent.OrdSet a) q) (Ref (Persistent.OrdSet a) q)] Bool))
          (defn = [a-ref b-ref]
            (if (/= (length a-ref) (length b-ref))
              false
              (let [aa (to-array a-ref)
                    ab (to-array b-ref)] (= &aa &ab))))
          (implements = Persistent.OrdSet.=)

          (doc any? "Return true if any element satisfies the predicate.")
          (sig any?
               (Fn [(Ref (Fn [(Ref a q)] Bool) r) (Ref (Persistent.OrdSet a) s)] Bool))
          (defn any? [pred coll-ref]
            (reduce &(fn [acc x] (or acc (~pred &x))) false coll-ref))

          (doc all? "Return true if all elements satisfy the predicate.")
          (sig all?
               (Fn [(Ref (Fn [(Ref a q)] Bool) r) (Ref (Persistent.OrdSet a) s)] Bool))
          (defn all? [pred coll-ref]
            (reduce &(fn [acc x] (and acc (~pred &x))) true coll-ref))

          (doc str "Diagnostic formatting for an ordered set.")
          (sig str (Fn [(Ref (Persistent.OrdSet a) q)] String))
          (defn str [set-ref]
            (fmt "(PersistentOrdSet size=%ld)" (length set-ref)))

          (sig prn (Fn [(Ref (Persistent.OrdSet a) q)] String))
          (defn prn [set-ref] (str set-ref)))
)

(defmodule Persistent
        (deftype (HeapNode a)
          [value a
           left (Maybe (Rc (Persistent.HeapNode a)))
           right (Maybe (Rc (Persistent.HeapNode a)))])
        (hidden HeapNode)

        (deftype (Heap a) [root (Maybe (Rc (Persistent.HeapNode a)))
                        count Long])

        (defmodule Heap
          (private merge-roots)
          (hidden merge-roots)
          (sig merge-roots
               (Fn
                 [(Ref (Maybe (Rc (Persistent.HeapNode a))) q) (Ref (Maybe (Rc (Persistent.HeapNode a))) r)]
                 (Maybe (Rc (Persistent.HeapNode a)))))
          (defn merge-roots [a-ref b-ref]
            (let-do [a @a-ref
                     b @b-ref
                     path (the
                       (Array (Pair a (Maybe (Rc (Persistent.HeapNode a)))))
                       [])
                     result (the (Maybe (Rc (Persistent.HeapNode a))) (Maybe.Nothing))
                     keep-going true]
              (while-do keep-going
                (match-ref &a
                  (Maybe.Nothing) (do (set! result @&b) (set! keep-going false))
                  (Maybe.Just a-rc)
                    (match-ref &b
                      (Maybe.Nothing)
                        (do (set! result @&a) (set! keep-going false))
                      (Maybe.Just b-rc)
                        (let [a-node (Rc.get a-rc)
                              b-node (Rc.get b-rc)]
                          (if (< @(Persistent.HeapNode.value &b-node) @(Persistent.HeapNode.value &a-node))
                            (let [tmp @&a] (do (set! a @&b) (set! b tmp)))
                            (do
                              (set! path
                                    (Array.push-back path
                                                     (Pair.init @(Persistent.HeapNode.value &a-node)
                                                                @(Persistent.HeapNode.left &a-node))))
                              (set! a @(Persistent.HeapNode.right &a-node))))))))
              (let-do [j (Int.dec (Array.length &path))]
                (while-do (>= j 0)
                  (let [frame (Array.unsafe-nth &path j)
                        v (Pair.a frame)
                        saved-left (Pair.b frame)
                        new-node (Persistent.HeapNode.init @v @&result @saved-left)]
                    (do
                      (set! result (Maybe.Just (Rc.new new-node)))
                      (set! j (Int.dec j))))))
              result))

          (doc empty "Create an empty persistent heap.")
          (sig empty (Fn [] (Persistent.Heap a)))
          (defn empty [] (Persistent.Heap.init (Maybe.Nothing) 0l))

          (doc singleton "Create a singleton heap.")
          (sig singleton (Fn [a] (Persistent.Heap a)))
          (defn singleton [value]
            (let [node (Persistent.HeapNode.init value (Maybe.Nothing) (Maybe.Nothing))]
              (Persistent.Heap.init (Maybe.Just (Rc.new node)) 1l)))

          (doc length "Return number of stored heap entries.")
          (sig length (Fn [(Ref (Persistent.Heap a) q)] Long))
          (defn length [heap-ref] @(Persistent.Heap.count heap-ref))

          (doc empty? "Returns `true` when heap contains no entries.")
          (sig empty? (Fn [(Ref (Persistent.Heap a) q)] Bool))
          (defn empty? [heap-ref] (= (length heap-ref) 0l))

          (doc merge "Merge two heaps, returning a new heap.")
          (sig merge (Fn [(Ref (Persistent.Heap a) q) (Ref (Persistent.Heap a) r)] (Persistent.Heap a)))
          (defn merge [a-ref b-ref]
            (let [root2 (merge-roots (Persistent.Heap.root a-ref) (Persistent.Heap.root b-ref))
                  count2 (+ @(Persistent.Heap.count a-ref) @(Persistent.Heap.count b-ref))]
              (Persistent.Heap.init root2 count2)))

          (doc insert "Insert value into heap, returning a new heap.")
          (sig insert (Fn [a (Ref (Persistent.Heap a) q)] (Persistent.Heap a)))
          (defn insert [value heap-ref]
            (let [node (Persistent.HeapNode.init value (Maybe.Nothing) (Maybe.Nothing))
                  singleton-root (Maybe.Just (Rc.new node))
                  root2 (merge-roots (Persistent.Heap.root heap-ref) &singleton-root)]
              (Persistent.Heap.init root2 (Long.inc @(Persistent.Heap.count heap-ref)))))

          (doc peek "Read minimum value, if any.")
          (sig peek (Fn [(Ref (Persistent.Heap a) q)] (Maybe a)))
          (defn peek [heap-ref]
            (match @(Persistent.Heap.root heap-ref)
              (Maybe.Nothing) (Maybe.Nothing)
              (Maybe.Just root-rc)
                (let [node (Rc.get &root-rc)]
                  (Maybe.Just @(Persistent.HeapNode.value &node)))))

          (doc pop
            "Pop minimum value, returning `(Maybe (Pair value next-heap))`.")
          (sig pop (Fn [(Ref (Persistent.Heap a) q)] (Maybe (Pair a (Persistent.Heap a)))))
          (defn pop [heap-ref]
            (match @(Persistent.Heap.root heap-ref)
              (Maybe.Nothing) (Maybe.Nothing)
              (Maybe.Just root-rc)
                (let [node (Rc.get &root-rc)
                      root2 (merge-roots (Persistent.HeapNode.left &node) (Persistent.HeapNode.right &node))
                      heap2 (Persistent.Heap.init root2 (Long.dec @(Persistent.Heap.count heap-ref)))]
                  (Maybe.Just (Pair.init @(Persistent.HeapNode.value &node) heap2)))))

          (doc ptr-eq
            "Pointer identity check for heap root plus count equality.")
          (sig ptr-eq (Fn [(Ref (Persistent.Heap a) q) (Ref (Persistent.Heap a) r)] Bool))
          (defn ptr-eq [a-ref b-ref]
            (and
              (= @(Persistent.Heap.count a-ref) @(Persistent.Heap.count b-ref))
              (match @(Persistent.Heap.root a-ref)
                (Maybe.Nothing)
                  (match @(Persistent.Heap.root b-ref)
                    (Maybe.Nothing) true
                    (Maybe.Just _) false)
                (Maybe.Just a-root)
                  (match @(Persistent.Heap.root b-ref)
                    (Maybe.Just b-root) (Rc.ptr-eq &a-root &b-root)
                    (Maybe.Nothing) false))))

          (doc reduce
            "Reduce all heap values in structural (unordered) DFS with accumulator.")
          (sig reduce (Fn [(Ref (Fn [b a] b) q) b (Ref (Persistent.Heap a) r)] b))
          (defn reduce [f init heap-ref]
            (let-do [stack (the (Array (Rc (Persistent.HeapNode a))) [])
                     acc init]
              (match-ref (Persistent.Heap.root heap-ref)
                (Maybe.Nothing) ()
                (Maybe.Just root-rc)
                  (set! stack (Array.push-back stack @root-rc)))
              (while-do (> (Array.length &stack) 0)
                (let [top-rc (Array.pop-back! &stack)
                      node (Rc.get &top-rc)]
                  (do
                    (set! acc (~f acc @(Persistent.HeapNode.value &node)))
                    (match-ref (Persistent.HeapNode.left &node)
                      (Maybe.Nothing) ()
                      (Maybe.Just l) (set! stack (Array.push-back stack @l)))
                    (match-ref (Persistent.HeapNode.right &node)
                      (Maybe.Nothing) ()
                      (Maybe.Just r) (set! stack (Array.push-back stack @r))))))
              acc))

          (doc each
            "Invoke a side-effecting function on every heap value (unordered).")
          (sig each (Fn [(Ref (Fn [a] ()) q) (Ref (Persistent.Heap a) r)] ()))
          (defn each [f heap-ref]
            (let-do [stack (the (Array (Rc (Persistent.HeapNode a))) [])]
              (match-ref (Persistent.Heap.root heap-ref)
                (Maybe.Nothing) ()
                (Maybe.Just root-rc)
                  (set! stack (Array.push-back stack @root-rc)))
              (while-do (> (Array.length &stack) 0)
                (let [top-rc (Array.pop-back! &stack)
                      node (Rc.get &top-rc)]
                  (do
                    (~f @(Persistent.HeapNode.value &node))
                    (match-ref (Persistent.HeapNode.left &node)
                      (Maybe.Nothing) ()
                      (Maybe.Just l) (set! stack (Array.push-back stack @l)))
                    (match-ref (Persistent.HeapNode.right &node)
                      (Maybe.Nothing) ()
                      (Maybe.Just r) (set! stack (Array.push-back stack @r))))))))

          (doc to-array
            "Copy all heap values into an `Array` in structural (unordered) order.")
          (sig to-array (Fn [(Ref (Persistent.Heap a) q)] (Array a)))
          (defn to-array [heap-ref]
            (reduce &(fn [acc x] (Array.push-back acc x)) [] heap-ref))

          (doc from-array "Build a heap from an `Array` of values.")
          (sig from-array (Fn [(Ref (Array a) q)] (Persistent.Heap a)))
          (defn from-array [arr-ref]
            (Array.reduce &(fn [acc x] (insert @x &acc)) (empty) arr-ref))

          (doc any? "Return true if any element satisfies the predicate.")
          (sig any?
               (Fn [(Ref (Fn [(Ref a q)] Bool) r) (Ref (Persistent.Heap a) s)] Bool))
          (defn any? [pred coll-ref]
            (reduce &(fn [acc x] (or acc (~pred &x))) false coll-ref))

          (doc all? "Return true if all elements satisfy the predicate.")
          (sig all?
               (Fn [(Ref (Fn [(Ref a q)] Bool) r) (Ref (Persistent.Heap a) s)] Bool))
          (defn all? [pred coll-ref]
            (reduce &(fn [acc x] (and acc (~pred &x))) true coll-ref))

          (doc str "Diagnostic formatting for a heap.")
          (sig str (Fn [(Ref (Persistent.Heap a) q)] String))
          (defn str [heap-ref]
            (fmt "(PersistentHeap size=%ld)" (length heap-ref)))

          (sig prn (Fn [(Ref (Persistent.Heap a) q)] String))
          (defn prn [heap-ref] (str heap-ref)))
)

(defmodule Persistent
        (deftype (HashMapSlot k v)
          (Entry [k v])
          (Sub   [(Rc (Persistent.HashMapNode k v))]))
        (hidden HashMapSlot)
        (deftype (HashMapNode k v)
          (Collision [Int (Array (Pair k v))])
          (Bitmap    [Int (Array (Persistent.HashMapSlot k v))]))
        (hidden HashMapNode)

        (deftype (HashMap k v) [root (Maybe (Rc (Persistent.HashMapNode k v))) count Long])

        (defmodule HashMap
          (private bucket-find)
          (hidden bucket-find)
          (sig bucket-find
               (Fn [(Ref (Array (Pair k v)) q) (Ref k r)] Int))
          (defn bucket-find [bucket-ref key-ref]
            (let-do [idx -1]
              (for [i 0 (Array.length bucket-ref)]
                (when (= (Pair.a (Array.unsafe-nth bucket-ref i)) key-ref)
                  (do (set! idx i) (break))))
              idx))

          (private bucket-get)
          (hidden bucket-get)
          (sig bucket-get
               (Fn [(Ref (Array (Pair k v)) q) (Ref k r)]
                   (Maybe v)))
          (defn bucket-get [bucket-ref key-ref]
            (let [idx (bucket-find bucket-ref key-ref)]
              (if (<= 0 idx)
                (Maybe.Just @(Pair.b (Array.unsafe-nth bucket-ref idx)))
                (Maybe.Nothing))))

          (private bucket-upsert)
          (hidden bucket-upsert)
          (sig bucket-upsert
               (Fn [(Ref (Array (Pair k v)) q) (Ref k r) v]
                   (Pair (Array (Pair k v)) Bool)))
          (defn bucket-upsert [bucket-ref key-ref value]
            (let-do [out (the (Array (Pair k v)) [])
                     found false]
              (for [i 0 (Array.length bucket-ref)]
                (let [entry (Array.unsafe-nth bucket-ref i)]
                  (if (= (Pair.a entry) key-ref)
                    (do
                      (set! out (Array.push-back out (Pair.init-from-refs key-ref &value)))
                      (set! found true))
                    (set! out (Array.push-back out @entry)))))
              (if found
                (Pair.init out false)
                (Pair.init (Array.push-back out (Pair.init-from-refs key-ref &value)) true))))

          (private bucket-remove)
          (hidden bucket-remove)
          (sig bucket-remove
               (Fn [(Ref (Array (Pair k v)) q) (Ref k r)]
                   (Pair (Array (Pair k v)) Bool)))
          (defn bucket-remove [bucket-ref key-ref]
            (let-do [out (the (Array (Pair k v)) [])
                     removed false]
              (for [i 0 (Array.length bucket-ref)]
                (let [entry (Array.unsafe-nth bucket-ref i)]
                  (if (= (Pair.a entry) key-ref)
                    (set! removed true)
                    (set! out (Array.push-back out @entry)))))
              (Pair.init out removed)))

          (private khash)
          (hidden khash)
          (sig khash (Fn [(Ref k q)] Int))
          (defn khash [key-ref] (Int.bit-and (hash key-ref) 2147483647))

          (private frag)
          (hidden frag)
          (sig frag (Fn [Int Int] Int))
          (defn frag [hash shift] (Int.bit-and (Int.bit-shift-right hash shift) 31))

          (private bitpos)
          (hidden bitpos)
          (sig bitpos (Fn [Int] Int))
          (defn bitpos [f] (Int.bit-shift-left 1 f))

          (private bindex)
          (hidden bindex)
          (sig bindex (Fn [Int Int] Int))
          (defn bindex [bm bit] (Persistent.popcount (Int.bit-and bm (Int.dec bit))))

          (private array-insert-at)
          (hidden array-insert-at)
          (sig array-insert-at
               (Fn [(Ref (Array (Persistent.HashMapSlot k v)) q) Int (Persistent.HashMapSlot k v)] (Array (Persistent.HashMapSlot k v))))
          (defn array-insert-at [arr idx x]
            (let-do [out (the (Array (Persistent.HashMapSlot k v)) [])]
              (for [i 0 idx] (set! out (Array.push-back out @(Array.unsafe-nth arr i))))
              (set! out (Array.push-back out x))
              (for [i idx (Array.length arr)]
                (set! out (Array.push-back out @(Array.unsafe-nth arr i))))
              out))

          (private array-set-at)
          (hidden array-set-at)
          (sig array-set-at
               (Fn [(Ref (Array (Persistent.HashMapSlot k v)) q) Int (Persistent.HashMapSlot k v)] (Array (Persistent.HashMapSlot k v))))
          (defn array-set-at [arr idx x]
            (let-do [out @arr] (Array.aset! &out idx x) out))

          (private array-remove-at)
          (hidden array-remove-at)
          (sig array-remove-at
               (Fn [(Ref (Array (Persistent.HashMapSlot k v)) q) Int] (Array (Persistent.HashMapSlot k v))))
          (defn array-remove-at [arr idx]
            (let-do [out (the (Array (Persistent.HashMapSlot k v)) [])]
              (for [i 0 (Array.length arr)]
                (when (/= i idx) (set! out (Array.push-back out @(Array.unsafe-nth arr i)))))
              out))

          (private merge-entries)
          (hidden merge-entries)
          (sig merge-entries
               (Fn [k v Int k v Int Int] (Rc (Persistent.HashMapNode k v))))
          (defn merge-entries [k1 v1 h1 k2 v2 h2 shift]
            (if (= h1 h2)
              (Rc.new (Persistent.HashMapNode.Collision h1 [(Pair.init k1 v1) (Pair.init k2 v2)]))
              (let [f1 (frag h1 shift) f2 (frag h2 shift)]
                (if (= f1 f2)
                  (Rc.new (Persistent.HashMapNode.Bitmap (bitpos f1)
                    [(Persistent.HashMapSlot.Sub (merge-entries k1 v1 h1 k2 v2 h2 (+ shift 5)))]))
                  (Rc.new (Persistent.HashMapNode.Bitmap (Int.bit-or (bitpos f1) (bitpos f2))
                    (if (< f1 f2)
                      [(Persistent.HashMapSlot.Entry k1 v1) (Persistent.HashMapSlot.Entry k2 v2)]
                      [(Persistent.HashMapSlot.Entry k2 v2) (Persistent.HashMapSlot.Entry k1 v1)])))))))

          (private merge-collision-entry)
          (hidden merge-collision-entry)
          (sig merge-collision-entry
               (Fn [(Rc (Persistent.HashMapNode k v)) Int k v Int Int] (Rc (Persistent.HashMapNode k v))))
          (defn merge-collision-entry [coll-rc chash key value hash shift]
            (let [f1 (frag chash shift) f2 (frag hash shift)]
              (if (= f1 f2)
                (Rc.new (Persistent.HashMapNode.Bitmap (bitpos f1)
                  [(Persistent.HashMapSlot.Sub (merge-collision-entry coll-rc chash key value hash (+ shift 5)))]))
                (Rc.new (Persistent.HashMapNode.Bitmap (Int.bit-or (bitpos f1) (bitpos f2))
                  (if (< f1 f2)
                    [(Persistent.HashMapSlot.Sub coll-rc) (Persistent.HashMapSlot.Entry key value)]
                    [(Persistent.HashMapSlot.Entry key value) (Persistent.HashMapSlot.Sub coll-rc)]))))))

          (private node-get)
          (hidden node-get)
          (sig node-get (Fn [(Ref (Rc (Persistent.HashMapNode k v)) q) Int (Ref k r) Int] (Maybe v)))
          (defn node-get [node-rc-ref hash key-ref shift]
            (let [node (Rc.value-ref node-rc-ref)]
              (match-ref node
                (Persistent.HashMapNode.Collision h entries)
                  (if (/= @h hash) (Maybe.Nothing) (bucket-get entries key-ref))
                (Persistent.HashMapNode.Bitmap bm slots)
                  (let [bit (bitpos (frag hash shift))]
                    (if (= 0 (Int.bit-and @bm bit))
                      (Maybe.Nothing)
                      (match-ref (Array.unsafe-nth slots (bindex @bm bit))
                        (Persistent.HashMapSlot.Entry ek ev) (if (= ek key-ref) (Maybe.Just @ev) (Maybe.Nothing))
                        (Persistent.HashMapSlot.Sub rc) (node-get rc hash key-ref (+ shift 5))))))))

          (private node-insert)
          (hidden node-insert)
          (sig node-insert
               (Fn [(Ref (Rc (Persistent.HashMapNode k v)) q) Int (Ref k r) v Int]
                   (Pair (Rc (Persistent.HashMapNode k v)) Bool)))
          (defn node-insert [node-rc-ref hash key-ref value shift]
            (let [node (Rc.value-ref node-rc-ref)]
              (match-ref node
                (Persistent.HashMapNode.Collision h entries)
                  (if (= @h hash)
                    (let [rec (bucket-upsert entries key-ref value)]
                      (Pair.init (Rc.new (Persistent.HashMapNode.Collision hash @(Pair.a &rec)))
                                 @(Pair.b &rec)))
                    (Pair.init (merge-collision-entry @node-rc-ref @h @key-ref value hash shift) true))
                (Persistent.HashMapNode.Bitmap bm slots)
                  (let [bit (bitpos (frag hash shift))
                        idx (bindex @bm bit)]
                    (if (= 0 (Int.bit-and @bm bit))
                      (Pair.init (Rc.new (Persistent.HashMapNode.Bitmap (Int.bit-or @bm bit)
                                   (array-insert-at slots idx (Persistent.HashMapSlot.Entry @key-ref value)))) true)
                      (match-ref (Array.unsafe-nth slots idx)
                        (Persistent.HashMapSlot.Entry ek ev)
                          (if (= ek key-ref)
                            (Pair.init (Rc.new (Persistent.HashMapNode.Bitmap @bm
                                         (array-set-at slots idx (Persistent.HashMapSlot.Entry @key-ref value)))) false)
                            (let [sub (merge-entries @ek @ev (khash ek) @key-ref value hash (+ shift 5))]
                              (Pair.init (Rc.new (Persistent.HashMapNode.Bitmap @bm
                                           (array-set-at slots idx (Persistent.HashMapSlot.Sub sub)))) true)))
                        (Persistent.HashMapSlot.Sub rc)
                          (let [rec (node-insert rc hash key-ref value (+ shift 5))]
                            (Pair.init (Rc.new (Persistent.HashMapNode.Bitmap @bm
                                         (array-set-at slots idx (Persistent.HashMapSlot.Sub @(Pair.a &rec))))) @(Pair.b &rec)))))))))

          (private node-remove)
          (hidden node-remove)
          (sig node-remove
               (Fn [(Ref (Rc (Persistent.HashMapNode k v)) q) Int (Ref k r) Int]
                   (Pair (Maybe (Rc (Persistent.HashMapNode k v))) Bool)))
          (defn node-remove [node-rc-ref hash key-ref shift]
            (let [node (Rc.value-ref node-rc-ref)]
              (match-ref node
                (Persistent.HashMapNode.Collision h entries)
                  (if (/= @h hash) (Pair.init (Maybe.Just @node-rc-ref) false)
                    (let [rec (bucket-remove entries key-ref)]
                      (if (not @(Pair.b &rec)) (Pair.init (Maybe.Just @node-rc-ref) false)
                        (Pair.init (Maybe.Just (Rc.new (Persistent.HashMapNode.Collision hash @(Pair.a &rec)))) true))))
                (Persistent.HashMapNode.Bitmap bm slots)
                  (let [bit (bitpos (frag hash shift))]
                    (if (= 0 (Int.bit-and @bm bit)) (Pair.init (Maybe.Just @node-rc-ref) false)
                      (let [idx (bindex @bm bit)]
                        (match-ref (Array.unsafe-nth slots idx)
                          (Persistent.HashMapSlot.Entry ek ev)
                            (if (= ek key-ref)
                              (let [nbm (Int.bit-and @bm (- -1 bit))]
                                (if (= 0 nbm) (Pair.init (Maybe.Nothing) true)
                                  (Pair.init (Maybe.Just (Rc.new (Persistent.HashMapNode.Bitmap nbm (array-remove-at slots idx)))) true)))
                              (Pair.init (Maybe.Just @node-rc-ref) false))
                          (Persistent.HashMapSlot.Sub rc)
                            (let [rec (node-remove rc hash key-ref (+ shift 5))]
                              (if (not @(Pair.b &rec)) (Pair.init (Maybe.Just @node-rc-ref) false)
                                (match-ref (Pair.a &rec)
                                  (Maybe.Nothing)
                                    (let [nbm (Int.bit-and @bm (- -1 bit))]
                                      (if (= 0 nbm) (Pair.init (Maybe.Nothing) true)
                                        (Pair.init (Maybe.Just (Rc.new (Persistent.HashMapNode.Bitmap nbm (array-remove-at slots idx)))) true)))
                                  (Maybe.Just sub2)
                                    (Pair.init (Maybe.Just (Rc.new (Persistent.HashMapNode.Bitmap @bm (array-set-at slots idx (Persistent.HashMapSlot.Sub @sub2))))) true)))))))))))

          (doc empty "Create an empty hash map.")
          (sig empty (Fn [] (Persistent.HashMap k v)))
          (defn empty [] (Persistent.HashMap.init (Maybe.Nothing) 0l))

          (doc length "Return number of stored key/value pairs.")
          (sig length (Fn [(Ref (Persistent.HashMap k v) q)] Long))
          (defn length [map-ref] @(Persistent.HashMap.count map-ref))

          (doc empty? "Returns `true` when hash map contains no entries.")
          (sig empty? (Fn [(Ref (Persistent.HashMap k v) q)] Bool))
          (defn empty? [map-ref] (= (length map-ref) 0l))

          (doc get "Lookup key, returning `Maybe` value.")
          (sig get (Fn [(Ref k q) (Ref (Persistent.HashMap k v) r)] (Maybe v)))
          (defn get [key-ref map-ref]
            (match-ref (Persistent.HashMap.root map-ref)
              (Maybe.Nothing) (Maybe.Nothing)
              (Maybe.Just root-rc) (node-get root-rc (khash key-ref) key-ref 0)))

          (doc contains? "Returns `true` when key exists in hash map.")
          (sig contains? (Fn [(Ref k q) (Ref (Persistent.HashMap k v) r)] Bool))
          (defn contains? [key-ref map-ref]
            (match (get key-ref map-ref) (Maybe.Nothing) false (Maybe.Just _) true))

          (doc insert "Insert or replace value for key, returning a new map.")
          (sig insert (Fn [k v (Ref (Persistent.HashMap k v) q)] (Persistent.HashMap k v)))
          (defn insert [key value map-ref]
            (let [h (khash &key)]
              (match-ref (Persistent.HashMap.root map-ref)
                (Maybe.Nothing)
                  (Persistent.HashMap.init (Maybe.Just (Rc.new (Persistent.HashMapNode.Bitmap (bitpos (frag h 0))
                               [(Persistent.HashMapSlot.Entry key value)]))) 1l)
                (Maybe.Just root-rc)
                  (let [rec (node-insert root-rc h &key value 0)]
                    (Persistent.HashMap.init (Maybe.Just @(Pair.a &rec))
                               (if @(Pair.b &rec)
                                 (Long.inc @(Persistent.HashMap.count map-ref))
                                 @(Persistent.HashMap.count map-ref)))))))

          (doc singleton "Create a hash map with one key/value pair.")
          (sig singleton (Fn [k v] (Persistent.HashMap k v)))
          (defn singleton [key value] (insert key value &(empty)))

          (doc remove "Remove key (if present), returning a new map.")
          (sig remove (Fn [(Ref k q) (Ref (Persistent.HashMap k v) r)] (Persistent.HashMap k v)))
          (defn remove [key-ref map-ref]
            (match-ref (Persistent.HashMap.root map-ref)
              (Maybe.Nothing) @map-ref
              (Maybe.Just root-rc)
                (let [rec (node-remove root-rc (khash key-ref) key-ref 0)]
                  (if (not @(Pair.b &rec))
                    @map-ref
                    (Persistent.HashMap.init @(Pair.a &rec) (Long.dec @(Persistent.HashMap.count map-ref)))))))

          (doc ptr-eq "Pointer identity check for backing root plus count equality.")
          (sig ptr-eq (Fn [(Ref (Persistent.HashMap k v) q) (Ref (Persistent.HashMap k v) r)] Bool))
          (defn ptr-eq [a-ref b-ref]
            (and (= @(Persistent.HashMap.count a-ref) @(Persistent.HashMap.count b-ref))
              (match-ref (Persistent.HashMap.root a-ref)
                (Maybe.Nothing) (match-ref (Persistent.HashMap.root b-ref) (Maybe.Nothing) true (Maybe.Just _) false)
                (Maybe.Just ra)
                  (match-ref (Persistent.HashMap.root b-ref)
                    (Maybe.Nothing) false
                    (Maybe.Just rb) (Rc.ptr-eq ra rb)))))

          (doc reduce "Reduce over `(Pair key value)` entries in unspecified order.")
          (sig reduce
               (Fn [(Ref (Fn [a (Pair k v)] a) q) a (Ref (Persistent.HashMap k v) r)] a))
          ; iterative (explicit node stack): recursing while passing the
          ; ref-to-fn `f` builds an infinite function type in inference.
          (defn reduce [f init map-ref]
            (match-ref (Persistent.HashMap.root map-ref)
              (Maybe.Nothing) init
              (Maybe.Just root-rc)
                (let-do [stack (the (Array (Rc (Persistent.HashMapNode k v))) [@root-rc])
                         acc init]
                  (while-do (> (Array.length &stack) 0)
                    (let [rc (Array.pop-back! &stack)
                          node (Rc.value-ref &rc)]
                      (match-ref node
                        (Persistent.HashMapNode.Collision h entries)
                          (for [i 0 (Array.length entries)]
                            (set! acc (~f acc @(Array.unsafe-nth entries i))))
                        (Persistent.HashMapNode.Bitmap bm slots)
                          (for [i 0 (Array.length slots)]
                            (match-ref (Array.unsafe-nth slots i)
                              (Persistent.HashMapSlot.Entry k v) (set! acc (~f acc (Pair.init @k @v)))
                              (Persistent.HashMapSlot.Sub crc) (set! stack (Array.push-back stack @crc)))))))
                  acc)))

          (doc each "Invoke a side-effecting function on each `(Pair key value)` entry.")
          (sig each
               (Fn [(Ref (Fn [(Pair k v)] ()) q) (Ref (Persistent.HashMap k v) r)] ()))
          (defn each [f map-ref]
            (ignore (reduce &(fn [acc p] (do (~f p) acc)) 0l map-ref)))

          (doc to-array "Copy all `(Pair key value)` entries into an `Array`.")
          (sig to-array (Fn [(Ref (Persistent.HashMap k v) q)] (Array (Pair k v))))
          (defn to-array [map-ref]
            (reduce &(fn [acc p] (Array.push-back acc p)) [] map-ref))

          (doc from-array "Build a hash map from an `Array` of `(Pair key value)` entries.")
          (sig from-array (Fn [(Ref (Array (Pair k v)) q)] (Persistent.HashMap k v)))
          (defn from-array [arr-ref]
            (Array.reduce &(fn [acc p] (insert @(Pair.a p) @(Pair.b p) &acc)) (empty) arr-ref))

          (doc keys "Collect all keys into an `Array`.")
          (sig keys (Fn [(Ref (Persistent.HashMap k v) q)] (Array k)))
          (defn keys [map-ref]
            (reduce &(fn [acc p] (Array.push-back acc @(Pair.a &p))) [] map-ref))

          (doc values "Collect all values into an `Array`.")
          (sig values (Fn [(Ref (Persistent.HashMap k v) q)] (Array v)))
          (defn values [map-ref]
            (reduce &(fn [acc p] (Array.push-back acc @(Pair.b &p))) [] map-ref))

          (doc merge "Merge two maps. On key collision the second (right) map wins.")
          (sig merge (Fn [(Ref (Persistent.HashMap k v) a) (Ref (Persistent.HashMap k v) b)] (Persistent.HashMap k v)))
          (defn merge [a-ref b-ref]
            (reduce &(fn [acc p] (insert @(Pair.a &p) @(Pair.b &p) &acc)) @a-ref b-ref))

          (doc merge-with
            "Merge two maps with a conflict resolver. For keys in both maps, call the resolver with both values.")
          (sig merge-with
               (Fn [(Ref (Fn [v v] v) q) (Ref (Persistent.HashMap k v) a) (Ref (Persistent.HashMap k v) b)] (Persistent.HashMap k v)))
          (defn merge-with [f a-ref b-ref]
            (reduce
              &(fn [acc p]
                (let [k @(Pair.a &p) bv @(Pair.b &p)]
                  (match (get &k &acc)
                    (Maybe.Nothing) (insert k bv &acc)
                    (Maybe.Just av) (insert k (~f av bv) &acc))))
              @a-ref b-ref))

          (doc = "Structural equality: same size and same set of `(key, value)` entries.")
          (sig = (Fn [(Ref (Persistent.HashMap k v) q) (Ref (Persistent.HashMap k v) q)] Bool))
          (defn = [a-ref b-ref]
            (if (/= @(Persistent.HashMap.count a-ref) @(Persistent.HashMap.count b-ref))
              false
              (reduce
                &(fn [acc p]
                  (and acc
                       (match (get (Pair.a &p) b-ref)
                         (Maybe.Nothing) false
                         (Maybe.Just bv) (= bv @(Pair.b &p)))))
                true a-ref)))
          (implements = Persistent.HashMap.=)

          (doc map-values
            "Apply a function to each value, returning a new map with the same keys.")
          (sig map-values
               (Fn [(Ref (Fn [v] v) q) (Ref (Persistent.HashMap k v) r)] (Persistent.HashMap k v)))
          (defn map-values [f map-ref]
            (reduce &(fn [acc p] (insert @(Pair.a &p) (~f @(Pair.b &p)) &acc)) (empty) map-ref))

          (doc filter "Keep only entries whose `(Pair key value)` satisfies a predicate.")
          (sig filter
               (Fn [(Ref (Fn [(Ref (Pair k v) q)] Bool) r) (Ref (Persistent.HashMap k v) s)] (Persistent.HashMap k v)))
          (defn filter [pred map-ref]
            (reduce
              &(fn [acc p] (if (~pred &p) (insert @(Pair.a &p) @(Pair.b &p) &acc) acc))
              (empty) map-ref))

          (doc any? "Return true if any entry satisfies the predicate.")
          (sig any?
               (Fn [(Ref (Fn [(Ref (Pair k v) q)] Bool) r) (Ref (Persistent.HashMap k v) s)] Bool))
          (defn any? [pred coll-ref]
            (reduce &(fn [acc x] (or acc (~pred &x))) false coll-ref))

          (doc all? "Return true if all entries satisfy the predicate.")
          (sig all?
               (Fn [(Ref (Fn [(Ref (Pair k v) q)] Bool) r) (Ref (Persistent.HashMap k v) s)] Bool))
          (defn all? [pred coll-ref]
            (reduce &(fn [acc x] (and acc (~pred &x))) true coll-ref))

          (doc str "Diagnostic formatting for a hash map.")
          (sig str (Fn [(Ref (Persistent.HashMap k v) q)] String))
          (defn str [map-ref]
            (fmt "(PersistentHashMap size=%ld)" (length map-ref)))

          (sig prn (Fn [(Ref (Persistent.HashMap k v) q)] String))
          (defn prn [map-ref] (str map-ref)))
)

(defmodule Persistent
        (deftype (HashSet a) [impl (Persistent.HashMap a Bool)])

        (defmodule HashSet
          (doc empty "Create an empty hash set.")
          (sig empty (Fn [] (Persistent.HashSet a)))
          (defn empty [] (Persistent.HashSet.init (Persistent.HashMap.empty)))

          (doc singleton "Create a singleton hash set.")
          (sig singleton (Fn [a] (Persistent.HashSet a)))
          (defn singleton [value] (Persistent.HashSet.init (Persistent.HashMap.singleton value true)))

          (doc length "Return number of stored set entries.")
          (sig length (Fn [(Ref (Persistent.HashSet a) q)] Long))
          (defn length [set-ref] (Persistent.HashMap.length (Persistent.HashSet.impl set-ref)))

          (doc empty? "Returns `true` when set contains no entries.")
          (sig empty? (Fn [(Ref (Persistent.HashSet a) q)] Bool))
          (defn empty? [set-ref] (Persistent.HashMap.empty? (Persistent.HashSet.impl set-ref)))

          (doc insert "Insert value, returning a new set.")
          (sig insert (Fn [a (Ref (Persistent.HashSet a) q)] (Persistent.HashSet a)))
          (defn insert [value set-ref]
            (Persistent.HashSet.init (Persistent.HashMap.insert value true (Persistent.HashSet.impl set-ref))))

          (doc remove "Remove value (if present), returning a new set.")
          (sig remove (Fn [(Ref a q) (Ref (Persistent.HashSet a) r)] (Persistent.HashSet a)))
          (defn remove [value-ref set-ref]
            (Persistent.HashSet.init (Persistent.HashMap.remove value-ref (Persistent.HashSet.impl set-ref))))

          (doc contains? "Returns `true` when value exists in set.")
          (sig contains? (Fn [(Ref a q) (Ref (Persistent.HashSet a) r)] Bool))
          (defn contains? [value-ref set-ref]
            (Persistent.HashMap.contains? value-ref (Persistent.HashSet.impl set-ref)))

          (doc ptr-eq "Pointer identity check for underlying map.")
          (sig ptr-eq (Fn [(Ref (Persistent.HashSet a) q) (Ref (Persistent.HashSet a) r)] Bool))
          (defn ptr-eq [a-ref b-ref]
            (Persistent.HashMap.ptr-eq (Persistent.HashSet.impl a-ref) (Persistent.HashSet.impl b-ref)))

          (doc reduce "Reduce over all values with accumulator.")
          (sig reduce (Fn [(Ref (Fn [b a] b) q) b (Ref (Persistent.HashSet a) r)] b))
          (defn reduce [f init set-ref]
            (Persistent.HashMap.reduce &(fn [acc p] (~f acc @(Pair.a &p)))
                         init
                         (Persistent.HashSet.impl set-ref)))

          (doc each "Invoke a side-effecting function on every value.")
          (sig each (Fn [(Ref (Fn [a] ()) q) (Ref (Persistent.HashSet a) r)] ()))
          (defn each [f set-ref]
            (Persistent.HashMap.each &(fn [p] (~f @(Pair.a &p))) (Persistent.HashSet.impl set-ref)))

          (doc to-array "Copy all values into an `Array`.")
          (sig to-array (Fn [(Ref (Persistent.HashSet a) q)] (Array a)))
          (defn to-array [set-ref]
            (reduce &(fn [acc x] (Array.push-back acc x)) [] set-ref))

          (doc from-array "Build a hash set from an `Array` of values.")
          (sig from-array (Fn [(Ref (Array a) q)] (Persistent.HashSet a)))
          (defn from-array [arr-ref]
            (Array.reduce &(fn [acc x] (insert @x &acc)) (empty) arr-ref))

          (doc union
            "Return the union of two sets (all elements from either set).")
          (sig union (Fn [(Ref (Persistent.HashSet a) q) (Ref (Persistent.HashSet a) r)] (Persistent.HashSet a)))
          (defn union [a-ref b-ref]
            (reduce &(fn [acc x] (insert x &acc)) @a-ref b-ref))

          (doc intersection
            "Return the intersection of two sets (elements present in both).")
          (sig intersection (Fn [(Ref (Persistent.HashSet a) q) (Ref (Persistent.HashSet a) r)] (Persistent.HashSet a)))
          (defn intersection [a-ref b-ref]
            (reduce
              &(fn [acc x] (if (contains? &x b-ref) (insert x &acc) acc))
              (empty)
              a-ref))

          (doc difference
            "Return the difference of two sets (elements in the first but not the second).")
          (sig difference (Fn [(Ref (Persistent.HashSet a) q) (Ref (Persistent.HashSet a) r)] (Persistent.HashSet a)))
          (defn difference [a-ref b-ref]
            (reduce
              &(fn [acc x] (if (contains? &x b-ref) acc (insert x &acc)))
              (empty)
              a-ref))

          (doc = "Structural equality: same size and same set of members.")
          (sig = (Fn [(Ref (Persistent.HashSet a) q) (Ref (Persistent.HashSet a) q)] Bool))
          (defn = [a-ref b-ref] (Persistent.HashMap.= (Persistent.HashSet.impl a-ref) (Persistent.HashSet.impl b-ref)))
          (implements = Persistent.HashSet.=)

          (doc any? "Return true if any element satisfies the predicate.")
          (sig any?
               (Fn [(Ref (Fn [(Ref a q)] Bool) r) (Ref (Persistent.HashSet a) s)] Bool))
          (defn any? [pred coll-ref]
            (reduce &(fn [acc x] (or acc (~pred &x))) false coll-ref))

          (doc all? "Return true if all elements satisfy the predicate.")
          (sig all?
               (Fn [(Ref (Fn [(Ref a q)] Bool) r) (Ref (Persistent.HashSet a) s)] Bool))
          (defn all? [pred coll-ref]
            (reduce &(fn [acc x] (and acc (~pred &x))) true coll-ref))

          (doc str "Diagnostic formatting for a hash set.")
          (sig str (Fn [(Ref (Persistent.HashSet a) q)] String))
          (defn str [set-ref]
            (fmt "(PersistentHashSet size=%ld)" (length set-ref)))

          (sig prn (Fn [(Ref (Persistent.HashSet a) q)] String))
          (defn prn [set-ref] (str set-ref)))
)

(defmodule Persistent
        (deftype (VectorNode a)
          (Branch [(Array (Rc (Persistent.VectorNode a)))])
          (Leaf   [(Array a)]))
        (hidden VectorNode)

        (deftype (Vector a) [count Long shift Int root (Rc (Persistent.VectorNode a))
                        tail (Array a)])

        (defmodule Vector
          (private branch-children)
          (hidden branch-children)
          (sig branch-children
               (Fn [(Ref (Persistent.VectorNode a) q)] (Ref (Array (Rc (Persistent.VectorNode a))) q)))
          (defn branch-children [n]
            (match-ref n
              (Persistent.VectorNode.Branch cs) cs
              (Persistent.VectorNode.Leaf _) (unreachable "branch-children on a leaf")))

          (private leaf-values)
          (hidden leaf-values)
          (sig leaf-values (Fn [(Ref (Persistent.VectorNode a) q)] (Ref (Array a) q)))
          (defn leaf-values [n]
            (match-ref n
              (Persistent.VectorNode.Leaf vs) vs
              (Persistent.VectorNode.Branch _) (unreachable "leaf-values on a branch")))

          (private child-ref)
          (hidden child-ref)
          (sig child-ref
               (Fn [(Ref (Array (Rc (Persistent.VectorNode a))) q) Int] (Ref (Rc (Persistent.VectorNode a)) q)))
          (defn child-ref [children i]
            (Array.unsafe-nth children i))

          (private nchildren)
          (hidden nchildren)
          (sig nchildren (Fn [(Ref (Persistent.VectorNode a) q)] Int))
          (defn nchildren [n] (Array.length (branch-children n)))

          (private tailoff)
          (hidden tailoff)
          (sig tailoff (Fn [Long] Int))
          (defn tailoff [cnt]
            (if (< cnt 32l)
              0
              (Int.bit-shift-left
                (Int.bit-shift-right (Long.to-int (Long.dec cnt)) 5) 5)))

          (doc empty "Create an empty vector.")
          (sig empty (Fn [] (Persistent.Vector a)))
          (defn empty [] (Persistent.Vector.init 0l 5 (Rc.new (Persistent.VectorNode.Branch [])) []))

          (doc length "Return number of stored entries.")
          (sig length (Fn [(Ref (Persistent.Vector a) q)] Long))
          (defn length [vec-ref] @(Persistent.Vector.count vec-ref))

          (doc empty? "Returns `true` when vector contains no entries.")
          (sig empty? (Fn [(Ref (Persistent.Vector a) q)] Bool))
          (defn empty? [vec-ref] (= (length vec-ref) 0l))

          (private node-for)
          (hidden node-for)
          ; returns the leaf node's Rc handle (cheap refcount copy); callers
          ; borrow it via value-ref to read a value without copying the leaf.
          (sig node-for (Fn [(Ref (Persistent.Vector a) q) Int] (Rc (Persistent.VectorNode a))))
          (defn node-for [vec-ref index]
            (let-do [node @(Persistent.Vector.root vec-ref)
                     level @(Persistent.Vector.shift vec-ref)]
              (while (> level 0)
                (let [nv (Rc.value-ref &node)
                      child @(child-ref (branch-children nv)
                                        (Int.bit-and
                                          (Int.bit-shift-right index level) 31))]
                  (do (set! node child) (set! level (- level 5)))))
              node))

          ; walk to the leaf for `index` borrowing every node, copy out only the
          ; found value (no Rc handle copies, no allocation)
          (private leaf-get)
          (hidden leaf-get)
          (sig leaf-get (Fn [(Ref (Persistent.VectorNode a) q) Int Int] a))
          (defn leaf-get [root-node index shift]
            (let-do [node root-node
                     level shift]
              (while (> level 0)
                (do
                  (set! node (Rc.value-ref (child-ref (branch-children node)
                                                      (Int.bit-and (Int.bit-shift-right index level) 31))))
                  (set! level (- level 5))))
              @(Array.unsafe-nth (leaf-values node) (Int.bit-and index 31))))

          (doc get "Lookup index, returning `Maybe` value.")
          (sig get (Fn [Int (Ref (Persistent.Vector a) q)] (Maybe a)))
          (defn get [index vec-ref]
            (if (or (< index 0) (>= index (Long.to-int @(Persistent.Vector.count vec-ref))))
              (Maybe.Nothing)
              (if (>= index (tailoff @(Persistent.Vector.count vec-ref)))
                (Maybe.Just @(Array.unsafe-nth (Persistent.Vector.tail vec-ref)
                                               (Int.bit-and index 31)))
                (Maybe.Just (leaf-get (Rc.value-ref (Persistent.Vector.root vec-ref))
                                      index @(Persistent.Vector.shift vec-ref))))))

          (private new-path)
          (hidden new-path)
          (sig new-path (Fn [Int (Rc (Persistent.VectorNode a))] (Rc (Persistent.VectorNode a))))
          (defn new-path [level node]
            (let-do [result node
                     lvl 0]
              (while (< lvl level)
                (do
                  (set! result (Rc.new (Persistent.VectorNode.Branch [result])))
                  (set! lvl (+ lvl 5))))
              result))

          (private push-tail)
          (hidden push-tail)
          (sig push-tail
               (Fn [Int (Ref (Persistent.VectorNode a) q) (Rc (Persistent.VectorNode a)) Long] (Rc (Persistent.VectorNode a))))
          (defn push-tail [level parent tailnode cnt]
            ; iterative descend/rebuild (see do-assoc). Descend recording a
            ; spine of (children-copy, subidx); `tailnode` is consumed once,
            ; after the loop, to keep its linear use valid.
            (let-do [spine-cs (the (Array (Array (Rc (Persistent.VectorNode a)))) [])
                     spine-ix (the (Array Int) [])
                     cur-children @(branch-children parent)
                     lvl level
                     mode 0
                     attach-children (the (Array (Rc (Persistent.VectorNode a))) [])
                     attach-level 0
                     done false]
              (while (not done)
                (let [subidx (Int.bit-and
                               (Int.bit-shift-right (Long.to-int (Long.dec cnt)) lvl)
                               31)]
                  (if (= lvl 5)
                    (do (set! mode 0) (set! attach-children @&cur-children)
                        (set! attach-level lvl) (set! done true))
                    (if (< subidx (Array.length &cur-children))
                      (let-do [child @(child-ref &cur-children subidx)]
                        (set! spine-cs (Array.push-back spine-cs @&cur-children))
                        (set! spine-ix (Array.push-back spine-ix subidx))
                        (set! cur-children @(branch-children (Rc.value-ref &child)))
                        (set! lvl (- lvl 5)))
                      (do (set! mode 1) (set! attach-children @&cur-children)
                          (set! attach-level lvl) (set! done true))))))
              (let-do [built (if (= mode 0)
                               (Rc.new (Persistent.VectorNode.Branch
                                 (Array.push-back attach-children tailnode)))
                               (Rc.new (Persistent.VectorNode.Branch
                                 (Array.push-back attach-children
                                   (new-path (- attach-level 5) tailnode)))))]
                (while (> (Array.length &spine-cs) 0)
                  (let-do [cs (Array.pop-back! &spine-cs)
                           sidx (Array.pop-back! &spine-ix)]
                    (set! built (Rc.new (Persistent.VectorNode.Branch
                                  (do (Array.aset! &cs sidx built) cs))))))
                built)))

          (doc push-back "Append value, returning a new vector.")
          (sig push-back (Fn [a (Ref (Persistent.Vector a) q)] (Persistent.Vector a)))
          (defn push-back [value vec-ref]
            (let [cnt @(Persistent.Vector.count vec-ref)
                  taillen (- (Long.to-int cnt) (tailoff cnt))]
              (if (< taillen 32)
                (Persistent.Vector.init (Long.inc cnt) @(Persistent.Vector.shift vec-ref) @(Persistent.Vector.root vec-ref)
                           (Array.push-back @(Persistent.Vector.tail vec-ref) value))
                (let [tailnode (Rc.new (Persistent.VectorNode.Leaf @(Persistent.Vector.tail vec-ref)))
                      shift @(Persistent.Vector.shift vec-ref)]
                  (if (> (Int.bit-shift-right (Long.to-int cnt) 5)
                         (Int.bit-shift-left 1 shift))
                    (Persistent.Vector.init (Long.inc cnt) (+ shift 5)
                               (Rc.new (Persistent.VectorNode.Branch
                                 [@(Persistent.Vector.root vec-ref)
                                  (new-path shift tailnode)]))
                               [value])
                    (Persistent.Vector.init (Long.inc cnt) shift
                               (push-tail shift (Rc.value-ref (Persistent.Vector.root vec-ref))
                                          tailnode cnt)
                               [value]))))))

          (doc push-back-owned
            "Append, consuming the vector instead of borrowing it.

When the caller hands over ownership (moves the vector in rather than
passing a reference), the common tail-only append mutates the tail in
place — no copy, no allocation — because tails are never shared between
versions. Use this in build/churn loops that discard the previous
version; it is a transient-style fast path with the same result as
`push-back`. The rarer tail-flush case falls back to a copying push.")
          (sig push-back-owned (Fn [a (Persistent.Vector a)] (Persistent.Vector a)))
          (defn push-back-owned [value vec]
            (let-do [v vec
                     cnt @(Persistent.Vector.count &v)]
              (if (< (- (Long.to-int cnt) (tailoff cnt)) 32)
                (do
                  ; pre-size the owned tail to a full 32 slots so the
                  ; in-place append never reallocs (Clojure's transient
                  ; tail trick); the leaf copy on flush trims it back.
                  (Persistent.array-reserve! (Persistent.Vector.tail &v) 32)
                  (Array.push-back! (Persistent.Vector.tail &v) value)
                  (Persistent.Vector.set-count! &v (Long.inc cnt))
                  v)
                (push-back value &v))))

          (private do-assoc)
          (hidden do-assoc)
          (sig do-assoc (Fn [Int (Ref (Persistent.VectorNode a) q) Int a] (Rc (Persistent.VectorNode a))))
          (defn do-assoc [level node index value]
            (if (= level 0)
              (let-do [vs @(leaf-values node)]
                (Array.aset! &vs (Int.bit-and index 31) value)
                (Rc.new (Persistent.VectorNode.Leaf vs)))
              ; iterative descend/rebuild: recursing while passing the
              ; type-parameter through nested generic accessors makes inference
              ; diverge, so walk parallel spines (one copied children-array per
              ; level, plus its subindex). Exactly one array copy per level: the
              ; copy made on descent becomes the new node, mutated in place on
              ; the way back up.
              (let-do [subidx0 (Int.bit-and (Int.bit-shift-right index level) 31)
                       cs0 @(branch-children node)
                       cursor @(child-ref &cs0 subidx0)
                       spine-cs (the (Array (Array (Rc (Persistent.VectorNode a)))) [cs0])
                       spine-ix (the (Array Int) [subidx0])
                       lvl (- level 5)]
                (while (> lvl 0)
                  (let-do [subidx (Int.bit-and (Int.bit-shift-right index lvl) 31)
                           cs @(branch-children (Rc.value-ref &cursor))
                           child @(child-ref &cs subidx)]
                    (set! spine-cs (Array.push-back spine-cs cs))
                    (set! spine-ix (Array.push-back spine-ix subidx))
                    (set! cursor child)
                    (set! lvl (- lvl 5))))
                (let-do [lvs @(leaf-values (Rc.value-ref &cursor))]
                  (Array.aset! &lvs (Int.bit-and index 31) value)
                  (set! cursor (Rc.new (Persistent.VectorNode.Leaf lvs)))
                  (while (> (Array.length &spine-cs) 0)
                    (let-do [cs (Array.pop-back! &spine-cs)
                             sidx (Array.pop-back! &spine-ix)]
                      (set! cursor (Rc.new (Persistent.VectorNode.Branch
                                     (do (Array.aset! &cs sidx cursor) cs))))))
                  cursor))))

          (doc assoc "Replace value at index, returning `(Maybe next-vector)`.")
          (sig assoc (Fn [Int a (Ref (Persistent.Vector a) q)] (Maybe (Persistent.Vector a))))
          (defn assoc [index value vec-ref]
            (let [cnt @(Persistent.Vector.count vec-ref)]
              (if (or (< index 0) (>= index (Long.to-int cnt)))
                (Maybe.Nothing)
                (if (>= index (tailoff cnt))
                  (let-do [t @(Persistent.Vector.tail vec-ref)]
                    (Array.aset! &t (Int.bit-and index 31) value)
                    (Maybe.Just (Persistent.Vector.init cnt @(Persistent.Vector.shift vec-ref)
                                           @(Persistent.Vector.root vec-ref) t)))
                  (Maybe.Just (Persistent.Vector.init cnt @(Persistent.Vector.shift vec-ref)
                                (do-assoc @(Persistent.Vector.shift vec-ref)
                                          (Rc.value-ref (Persistent.Vector.root vec-ref))
                                          index value)
                                @(Persistent.Vector.tail vec-ref)))))))

          (private pop-tail)
          (hidden pop-tail)
          (sig pop-tail (Fn [Int (Ref (Persistent.VectorNode a) q) Long] (Maybe (Rc (Persistent.VectorNode a)))))
          (defn pop-tail [level node cnt]
            ; iterative descend/rebuild with collapse: descend to level 5
            ; recording a spine, drop the last leaf, then rebuild upward,
            ; propagating Nothing when a branch empties.
            (let-do [spine (the (Array (Pair (Array (Rc (Persistent.VectorNode a))) Int)) [])
                     cur-children @(branch-children node)
                     lvl level]
              (while (> lvl 5)
                (let-do [subidx (Int.bit-and (Int.bit-shift-right (Long.to-int (- cnt 2l)) lvl) 31)
                         child @(child-ref &cur-children subidx)]
                  (set! spine (Array.push-back spine (Pair.init @&cur-children subidx)))
                  (set! cur-children @(branch-children (Rc.value-ref &child)))
                  (set! lvl (- lvl 5))))
              (let-do [subidx5 (Int.bit-and (Int.bit-shift-right (Long.to-int (- cnt 2l)) 5) 31)
                       result (if (= subidx5 0)
                                (the (Maybe (Rc (Persistent.VectorNode a))) (Maybe.Nothing))
                                (Maybe.Just (Rc.new (Persistent.VectorNode.Branch
                                  (Array.prefix &cur-children subidx5)))))]
                (while (> (Array.length &spine) 0)
                  (let-do [pr (Array.pop-back! &spine)
                           cs @(Pair.a &pr)
                           sidx @(Pair.b &pr)]
                    (set! result
                      (match result
                        (Maybe.Nothing)
                          (if (= sidx 0)
                            (Maybe.Nothing)
                            (Maybe.Just (Rc.new (Persistent.VectorNode.Branch
                              (Array.prefix &cs sidx)))))
                        (Maybe.Just newchild)
                          (Maybe.Just (Rc.new (Persistent.VectorNode.Branch
                            (Array.aset cs sidx newchild))))))))
                result)))

          (doc pop-back
            "Pop last value, returning `(Maybe (Pair value next-vector))`.")
          (sig pop-back (Fn [(Ref (Persistent.Vector a) q)] (Maybe (Pair a (Persistent.Vector a)))))
          (defn pop-back [vec-ref]
            (let [cnt @(Persistent.Vector.count vec-ref)]
              (if (= cnt 0l)
                (Maybe.Nothing)
                (let [lastval (Maybe.unsafe-from
                                (get (Long.to-int (Long.dec cnt)) vec-ref))]
                  (if (= cnt 1l)
                    (Maybe.Just (Pair.init lastval (empty)))
                    (if (> (- (Long.to-int cnt) (tailoff cnt)) 1)
                      (let [t @(Persistent.Vector.tail vec-ref)
                            nt (Array.prefix &t (Int.dec (Array.length &t)))]
                        (Maybe.Just (Pair.init lastval
                          (Persistent.Vector.init (Long.dec cnt) @(Persistent.Vector.shift vec-ref)
                                     @(Persistent.Vector.root vec-ref) nt))))
                      (let [newtail-leaf (node-for vec-ref (- (Long.to-int cnt) 2))
                            newtail @(leaf-values (Rc.value-ref &newtail-leaf))
                            shift @(Persistent.Vector.shift vec-ref)]
                        (match (pop-tail shift
                                 (Rc.value-ref (Persistent.Vector.root vec-ref)) cnt)
                          (Maybe.Nothing)
                            (Maybe.Just (Pair.init lastval
                              (Persistent.Vector.init (Long.dec cnt) shift
                                         (Rc.new (Persistent.VectorNode.Branch [])) newtail)))
                          (Maybe.Just nr)
                            (if (and (> shift 5)
                                     (= 1 (nchildren (Rc.value-ref &nr))))
                              (let [collapsed @(child-ref
                                                 (branch-children
                                                   (Rc.value-ref &nr)) 0)]
                                (Maybe.Just (Pair.init lastval
                                  (Persistent.Vector.init (Long.dec cnt) (- shift 5)
                                             collapsed newtail))))
                              (Maybe.Just (Pair.init lastval
                                (Persistent.Vector.init (Long.dec cnt) shift nr newtail))))))))))))

          (doc ptr-eq
            "Pointer identity check for backing root plus count equality.")
          (sig ptr-eq (Fn [(Ref (Persistent.Vector a) q) (Ref (Persistent.Vector a) r)] Bool))
          (defn ptr-eq [a-ref b-ref]
            (and
              (= @(Persistent.Vector.count a-ref) @(Persistent.Vector.count b-ref))
              (Rc.ptr-eq (Persistent.Vector.root a-ref) (Persistent.Vector.root b-ref))))

          (doc reduce "Reduce the vector index 0 to count-1 with accumulator.")
          (sig reduce (Fn [(Ref (Fn [b a] b) q) b (Ref (Persistent.Vector a) r)] b))
          (defn reduce [f init vec-ref]
            (let-do [acc init
                     n (Long.to-int @(Persistent.Vector.count vec-ref))]
              (for [i 0 n]
                (match (get i vec-ref)
                  (Maybe.Nothing) ()
                  (Maybe.Just v) (set! acc (~f acc v))))
              acc))

          (doc each
            "Invoke a side-effecting function on each value in index order.")
          (sig each (Fn [(Ref (Fn [a] ()) q) (Ref (Persistent.Vector a) r)] ()))
          (defn each [f vec-ref]
            (let-do [n (Long.to-int @(Persistent.Vector.count vec-ref))]
              (for [i 0 n]
                (match (get i vec-ref) (Maybe.Nothing) () (Maybe.Just v) (~f v)))))

          (doc to-array "Copy all values into an `Array` in index order.")
          (sig to-array (Fn [(Ref (Persistent.Vector a) q)] (Array a)))
          (defn to-array [vec-ref]
            (reduce &(fn [acc x] (Array.push-back acc x)) [] vec-ref))

          (doc from-array
            "Build a vector from an `Array`, preserving index order.")
          (sig from-array (Fn [(Ref (Array a) q)] (Persistent.Vector a)))
          (defn from-array [arr-ref]
            (Array.reduce &(fn [acc x] (push-back @x &acc)) (empty) arr-ref))

          (doc singleton "Create a singleton vector.")
          (sig singleton (Fn [a] (Persistent.Vector a)))
          (defn singleton [value] (push-back value &(empty)))

          (doc = "Structural equality: same length and pairwise equal values.")
          (sig = (Fn [(Ref (Persistent.Vector a) q) (Ref (Persistent.Vector a) q)] Bool))
          (defn = [a-ref b-ref]
            (if (/= @(Persistent.Vector.count a-ref) @(Persistent.Vector.count b-ref))
              false
              (let [aa (to-array a-ref)
                    ab (to-array b-ref)] (= &aa &ab))))
          (implements = Persistent.Vector.=)

          (doc any? "Return true if any element satisfies the predicate.")
          (sig any?
               (Fn [(Ref (Fn [(Ref a q)] Bool) r) (Ref (Persistent.Vector a) s)] Bool))
          (defn any? [pred coll-ref]
            (reduce &(fn [acc x] (or acc (~pred &x))) false coll-ref))

          (doc all? "Return true if all elements satisfy the predicate.")
          (sig all?
               (Fn [(Ref (Fn [(Ref a q)] Bool) r) (Ref (Persistent.Vector a) s)] Bool))
          (defn all? [pred coll-ref]
            (reduce &(fn [acc x] (and acc (~pred &x))) true coll-ref))

          (doc map
            "Apply a function to each element, returning a new vector in index order.")
          (sig map
               (Fn [(Ref (Fn [a] a) q) (Ref (Persistent.Vector a) r)] (Persistent.Vector a)))
          (defn map [f vec-ref]
            (reduce &(fn [acc x] (push-back (~f x) &acc)) (empty) vec-ref))

          (doc filter
            "Keep only elements satisfying a predicate, preserving index order.")
          (sig filter
               (Fn [(Ref (Fn [(Ref a q)] Bool) r) (Ref (Persistent.Vector a) s)] (Persistent.Vector a)))
          (defn filter [pred vec-ref]
            (reduce
              &(fn [acc x] (if (~pred &x) (push-back x &acc) acc))
              (empty)
              vec-ref))

          (doc str "Diagnostic formatting for a vector.")
          (sig str (Fn [(Ref (Persistent.Vector a) q)] String))
          (defn str [vec-ref]
            (fmt "(PersistentVector size=%ld)" (length vec-ref)))

          (sig prn (Fn [(Ref (Persistent.Vector a) q)] String))
          (defn prn [vec-ref] (str vec-ref)))
)
