(load "Test.carp")
(use Test)
(load "../persistent.carp")
(load "test_harness.carp")

(TestHarness.configure-build)

(Persistent.define-ord-set IntSet Int)

(defn assert-memory-balance [state f expected-balance descr]
  (do
    (Debug.reset-memory-balance!)
    (f)
    (assert-equal state expected-balance (Debug.memory-balance) descr)))

(defn set-branch-lifecycle []
  (let [s0 (IntSet.empty)
        s1 (IntSet.insert 10 &s0)
        s2 (IntSet.insert 5 &s1)
        s3 (IntSet.insert 15 &s1)
        s4 (IntSet.remove 10 &s2)]
    (do (ignore s3) (ignore s4))))

(deftest test
  (assert-equal test
    true
    (let [s (IntSet.empty)] (IntSet.empty? &s))
    "empty ordered set reports empty")

  (assert-equal test
    true
    (let [s0 (IntSet.empty)
          s1 (IntSet.insert 2 &s0)
          s2 (IntSet.insert 1 &s1)
          s3 (IntSet.insert 3 &s2)]
      (and (= (IntSet.length &s3) 3l)
           (IntSet.contains? 1 &s3)
           (IntSet.contains? 2 &s3)
           (IntSet.contains? 3 &s3)))
    "insert/contains works")

  (assert-equal test
    true
    (let [s0 (IntSet.empty)
          s1 (IntSet.insert 7 &s0)
          s2 (IntSet.insert 7 &s1)]
      (= (IntSet.length &s2) 1l))
    "duplicate insert is idempotent")

  (assert-equal test
    true
    (let [s0 (IntSet.empty)
          s1 (IntSet.insert 7 &s0)
          s2 (IntSet.insert 8 &s1)
          s3 (IntSet.remove 7 &s2)]
      (and (= (IntSet.length &s3) 1l)
           (not (IntSet.contains? 7 &s3))
           (IntSet.contains? 8 &s3)))
    "remove drops only target value")

  (assert-equal test
    true
    (let [s0 (IntSet.empty)
          s1 (IntSet.insert 3 &s0)
          s2 (IntSet.insert 1 &s1)
          s3 (IntSet.insert 2 &s2)
          arr (IntSet.to-array &s3)]
      (and (= (Array.length &arr) 3)
           (= @(Array.unsafe-nth &arr 0) 1)
           (= @(Array.unsafe-nth &arr 2) 3)))
    "to-array yields ascending order")

  (assert-equal test
    true
    (let [a (IntSet.insert 2 &(IntSet.insert 1 &(IntSet.empty)))
          b (IntSet.insert 1 &(IntSet.insert 2 &(IntSet.empty)))
          c (IntSet.insert 3 &(IntSet.insert 1 &(IntSet.empty)))]
      (and (= &a &b) (not (= &a &c))))
    "= is structural regardless of insertion order")

  (assert-equal test
    true
    (let [a (IntSet.insert 2 &(IntSet.insert 1 &(IntSet.empty)))
          b (IntSet.insert 3 &(IntSet.insert 2 &(IntSet.empty)))
          u (IntSet.union &a &b)
          arr (IntSet.to-array &u)]
      (and (= (Array.length &arr) 3)
           (= @(Array.unsafe-nth &arr 0) 1)
           (= @(Array.unsafe-nth &arr 1) 2)
           (= @(Array.unsafe-nth &arr 2) 3)))
    "union merges elements from both sets")

  (assert-equal test
    true
    (let [a (IntSet.insert 2 &(IntSet.insert 1 &(IntSet.empty)))
          u (IntSet.union &a &(IntSet.empty))]
      (= &a &u))
    "union with empty set is identity")

  (assert-equal test
    true
    (let [a (IntSet.insert 2 &(IntSet.insert 1 &(IntSet.empty)))
          b (IntSet.insert 3 &(IntSet.insert 2 &(IntSet.empty)))
          i (IntSet.intersection &a &b)
          arr (IntSet.to-array &i)]
      (and (= (Array.length &arr) 1) (= @(Array.unsafe-nth &arr 0) 2)))
    "intersection keeps only shared elements")

  (assert-equal test
    true
    (let [a (IntSet.insert 2 &(IntSet.insert 1 &(IntSet.empty)))
          b (IntSet.insert 4 &(IntSet.insert 3 &(IntSet.empty)))
          i (IntSet.intersection &a &b)]
      (IntSet.empty? &i))
    "intersection of disjoint sets is empty")

  (assert-equal test
    true
    (let [a (IntSet.insert 3
                           &(IntSet.insert 2 &(IntSet.insert 1 &(IntSet.empty))))
          b (IntSet.insert 3 &(IntSet.insert 2 &(IntSet.empty)))
          d (IntSet.difference &a &b)
          arr (IntSet.to-array &d)]
      (and (= (Array.length &arr) 1) (= @(Array.unsafe-nth &arr 0) 1)))
    "difference removes elements in second set")

  (assert-equal test
    true
    (let [a (IntSet.insert 2 &(IntSet.insert 1 &(IntSet.empty)))
          d (IntSet.difference &a &(IntSet.empty))]
      (= &a &d))
    "difference with empty set is identity")

  (assert-equal test
    true
    (let [a (IntSet.insert 2 &(IntSet.insert 1 &(IntSet.empty)))
          d (IntSet.difference &a &a)]
      (IntSet.empty? &d))
    "difference with self is empty")

  (assert-equal test
    true
    (let [s (IntSet.insert 3
                           &(IntSet.insert 2 &(IntSet.insert 1 &(IntSet.empty))))]
      (IntSet.any? &(fn [x] (= x &3)) &s))
    "any? finds matching element")

  (assert-equal test
    false
    (let [s (IntSet.insert 3
                           &(IntSet.insert 2 &(IntSet.insert 1 &(IntSet.empty))))]
      (IntSet.any? &(fn [x] (= x &99)) &s))
    "any? returns false when none match")

  (assert-equal test
    true
    (let [s (IntSet.insert 3
                           &(IntSet.insert 2 &(IntSet.insert 1 &(IntSet.empty))))]
      (IntSet.all? &(fn [x] (> @x 0)) &s))
    "all? returns true when all match")

  (assert-equal test
    false
    (let [s (IntSet.insert 3
                           &(IntSet.insert 2 &(IntSet.insert 1 &(IntSet.empty))))]
      (IntSet.all? &(fn [x] (> @x 2)) &s))
    "all? returns false when not all match")

  (assert-equal test
    false
    (IntSet.any? &(fn [x] (= x &1)) &(IntSet.empty))
    "any? on empty returns false")

  (assert-equal test
    true
    (IntSet.all? &(fn [x] (= x &1)) &(IntSet.empty))
    "all? on empty returns true")

  (assert-equal test
    true
    (let-do [s (IntSet.empty)]
      (for [i 0 1000] (set! s (IntSet.insert i &s)))
      (<= (IntSet.height &s) 15))
    "AVL set height is logarithmic after 1000 ascending inserts")

  (assert-equal test
    true
    (let [arr [3 1 2]
          s (IntSet.from-array &arr)
          back (IntSet.to-array &s)]
      (and (= (IntSet.length &s) 3l)
           (= @(Array.unsafe-nth &back 0) 1)
           (= @(Array.unsafe-nth &back 1) 2)
           (= @(Array.unsafe-nth &back 2) 3)))
    "from-array builds set with elements in ascending order")

  (assert-equal test
    true
    (let [s (IntSet.from-array &(the (Array Int) []))] (IntSet.empty? &s))
    "from-array on empty array yields empty set")

  (assert-equal test
    true
    (let [s (IntSet.insert 3
                           &(IntSet.insert 2 &(IntSet.insert 1 &(IntSet.empty))))
          filtered (IntSet.filter &(fn [x] (> @x 1)) &s)
          arr (IntSet.to-array &filtered)]
      (and (= (Array.length &arr) 2)
           (= @(Array.unsafe-nth &arr 0) 2)
           (= @(Array.unsafe-nth &arr 1) 3)))
    "filter keeps elements matching predicate in order")

  (assert-equal test
    true
    (let [s (IntSet.insert 2 &(IntSet.insert 1 &(IntSet.empty)))
          filtered (IntSet.filter &(fn [x] false) &s)]
      (IntSet.empty? &filtered))
    "filter with always-false yields empty set")

  (assert-equal test
    true
    (let [s (IntSet.insert 2 &(IntSet.insert 1 &(IntSet.empty)))
          filtered (IntSet.filter &(fn [x] true) &s)]
      (= &filtered &s))
    "filter with always-true preserves all elements")

  (assert-equal test
    true
    (let [filtered (IntSet.filter &(fn [x] true) &(IntSet.empty))]
      (IntSet.empty? &filtered))
    "filter on empty set yields empty set")

  (assert-equal test
    true
    (let [s (IntSet.insert 3
                           &(IntSet.insert 2 &(IntSet.insert 1 &(IntSet.empty))))
          mapped (IntSet.map &(fn [x] (* x 10)) &s)
          arr (IntSet.to-array &mapped)]
      (and (= (Array.length &arr) 3)
           (= @(Array.unsafe-nth &arr 0) 10)
           (= @(Array.unsafe-nth &arr 1) 20)
           (= @(Array.unsafe-nth &arr 2) 30)))
    "map applies function preserving ascending order")

  (assert-equal test
    true
    (let [mapped (IntSet.map &(fn [x] (+ x 1)) &(IntSet.empty))]
      (IntSet.empty? &mapped))
    "map over empty set yields empty set")

  (assert-equal test
    true
    (let [s (IntSet.insert 2 &(IntSet.insert 1 &(IntSet.empty)))
          mapped (IntSet.map &(fn [x] 42) &s)]
      (and (= (IntSet.length &mapped) 1l) (IntSet.contains? 42 &mapped)))
    "map that collapses values reduces set size")

  (assert-memory-balance test
                         set-branch-lifecycle
                         0l
                         "persistent ordered set branch lifecycle is memory-balanced"))
