(load "Test.carp")
(use Test)
(load "../persistent.carp")
(load "test_harness.carp")

(TestHarness.configure-build)

(defn assert-memory-balance [state f expected-balance descr]
  (do
    (Debug.reset-memory-balance!)
    (f)
    (assert-equal state expected-balance (Debug.memory-balance) descr)))

(defn set-branch-lifecycle []
  (let [s0 (the (Persistent.OrdSet Int) (Persistent.OrdSet.empty))
        s1 (Persistent.OrdSet.insert 10 &s0)
        s2 (Persistent.OrdSet.insert 5 &s1)
        s3 (Persistent.OrdSet.insert 15 &s1)
        s4 (Persistent.OrdSet.remove 10 &s2)]
    (do (ignore s3) (ignore s4))))

(deftest test
  (assert-equal test
    true
    (let [s (the (Persistent.OrdSet Int) (Persistent.OrdSet.empty))] (Persistent.OrdSet.empty? &s))
    "empty ordered set reports empty")

  (assert-equal test
    true
    (let [s0 (the (Persistent.OrdSet Int) (Persistent.OrdSet.empty))
          s1 (Persistent.OrdSet.insert 2 &s0)
          s2 (Persistent.OrdSet.insert 1 &s1)
          s3 (Persistent.OrdSet.insert 3 &s2)]
      (and (= (Persistent.OrdSet.length &s3) 3l)
           (Persistent.OrdSet.contains? 1 &s3)
           (Persistent.OrdSet.contains? 2 &s3)
           (Persistent.OrdSet.contains? 3 &s3)))
    "insert/contains works")

  (assert-equal test
    true
    (let [s0 (the (Persistent.OrdSet Int) (Persistent.OrdSet.empty))
          s1 (Persistent.OrdSet.insert 7 &s0)
          s2 (Persistent.OrdSet.insert 7 &s1)]
      (= (Persistent.OrdSet.length &s2) 1l))
    "duplicate insert is idempotent")

  (assert-equal test
    true
    (let [s0 (the (Persistent.OrdSet Int) (Persistent.OrdSet.empty))
          s1 (Persistent.OrdSet.insert 7 &s0)
          s2 (Persistent.OrdSet.insert 8 &s1)
          s3 (Persistent.OrdSet.remove 7 &s2)]
      (and (= (Persistent.OrdSet.length &s3) 1l)
           (not (Persistent.OrdSet.contains? 7 &s3))
           (Persistent.OrdSet.contains? 8 &s3)))
    "remove drops only target value")

  (assert-equal test
    true
    (let [s0 (the (Persistent.OrdSet Int) (Persistent.OrdSet.empty))
          s1 (Persistent.OrdSet.insert 3 &s0)
          s2 (Persistent.OrdSet.insert 1 &s1)
          s3 (Persistent.OrdSet.insert 2 &s2)
          arr (Persistent.OrdSet.to-array &s3)]
      (and (= (Array.length &arr) 3)
           (= @(Array.unsafe-nth &arr 0) 1)
           (= @(Array.unsafe-nth &arr 2) 3)))
    "to-array yields ascending order")

  (assert-equal test
    true
    (let [a (Persistent.OrdSet.insert 2 &(Persistent.OrdSet.insert 1 &(the (Persistent.OrdSet Int) (Persistent.OrdSet.empty))))
          b (Persistent.OrdSet.insert 1 &(Persistent.OrdSet.insert 2 &(the (Persistent.OrdSet Int) (Persistent.OrdSet.empty))))
          c (Persistent.OrdSet.insert 3 &(Persistent.OrdSet.insert 1 &(the (Persistent.OrdSet Int) (Persistent.OrdSet.empty))))]
      (and (= &a &b) (not (= &a &c))))
    "= is structural regardless of insertion order")

  (assert-equal test
    true
    (let [a (Persistent.OrdSet.insert 2 &(Persistent.OrdSet.insert 1 &(the (Persistent.OrdSet Int) (Persistent.OrdSet.empty))))
          b (Persistent.OrdSet.insert 3 &(Persistent.OrdSet.insert 2 &(the (Persistent.OrdSet Int) (Persistent.OrdSet.empty))))
          u (Persistent.OrdSet.union &a &b)
          arr (Persistent.OrdSet.to-array &u)]
      (and (= (Array.length &arr) 3)
           (= @(Array.unsafe-nth &arr 0) 1)
           (= @(Array.unsafe-nth &arr 1) 2)
           (= @(Array.unsafe-nth &arr 2) 3)))
    "union merges elements from both sets")

  (assert-equal test
    true
    (let [a (Persistent.OrdSet.insert 2 &(Persistent.OrdSet.insert 1 &(the (Persistent.OrdSet Int) (Persistent.OrdSet.empty))))
          u (Persistent.OrdSet.union &a &(the (Persistent.OrdSet Int) (Persistent.OrdSet.empty)))]
      (= &a &u))
    "union with empty set is identity")

  (assert-equal test
    true
    (let [a (Persistent.OrdSet.insert 2 &(Persistent.OrdSet.insert 1 &(the (Persistent.OrdSet Int) (Persistent.OrdSet.empty))))
          b (Persistent.OrdSet.insert 3 &(Persistent.OrdSet.insert 2 &(the (Persistent.OrdSet Int) (Persistent.OrdSet.empty))))
          i (Persistent.OrdSet.intersection &a &b)
          arr (Persistent.OrdSet.to-array &i)]
      (and (= (Array.length &arr) 1) (= @(Array.unsafe-nth &arr 0) 2)))
    "intersection keeps only shared elements")

  (assert-equal test
    true
    (let [a (Persistent.OrdSet.insert 2 &(Persistent.OrdSet.insert 1 &(the (Persistent.OrdSet Int) (Persistent.OrdSet.empty))))
          b (Persistent.OrdSet.insert 4 &(Persistent.OrdSet.insert 3 &(the (Persistent.OrdSet Int) (Persistent.OrdSet.empty))))
          i (Persistent.OrdSet.intersection &a &b)]
      (Persistent.OrdSet.empty? &i))
    "intersection of disjoint sets is empty")

  (assert-equal test
    true
    (let [a (Persistent.OrdSet.insert 3
                           &(Persistent.OrdSet.insert 2 &(Persistent.OrdSet.insert 1 &(the (Persistent.OrdSet Int) (Persistent.OrdSet.empty)))))
          b (Persistent.OrdSet.insert 3 &(Persistent.OrdSet.insert 2 &(the (Persistent.OrdSet Int) (Persistent.OrdSet.empty))))
          d (Persistent.OrdSet.difference &a &b)
          arr (Persistent.OrdSet.to-array &d)]
      (and (= (Array.length &arr) 1) (= @(Array.unsafe-nth &arr 0) 1)))
    "difference removes elements in second set")

  (assert-equal test
    true
    (let [a (Persistent.OrdSet.insert 2 &(Persistent.OrdSet.insert 1 &(the (Persistent.OrdSet Int) (Persistent.OrdSet.empty))))
          d (Persistent.OrdSet.difference &a &(the (Persistent.OrdSet Int) (Persistent.OrdSet.empty)))]
      (= &a &d))
    "difference with empty set is identity")

  (assert-equal test
    true
    (let [a (Persistent.OrdSet.insert 2 &(Persistent.OrdSet.insert 1 &(the (Persistent.OrdSet Int) (Persistent.OrdSet.empty))))
          d (Persistent.OrdSet.difference &a &a)]
      (Persistent.OrdSet.empty? &d))
    "difference with self is empty")

  (assert-equal test
    true
    (let [s (Persistent.OrdSet.insert 3
                           &(Persistent.OrdSet.insert 2 &(Persistent.OrdSet.insert 1 &(the (Persistent.OrdSet Int) (Persistent.OrdSet.empty)))))]
      (Persistent.OrdSet.any? &(fn [x] (= x &3)) &s))
    "any? finds matching element")

  (assert-equal test
    false
    (let [s (Persistent.OrdSet.insert 3
                           &(Persistent.OrdSet.insert 2 &(Persistent.OrdSet.insert 1 &(the (Persistent.OrdSet Int) (Persistent.OrdSet.empty)))))]
      (Persistent.OrdSet.any? &(fn [x] (= x &99)) &s))
    "any? returns false when none match")

  (assert-equal test
    true
    (let [s (Persistent.OrdSet.insert 3
                           &(Persistent.OrdSet.insert 2 &(Persistent.OrdSet.insert 1 &(the (Persistent.OrdSet Int) (Persistent.OrdSet.empty)))))]
      (Persistent.OrdSet.all? &(fn [x] (> @x 0)) &s))
    "all? returns true when all match")

  (assert-equal test
    false
    (let [s (Persistent.OrdSet.insert 3
                           &(Persistent.OrdSet.insert 2 &(Persistent.OrdSet.insert 1 &(the (Persistent.OrdSet Int) (Persistent.OrdSet.empty)))))]
      (Persistent.OrdSet.all? &(fn [x] (> @x 2)) &s))
    "all? returns false when not all match")

  (assert-equal test
    false
    (Persistent.OrdSet.any? &(fn [x] (= x &1)) &(the (Persistent.OrdSet Int) (Persistent.OrdSet.empty)))
    "any? on empty returns false")

  (assert-equal test
    true
    (Persistent.OrdSet.all? &(fn [x] (= x &1)) &(the (Persistent.OrdSet Int) (Persistent.OrdSet.empty)))
    "all? on empty returns true")

  (assert-equal test
    true
    (let-do [s (the (Persistent.OrdSet Int) (Persistent.OrdSet.empty))]
      (for [i 0 1000] (set! s (Persistent.OrdSet.insert i &s)))
      (<= (Persistent.OrdSet.height &s) 15))
    "AVL set height is logarithmic after 1000 ascending inserts")

  (assert-equal test
    true
    (let [arr [3 1 2]
          s (Persistent.OrdSet.from-array &arr)
          back (Persistent.OrdSet.to-array &s)]
      (and (= (Persistent.OrdSet.length &s) 3l)
           (= @(Array.unsafe-nth &back 0) 1)
           (= @(Array.unsafe-nth &back 1) 2)
           (= @(Array.unsafe-nth &back 2) 3)))
    "from-array builds set with elements in ascending order")

  (assert-equal test
    true
    (let [s (Persistent.OrdSet.from-array &(the (Array Int) []))] (Persistent.OrdSet.empty? &s))
    "from-array on empty array yields empty set")

  (assert-memory-balance test
                         set-branch-lifecycle
                         0l
                         "persistent ordered set branch lifecycle is memory-balanced"))
