(load "Test.carp")
(use Test)
(load "../persistent.carp")
(load "test_harness.carp")

(TestHarness.configure-build)

(defn assert-memory-balance [state f expected-balance descr]
  (do
    (Debug.reset-memory-balance!)
    (f)
    (assert-equal state expected-balance (Debug.memory-balance) descr)))

(defn build-long-back-deque [n]
  (let-do [d (the (Persistent.Deque Int) (Persistent.Deque.empty))]
    (for [i 0 n] (set! d (Persistent.Deque.push-back i &d)))
    d))

(defn deque-branch-lifecycle []
  (let [d0 (the (Persistent.Deque Int) (Persistent.Deque.empty))
        d1 (Persistent.Deque.push-back 1 &d0)
        d2 (Persistent.Deque.push-back 2 &d1)
        d3 (Persistent.Deque.push-front 0 &d2)
        d4 (Persistent.Deque.push-back 3 &d3)]
    (do (ignore d2) (ignore d4))))

(defn pop-front-values [dq-ref]
  (let [out0 []] (pop-front-values-iter dq-ref &out0)))

(defn pop-front-values-iter [dq-ref out-ref]
  (match (Persistent.Deque.pop-front dq-ref)
    (Maybe.Nothing) @out-ref
    (Maybe.Just p)
      (let [value @(Pair.a &p)
            next-dq @(Pair.b &p)]
        (do
          (Array.push-back! out-ref value)
          (pop-front-values-iter &next-dq out-ref)))))

(deftest test
  (assert-equal test
    true
    (let [d (the (Persistent.Deque Int) (Persistent.Deque.empty))] (Persistent.Deque.empty? &d))
    "empty deque reports empty")

  (assert-equal test
    0l
    (let [d (the (Persistent.Deque Int) (Persistent.Deque.empty))] (Persistent.Deque.length &d))
    "empty deque has length 0")

  (assert-equal test
    true
    (let [d0 (the (Persistent.Deque Int) (Persistent.Deque.empty))
          d1 (Persistent.Deque.push-back 1 &d0)
          d2 (Persistent.Deque.push-front 0 &d1)
          d3 (Persistent.Deque.push-back 2 &d2)]
      (and
        (match (Persistent.Deque.peek-front &d3)
          (Maybe.Just v) (= v 0)
          (Maybe.Nothing) false)
        (match (Persistent.Deque.peek-back &d3)
          (Maybe.Just v) (= v 2)
          (Maybe.Nothing) false)))
    "peek-front/peek-back read both ends")

  (assert-equal test
    true
    (let [d0 (the (Persistent.Deque Int) (Persistent.Deque.empty))
          d1 (Persistent.Deque.push-back 1 &d0)
          d2 (Persistent.Deque.push-back 2 &d1)
          d3 (Persistent.Deque.push-front 0 &d2)
          vals (pop-front-values &d3)]
      (and (= (Array.length &vals) 3)
           (= @(Array.unsafe-nth &vals 0) 0)
           (= @(Array.unsafe-nth &vals 1) 1)
           (= @(Array.unsafe-nth &vals 2) 2)))
    "pop-front drains in expected order")

  (assert-equal test
    true
    (let [d0 (the (Persistent.Deque Int) (Persistent.Deque.empty))
          d1 (Persistent.Deque.push-back 1 &d0)
          d2 (Persistent.Deque.push-back 2 &d1)
          d3 (Persistent.Deque.push-back 3 &d2)]
      (match (Persistent.Deque.pop-back &d3)
        (Maybe.Nothing) false
        (Maybe.Just p)
          (let [value @(Pair.a &p)
                d4 @(Pair.b &p)]
            (and (= value 3)
                 (match (Persistent.Deque.peek-back &d4)
                   (Maybe.Just v) (= v 2)
                   (Maybe.Nothing) false)))))
    "pop-back removes rear and updates rear view")

  (assert-equal test
    true
    (let [d0 (the (Persistent.Deque Int) (Persistent.Deque.empty))
          d1 (Persistent.Deque.push-back 1 &d0)
          d2 (Persistent.Deque.push-back 2 &d1)
          d3 (Persistent.Deque.push-back 3 &d1)]
      (and (not (Persistent.Deque.ptr-eq &d2 &d3))
           (= (Persistent.Deque.length &d2) 2l)
           (= (Persistent.Deque.length &d3) 2l)))
    "branching deques preserve persistence")

  (assert-equal test
    true
    (let [d (build-long-back-deque 100000)]
      (match (Persistent.Deque.pop-front &d)
        (Maybe.Nothing) false
        (Maybe.Just p)
          (let [v @(Pair.a &p)
                d2 @(Pair.b &p)]
            (and (= v 0) (= (Persistent.Deque.length &d2) 99999l)))))
    "pop-front on 100k rear-only deque rebalances without blowing the C stack")

  (assert-equal test
    true
    (let [d0 (the (Persistent.Deque Int) (Persistent.Deque.empty))
          d1 (Persistent.Deque.push-back 2 &d0)
          d2 (Persistent.Deque.push-back 3 &d1)
          d3 (Persistent.Deque.push-front 1 &d2)
          arr (Persistent.Deque.to-array &d3)]
      (and (= (Array.length &arr) 3)
           (= @(Array.unsafe-nth &arr 0) 1)
           (= @(Array.unsafe-nth &arr 1) 2)
           (= @(Array.unsafe-nth &arr 2) 3)))
    "to-array materializes deque front-to-back")

  (assert-equal test
    6
    (let [d0 (the (Persistent.Deque Int) (Persistent.Deque.empty))
          d1 (Persistent.Deque.push-back 2 &d0)
          d2 (Persistent.Deque.push-front 1 &d1)
          d3 (Persistent.Deque.push-back 3 &d2)]
      (Persistent.Deque.reduce &(fn [acc x] (+ acc x)) 0 &d3))
    "reduce folds deque front-to-back")

  (assert-equal test
    true
    (let [a (Persistent.Deque.push-back 2 &(Persistent.Deque.push-back 1 &(the (Persistent.Deque Int) (Persistent.Deque.empty))))
          b (Persistent.Deque.push-front 1 &(Persistent.Deque.push-back 2 &(the (Persistent.Deque Int) (Persistent.Deque.empty))))
          c (Persistent.Deque.push-back 3 &(Persistent.Deque.push-back 1 &(the (Persistent.Deque Int) (Persistent.Deque.empty))))]
      (and (= &a &b) (not (= &a &c))))
    "= is structural regardless of front/rear split")

  (assert-equal test
    true
    (let [d0 (the (Persistent.Deque Int) (Persistent.Deque.empty))
          d1 (Persistent.Deque.push-back 1 &d0)
          d2 (Persistent.Deque.push-back 2 &d1)
          d3 (Persistent.Deque.push-front 0 &d2)
          mapped (Persistent.Deque.map &(fn [x] (+ x 10)) &d3)
          arr (Persistent.Deque.to-array &mapped)]
      (and (= (Array.length &arr) 3)
           (= @(Array.unsafe-nth &arr 0) 10)
           (= @(Array.unsafe-nth &arr 1) 11)
           (= @(Array.unsafe-nth &arr 2) 12)))
    "map applies function preserving front-to-back order")

  (assert-equal test
    true
    (let [d (the (Persistent.Deque Int) (Persistent.Deque.empty))
          m (Persistent.Deque.map &(fn [x] (+ x 1)) &d)]
      (Persistent.Deque.empty? &m))
    "map over empty deque yields empty")

  (assert-equal test
    true
    (let [d0 (the (Persistent.Deque Int) (Persistent.Deque.empty))
          d1 (Persistent.Deque.push-back 1 &d0)
          d2 (Persistent.Deque.push-back 2 &d1)
          d3 (Persistent.Deque.push-back 3 &d2)
          d4 (Persistent.Deque.push-front 0 &d3)
          filtered (Persistent.Deque.filter &(fn [x] (> @x 1)) &d4)
          arr (Persistent.Deque.to-array &filtered)]
      (and (= (Array.length &arr) 2)
           (= @(Array.unsafe-nth &arr 0) 2)
           (= @(Array.unsafe-nth &arr 1) 3)))
    "filter keeps elements matching predicate in order")

  (assert-equal test
    true
    (let [d0 (the (Persistent.Deque Int) (Persistent.Deque.empty))
          d1 (Persistent.Deque.push-back 1 &d0)
          d2 (Persistent.Deque.push-back 2 &d1)
          filtered (Persistent.Deque.filter &(fn [x] false) &d2)]
      (Persistent.Deque.empty? &filtered))
    "filter with always-false yields empty deque")

  (assert-equal test
    true
    (let [d0 (the (Persistent.Deque Int) (Persistent.Deque.empty))
          d1 (Persistent.Deque.push-back 1 &d0)
          d2 (Persistent.Deque.push-back 2 &d1)
          filtered (Persistent.Deque.filter &(fn [x] true) &d2)]
      (= &filtered &d2))
    "filter with always-true preserves all elements")

  (assert-equal test
    true
    (let [d (Persistent.Deque.push-back 3
                                &(Persistent.Deque.push-back 2
                                                     &(Persistent.Deque.push-back 1
                                                                          &(the (Persistent.Deque Int) (Persistent.Deque.empty)))))]
      (Persistent.Deque.any? &(fn [x] (= x &3)) &d))
    "any? finds matching element")

  (assert-equal test
    false
    (let [d (Persistent.Deque.push-back 3
                                &(Persistent.Deque.push-back 2
                                                     &(Persistent.Deque.push-back 1
                                                                          &(the (Persistent.Deque Int) (Persistent.Deque.empty)))))]
      (Persistent.Deque.any? &(fn [x] (= x &99)) &d))
    "any? returns false when none match")

  (assert-equal test
    true
    (let [d (Persistent.Deque.push-back 3
                                &(Persistent.Deque.push-back 2
                                                     &(Persistent.Deque.push-back 1
                                                                          &(the (Persistent.Deque Int) (Persistent.Deque.empty)))))]
      (Persistent.Deque.all? &(fn [x] (> @x 0)) &d))
    "all? returns true when all match")

  (assert-equal test
    false
    (let [d (Persistent.Deque.push-back 3
                                &(Persistent.Deque.push-back 2
                                                     &(Persistent.Deque.push-back 1
                                                                          &(the (Persistent.Deque Int) (Persistent.Deque.empty)))))]
      (Persistent.Deque.all? &(fn [x] (> @x 2)) &d))
    "all? returns false when not all match")

  (assert-equal test
    false
    (Persistent.Deque.any? &(fn [x] (= x &1)) &(the (Persistent.Deque Int) (Persistent.Deque.empty)))
    "any? on empty returns false")

  (assert-equal test
    true
    (Persistent.Deque.all? &(fn [x] (= x &1)) &(the (Persistent.Deque Int) (Persistent.Deque.empty)))
    "all? on empty returns true")

  (assert-equal test
    true
    (let [arr [10 20 30]
          d (Persistent.Deque.from-array &arr)
          back (Persistent.Deque.to-array &d)]
      (= &arr &back))
    "from-array round-trips through to-array")

  (assert-equal test
    true
    (let [d (Persistent.Deque.from-array &(the (Array Int) []))] (Persistent.Deque.empty? &d))
    "from-array on empty array yields empty deque")

  (assert-memory-balance test
                         deque-branch-lifecycle
                         0l
                         "persistent deque branch lifecycle is memory-balanced"))
