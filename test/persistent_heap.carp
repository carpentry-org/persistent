(load "Test.carp")
(use Test)
(load "../persistent.carp")
(load "test_harness.carp")

(TestHarness.configure-build)

(defn assert-memory-balance [state f expected-balance descr]
  (do
    (Debug.reset-memory-balance!)
    (f)
    (assert-equal state expected-balance (Debug.memory-balance) descr)))

(defn build-descending-heap [n]
  (let-do [h (the (Persistent.Heap Int) (Persistent.Heap.empty))]
    (for [i 0 n] (set! h (Persistent.Heap.insert (- n i) &h)))
    h))

(defn heap-branch-lifecycle []
  (let [h0 (the (Persistent.Heap Int) (Persistent.Heap.empty))
        h1 (Persistent.Heap.insert 5 &h0)
        h2 (Persistent.Heap.insert 2 &h1)
        h3 (Persistent.Heap.insert 7 &h1)
        h4 (Persistent.Heap.merge &h2 &h3)]
    (ignore h4)))

(defn pop-values [heap-ref] (let [out0 []] (pop-values-iter heap-ref &out0)))

(defn pop-values-iter [heap-ref out-ref]
  (match (Persistent.Heap.pop heap-ref)
    (Maybe.Nothing) @out-ref
    (Maybe.Just p)
      (let [value @(Pair.a &p)
            next-h @(Pair.b &p)]
        (do (Array.push-back! out-ref value) (pop-values-iter &next-h out-ref)))))

(deftest test
  (assert-equal test
    true
    (let [h (the (Persistent.Heap Int) (Persistent.Heap.empty))] (Persistent.Heap.empty? &h))
    "empty heap reports empty")

  (assert-equal test
    true
    (let [h0 (the (Persistent.Heap Int) (Persistent.Heap.empty))
          h1 (Persistent.Heap.insert 5 &h0)
          h2 (Persistent.Heap.insert 2 &h1)
          h3 (Persistent.Heap.insert 7 &h2)]
      (match (Persistent.Heap.peek &h3) (Maybe.Just v) (= v 2) (Maybe.Nothing) false))
    "peek returns minimum")

  (assert-equal test
    true
    (let [h0 (the (Persistent.Heap Int) (Persistent.Heap.empty))
          h1 (Persistent.Heap.insert 5 &h0)
          h2 (Persistent.Heap.insert 2 &h1)
          h3 (Persistent.Heap.insert 7 &h2)
          vals (pop-values &h3)]
      (and (= (Array.length &vals) 3)
           (= @(Array.unsafe-nth &vals 0) 2)
           (= @(Array.unsafe-nth &vals 1) 5)
           (= @(Array.unsafe-nth &vals 2) 7)))
    "pop drains in ascending order")

  (assert-equal test
    true
    (let [a0 (the (Persistent.Heap Int) (Persistent.Heap.empty))
          a1 (Persistent.Heap.insert 4 &a0)
          a2 (Persistent.Heap.insert 1 &a1)
          b0 (the (Persistent.Heap Int) (Persistent.Heap.empty))
          b1 (Persistent.Heap.insert 3 &b0)
          b2 (Persistent.Heap.insert 2 &b1)
          merged (Persistent.Heap.merge &a2 &b2)]
      (and (= (Persistent.Heap.length &merged) 4l)
           (match (Persistent.Heap.peek &merged)
             (Maybe.Just v) (= v 1)
             (Maybe.Nothing) false)))
    "merge preserves all elements and heap property")

  (assert-equal test
    true
    (let [h (build-descending-heap 100000)]
      (and (= (Persistent.Heap.length &h) 100000l)
           (match (Persistent.Heap.peek &h) (Maybe.Just v) (= v 1) (Maybe.Nothing) false)))
    "descending insert of 100k items does not blow the stack via merge-roots")

  (assert-equal test
    11
    (let [h0 (the (Persistent.Heap Int) (Persistent.Heap.empty))
          h1 (Persistent.Heap.insert 5 &h0)
          h2 (Persistent.Heap.insert 2 &h1)
          h3 (Persistent.Heap.insert 4 &h2)]
      (Persistent.Heap.reduce &(fn [acc x] (+ acc x)) 0 &h3))
    "reduce sums all heap values")

  (assert-equal test
    true
    (let [h0 (the (Persistent.Heap Int) (Persistent.Heap.empty))
          h1 (Persistent.Heap.insert 5 &h0)
          h2 (Persistent.Heap.insert 2 &h1)
          h3 (Persistent.Heap.insert 4 &h2)
          arr (Persistent.Heap.to-array &h3)]
      (= (Array.length &arr) 3))
    "to-array has count elements")

  (assert-equal test
    true
    (let [h (Persistent.Heap.insert 3
                            &(Persistent.Heap.insert 2
                                             &(Persistent.Heap.insert 1 &(the (Persistent.Heap Int) (Persistent.Heap.empty)))))]
      (Persistent.Heap.any? &(fn [x] (= x &3)) &h))
    "any? finds matching element")

  (assert-equal test
    false
    (let [h (Persistent.Heap.insert 3
                            &(Persistent.Heap.insert 2
                                             &(Persistent.Heap.insert 1 &(the (Persistent.Heap Int) (Persistent.Heap.empty)))))]
      (Persistent.Heap.any? &(fn [x] (= x &99)) &h))
    "any? returns false when none match")

  (assert-equal test
    true
    (let [h (Persistent.Heap.insert 3
                            &(Persistent.Heap.insert 2
                                             &(Persistent.Heap.insert 1 &(the (Persistent.Heap Int) (Persistent.Heap.empty)))))]
      (Persistent.Heap.all? &(fn [x] (> @x 0)) &h))
    "all? returns true when all match")

  (assert-equal test
    false
    (let [h (Persistent.Heap.insert 3
                            &(Persistent.Heap.insert 2
                                             &(Persistent.Heap.insert 1 &(the (Persistent.Heap Int) (Persistent.Heap.empty)))))]
      (Persistent.Heap.all? &(fn [x] (> @x 2)) &h))
    "all? returns false when not all match")

  (assert-equal test
    false
    (Persistent.Heap.any? &(fn [x] (= x &1)) &(the (Persistent.Heap Int) (Persistent.Heap.empty)))
    "any? on empty returns false")

  (assert-equal test
    true
    (Persistent.Heap.all? &(fn [x] (= x &1)) &(the (Persistent.Heap Int) (Persistent.Heap.empty)))
    "all? on empty returns true")

  (assert-equal test
    true
    (let [arr [30 10 20]
          h (Persistent.Heap.from-array &arr)]
      (and (= (Persistent.Heap.length &h) 3l) (= &(Maybe.Just 10) &(Persistent.Heap.peek &h))))
    "from-array inserts all elements with correct min")

  (assert-equal test
    true
    (let [h (Persistent.Heap.from-array &(the (Array Int) []))] (Persistent.Heap.empty? &h))
    "from-array on empty array yields empty heap")

  (assert-memory-balance test
                         heap-branch-lifecycle
                         0l
                         "persistent heap branch lifecycle is memory-balanced"))
