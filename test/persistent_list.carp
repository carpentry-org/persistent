(load "Test.carp")
(use Test)
(load "../persistent.carp")
(load "test_harness.carp")

(TestHarness.configure-build)

(defn assert-memory-balance [state f expected-balance descr]
  (do
    (Debug.reset-memory-balance!)
    (f)
    (assert-equal state expected-balance (Debug.memory-balance) descr)))

(defn build-long-list [n]
  (let-do [l (the (Persistent.List Int) (Persistent.List.empty))] (for [i 0 n] (set! l (Persistent.List.prepend i &l))) l))

(defn list-branch-lifecycle []
  (let [base (Persistent.List.singleton 1)
        left (Persistent.List.prepend 2 &base)
        right (Persistent.List.prepend 3 &base)]
    (do (ignore left) (ignore right))))

(deftest test
  (assert-equal test
    true
    (let [l (the (Persistent.List Int) (Persistent.List.empty))] (Persistent.List.empty? &l))
    "empty list reports empty")

  (assert-equal test
    0l
    (let [l (the (Persistent.List Int) (Persistent.List.empty))] (Persistent.List.length &l))
    "empty list has length 0")

  (assert-equal test
    2l
    (let [l0 (the (Persistent.List Int) (Persistent.List.empty))
          l1 (Persistent.List.prepend 1 &l0)
          l2 (Persistent.List.prepend 2 &l1)]
      (Persistent.List.length &l2))
    "prepend increments length")

  (assert-equal test
    2
    (let [l0 (the (Persistent.List Int) (Persistent.List.empty))
          l1 (Persistent.List.prepend 1 &l0)
          l2 (Persistent.List.prepend 2 &l1)]
      (match (Persistent.List.head &l2) (Maybe.Just v) v (Maybe.Nothing) -1))
    "head reads first value")

  (assert-equal test
    1
    (let [l0 (the (Persistent.List Int) (Persistent.List.empty))
          l1 (Persistent.List.prepend 1 &l0)
          l2 (Persistent.List.prepend 2 &l1)]
      (match (Persistent.List.tail &l2)
        (Maybe.Just t)
          (match (Persistent.List.head &t) (Maybe.Just v) v (Maybe.Nothing) -1)
        (Maybe.Nothing) -1))
    "tail exposes next value")

  (assert-equal test
    true
    (let [base (Persistent.List.singleton 1)
          left (Persistent.List.prepend 2 &base)
          right (Persistent.List.prepend 3 &base)]
      (match (Persistent.List.tail &left)
        (Maybe.Just lt)
          (match (Persistent.List.tail &right)
            (Maybe.Just rt) (Persistent.List.ptr-eq &lt &rt)
            (Maybe.Nothing) false)
        (Maybe.Nothing) false))
    "branching preserves shared tail")

  (assert-equal test
    true
    (let [l0 (the (Persistent.List Int) (Persistent.List.empty))
          l0b (the (Persistent.List Int) (Persistent.List.empty))
          l1 (Persistent.List.singleton 7)
          d (Persistent.List.drop-n 3l &l1)]
      (and (Persistent.List.ptr-eq &l0 &l0b)
           (Persistent.List.empty? &d)
           (= (Persistent.List.length &d) 0l)))
    "drop beyond length yields empty")

  (assert-equal test
    true
    (let [l (build-long-list 200000)
          d (Persistent.List.drop-n 200000l &l)]
      (Persistent.List.empty? &d))
    "drop-n through a 200k-long list does not blow the C stack")

  (assert-equal test
    6
    (let [l0 (the (Persistent.List Int) (Persistent.List.empty))
          l1 (Persistent.List.prepend 3 &l0)
          l2 (Persistent.List.prepend 2 &l1)
          l3 (Persistent.List.prepend 1 &l2)]
      (Persistent.List.reduce &(fn [acc x] (+ acc x)) 0 &l3))
    "reduce folds head-to-tail")

  (assert-equal test
    true
    (let [l0 (the (Persistent.List Int) (Persistent.List.empty))
          l1 (Persistent.List.prepend 30 &l0)
          l2 (Persistent.List.prepend 20 &l1)
          l3 (Persistent.List.prepend 10 &l2)
          arr (Persistent.List.to-array &l3)]
      (and (= (Array.length &arr) 3)
           (= @(Array.unsafe-nth &arr 0) 10)
           (= @(Array.unsafe-nth &arr 1) 20)
           (= @(Array.unsafe-nth &arr 2) 30)))
    "to-array copies values in list order")

  (assert-equal test
    true
    (let [a0 (the (Persistent.List Int) (Persistent.List.empty))
          a1 (Persistent.List.prepend 2 &a0)
          a2 (Persistent.List.prepend 1 &a1)
          b0 (the (Persistent.List Int) (Persistent.List.empty))
          b1 (Persistent.List.prepend 2 &b0)
          b2 (Persistent.List.prepend 1 &b1)
          c0 (the (Persistent.List Int) (Persistent.List.empty))
          c1 (Persistent.List.prepend 9 &c0)
          c2 (Persistent.List.prepend 1 &c1)]
      (and (= &a2 &b2) (not (= &a2 &c2)) (not (= &a2 &a1))))
    "= is structural: equal shape + elements")

  (assert-equal test
    true
    (let [l (the (Persistent.List Int) (Persistent.List.empty))
          r (Persistent.List.reverse &l)] (Persistent.List.empty? &r))
    "reverse of empty list is empty")

  (assert-equal test
    true
    (let [l (Persistent.List.singleton 42)
          r (Persistent.List.reverse &l)] (= &r &l))
    "reverse of singleton is itself")

  (assert-equal test
    true
    (let [l0 (the (Persistent.List Int) (Persistent.List.empty))
          l1 (Persistent.List.prepend 1 &l0)
          l2 (Persistent.List.prepend 2 &l1)
          l3 (Persistent.List.prepend 3 &l2)
          rev (Persistent.List.reverse &l3)
          arr (Persistent.List.to-array &rev)]
      (and (= (Array.length &arr) 3)
           (= @(Array.unsafe-nth &arr 0) 1)
           (= @(Array.unsafe-nth &arr 1) 2)
           (= @(Array.unsafe-nth &arr 2) 3)))
    "reverse reverses element order")

  (assert-equal test
    true
    (let [l0 (the (Persistent.List Int) (Persistent.List.empty))
          l1 (Persistent.List.prepend 1 &l0)
          l2 (Persistent.List.prepend 2 &l1)
          l3 (Persistent.List.prepend 3 &l2)
          mapped (Persistent.List.map &(fn [x] (+ x 10)) &l3)
          arr (Persistent.List.to-array &mapped)]
      (and (= (Array.length &arr) 3)
           (= @(Array.unsafe-nth &arr 0) 13)
           (= @(Array.unsafe-nth &arr 1) 12)
           (= @(Array.unsafe-nth &arr 2) 11)))
    "map applies function preserving order")

  (assert-equal test
    true
    (let [l (the (Persistent.List Int) (Persistent.List.empty))
          m (Persistent.List.map &(fn [x] (+ x 1)) &l)]
      (Persistent.List.empty? &m))
    "map over empty list yields empty")

  (assert-equal test
    true
    (let [l0 (the (Persistent.List Int) (Persistent.List.empty))
          l1 (Persistent.List.prepend 1 &l0)
          l2 (Persistent.List.prepend 2 &l1)
          l3 (Persistent.List.prepend 3 &l2)
          l4 (Persistent.List.prepend 4 &l3)
          filtered (Persistent.List.filter &(fn [x] (> @x 2)) &l4)
          arr (Persistent.List.to-array &filtered)]
      (and (= (Array.length &arr) 2)
           (= @(Array.unsafe-nth &arr 0) 4)
           (= @(Array.unsafe-nth &arr 1) 3)))
    "filter keeps elements matching predicate in order")

  (assert-equal test
    true
    (let [l0 (the (Persistent.List Int) (Persistent.List.empty))
          l1 (Persistent.List.prepend 1 &l0)
          l2 (Persistent.List.prepend 2 &l1)
          filtered (Persistent.List.filter &(fn [x] false) &l2)]
      (Persistent.List.empty? &filtered))
    "filter with always-false yields empty")

  (assert-equal test
    true
    (let [l0 (the (Persistent.List Int) (Persistent.List.empty))
          l1 (Persistent.List.prepend 1 &l0)
          l2 (Persistent.List.prepend 2 &l1)
          filtered (Persistent.List.filter &(fn [x] true) &l2)]
      (= &filtered &l2))
    "filter with always-true preserves all elements")

  (assert-equal test
    true
    (let [l0 (the (Persistent.List Int) (Persistent.List.empty))
          l1 (Persistent.List.prepend 1 &l0)
          l2 (Persistent.List.prepend 2 &l1)
          l3 (Persistent.List.prepend 3 &l2)]
      (Persistent.List.any? &(fn [x] (= x &3)) &l3))
    "any? finds matching element")

  (assert-equal test
    false
    (let [l0 (the (Persistent.List Int) (Persistent.List.empty))
          l1 (Persistent.List.prepend 1 &l0)
          l2 (Persistent.List.prepend 2 &l1)
          l3 (Persistent.List.prepend 3 &l2)]
      (Persistent.List.any? &(fn [x] (= x &99)) &l3))
    "any? returns false when none match")

  (assert-equal test
    true
    (let [l0 (the (Persistent.List Int) (Persistent.List.empty))
          l1 (Persistent.List.prepend 1 &l0)
          l2 (Persistent.List.prepend 2 &l1)
          l3 (Persistent.List.prepend 3 &l2)]
      (Persistent.List.all? &(fn [x] (> @x 0)) &l3))
    "all? returns true when all match")

  (assert-equal test
    false
    (let [l0 (the (Persistent.List Int) (Persistent.List.empty))
          l1 (Persistent.List.prepend 1 &l0)
          l2 (Persistent.List.prepend 2 &l1)
          l3 (Persistent.List.prepend 3 &l2)]
      (Persistent.List.all? &(fn [x] (> @x 2)) &l3))
    "all? returns false when not all match")

  (assert-equal test
    false
    (Persistent.List.any? &(fn [x] (= x &1)) &(the (Persistent.List Int) (Persistent.List.empty)))
    "any? on empty returns false")

  (assert-equal test
    true
    (Persistent.List.all? &(fn [x] (= x &1)) &(the (Persistent.List Int) (Persistent.List.empty)))
    "all? on empty returns true")

  (assert-equal test
    true
    (let [arr [10 20 30]
          l (Persistent.List.from-array &arr)
          back (Persistent.List.to-array &l)]
      (= &arr &back))
    "from-array round-trips through to-array")

  (assert-equal test
    true
    (let [l (Persistent.List.from-array &(the (Array Int) []))] (Persistent.List.empty? &l))
    "from-array on empty array yields empty list")

  (assert-memory-balance test
                         list-branch-lifecycle
                         0l
                         "persistent branch lifecycle is memory-balanced"))
