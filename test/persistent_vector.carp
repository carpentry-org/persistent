(load "Test.carp")
(use Test)
(load "../persistent.carp")
(load "test_harness.carp")

(TestHarness.configure-build)

(defn assert-memory-balance [state f expected-balance descr]
  (do
    (Debug.reset-memory-balance!)
    (f)
    (assert-equal state expected-balance (Debug.memory-balance) descr)))

(defn vec-branch-lifecycle []
  (let [v0 (the (Persistent.Vector Int) (Persistent.Vector.empty))
        v1 (Persistent.Vector.push-back 1 &v0)
        v2 (Persistent.Vector.push-back 2 &v1)
        v3 (Persistent.Vector.push-back 3 &v1)
        v4 (match (Persistent.Vector.assoc 0 9 &v2) (Maybe.Just v) v (Maybe.Nothing) v2)
        v5 (match (Persistent.Vector.pop-back &v4)
          (Maybe.Just p) @(Pair.b &p)
          (Maybe.Nothing) v4)]
    (do (ignore v3) (ignore v5))))

(deftest test
  (assert-equal test
    true
    (let [v (the (Persistent.Vector Int) (Persistent.Vector.empty))] (Persistent.Vector.empty? &v))
    "empty vector reports empty")

  (assert-equal test
    true
    (let [v0 (the (Persistent.Vector Int) (Persistent.Vector.empty))
          v1 (Persistent.Vector.push-back 10 &v0)
          v2 (Persistent.Vector.push-back 20 &v1)
          v3 (Persistent.Vector.push-back 30 &v2)]
      (and (= (Persistent.Vector.length &v3) 3l)
           (match (Persistent.Vector.get 0 &v3)
             (Maybe.Just v) (= v 10)
             (Maybe.Nothing) false)
           (match (Persistent.Vector.get 2 &v3)
             (Maybe.Just v) (= v 30)
             (Maybe.Nothing) false)))
    "push-back/get works")

  (assert-equal test
    true
    (let [v0 (the (Persistent.Vector Int) (Persistent.Vector.empty))
          v1 (Persistent.Vector.push-back 10 &v0)
          v2 (Persistent.Vector.push-back 20 &v1)
          assoc-res (Persistent.Vector.assoc 1 99 &v2)]
      (and
        (match assoc-res
          (Maybe.Just v)
            (match (Persistent.Vector.get 1 &v)
              (Maybe.Just x) (= x 99)
              (Maybe.Nothing) false)
          (Maybe.Nothing) false)
        (match (Persistent.Vector.get 1 &v2) (Maybe.Just v) (= v 20) (Maybe.Nothing) false)))
    "assoc updates index while preserving prior version")

  (assert-equal test
    true
    (let [v0 (the (Persistent.Vector Int) (Persistent.Vector.empty))
          v1 (Persistent.Vector.push-back 10 &v0)
          v2 (Persistent.Vector.push-back 20 &v1)
          v3 (Persistent.Vector.push-back 30 &v2)]
      (match (Persistent.Vector.pop-back &v3)
        (Maybe.Nothing) false
        (Maybe.Just p)
          (let [value @(Pair.a &p)
                v4 @(Pair.b &p)]
            (and (= value 30)
                 (= (Persistent.Vector.length &v4) 2l)
                 (Maybe.nothing? &(Persistent.Vector.get 2 &v4))))))
    "pop-back removes tail")

  (assert-equal test
    60
    (let [v0 (the (Persistent.Vector Int) (Persistent.Vector.empty))
          v1 (Persistent.Vector.push-back 10 &v0)
          v2 (Persistent.Vector.push-back 20 &v1)
          v3 (Persistent.Vector.push-back 30 &v2)]
      (Persistent.Vector.reduce &(fn [acc x] (+ acc x)) 0 &v3))
    "reduce folds in index order")

  (assert-equal test
    true
    (let [v0 (the (Persistent.Vector Int) (Persistent.Vector.empty))
          v1 (Persistent.Vector.push-back 1 &v0)
          v2 (Persistent.Vector.push-back 2 &v1)
          v3 (Persistent.Vector.push-back 3 &v2)
          arr (Persistent.Vector.to-array &v3)]
      (and (= (Array.length &arr) 3)
           (= @(Array.unsafe-nth &arr 0) 1)
           (= @(Array.unsafe-nth &arr 2) 3)))
    "to-array in index order")

  (assert-equal test
    true
    (let [a (Persistent.Vector.push-back 2 &(Persistent.Vector.push-back 1 &(the (Persistent.Vector Int) (Persistent.Vector.empty))))
          b (Persistent.Vector.push-back 2 &(Persistent.Vector.push-back 1 &(the (Persistent.Vector Int) (Persistent.Vector.empty))))
          c (Persistent.Vector.push-back 9 &(Persistent.Vector.push-back 1 &(the (Persistent.Vector Int) (Persistent.Vector.empty))))]
      (and (= &a &b) (not (= &a &c))))
    "= is pairwise on index-ordered values")

  (assert-equal test
    true
    (let [v (Persistent.Vector.push-back 3
                              &(Persistent.Vector.push-back 2
                                                 &(Persistent.Vector.push-back 1
                                                                    &(the (Persistent.Vector Int) (Persistent.Vector.empty)))))]
      (Persistent.Vector.any? &(fn [x] (= x &3)) &v))
    "any? finds matching element")

  (assert-equal test
    false
    (let [v (Persistent.Vector.push-back 3
                              &(Persistent.Vector.push-back 2
                                                 &(Persistent.Vector.push-back 1
                                                                    &(the (Persistent.Vector Int) (Persistent.Vector.empty)))))]
      (Persistent.Vector.any? &(fn [x] (= x &99)) &v))
    "any? returns false when none match")

  (assert-equal test
    true
    (let [v (Persistent.Vector.push-back 3
                              &(Persistent.Vector.push-back 2
                                                 &(Persistent.Vector.push-back 1
                                                                    &(the (Persistent.Vector Int) (Persistent.Vector.empty)))))]
      (Persistent.Vector.all? &(fn [x] (> @x 0)) &v))
    "all? returns true when all match")

  (assert-equal test
    false
    (let [v (Persistent.Vector.push-back 3
                              &(Persistent.Vector.push-back 2
                                                 &(Persistent.Vector.push-back 1
                                                                    &(the (Persistent.Vector Int) (Persistent.Vector.empty)))))]
      (Persistent.Vector.all? &(fn [x] (> @x 2)) &v))
    "all? returns false when not all match")

  (assert-equal test
    false
    (Persistent.Vector.any? &(fn [x] (= x &1)) &(the (Persistent.Vector Int) (Persistent.Vector.empty)))
    "any? on empty returns false")

  (assert-equal test
    true
    (Persistent.Vector.all? &(fn [x] (= x &1)) &(the (Persistent.Vector Int) (Persistent.Vector.empty)))
    "all? on empty returns true")

  (assert-equal test
    true
    (let [v0 (the (Persistent.Vector Int) (Persistent.Vector.empty))
          v1 (Persistent.Vector.push-back 1 &v0)
          v2 (Persistent.Vector.push-back 2 &v1)
          v3 (Persistent.Vector.push-back 3 &v2)
          mapped (Persistent.Vector.map &(fn [x] (+ x 10)) &v3)
          arr (Persistent.Vector.to-array &mapped)]
      (and (= (Array.length &arr) 3)
           (= @(Array.unsafe-nth &arr 0) 11)
           (= @(Array.unsafe-nth &arr 1) 12)
           (= @(Array.unsafe-nth &arr 2) 13)))
    "map applies function preserving index order")

  (assert-equal test
    true
    (let [v (the (Persistent.Vector Int) (Persistent.Vector.empty))
          m (Persistent.Vector.map &(fn [x] (+ x 1)) &v)]
      (Persistent.Vector.empty? &m))
    "map over empty vector yields empty")

  (assert-equal test
    true
    (let [v0 (the (Persistent.Vector Int) (Persistent.Vector.empty))
          v1 (Persistent.Vector.push-back 1 &v0)
          v2 (Persistent.Vector.push-back 2 &v1)
          v3 (Persistent.Vector.push-back 3 &v2)
          filtered (Persistent.Vector.filter &(fn [x] (> @x 1)) &v3)
          arr (Persistent.Vector.to-array &filtered)]
      (and (= (Array.length &arr) 2)
           (= @(Array.unsafe-nth &arr 0) 2)
           (= @(Array.unsafe-nth &arr 1) 3)))
    "filter keeps elements matching predicate in order")

  (assert-equal test
    true
    (let [v0 (the (Persistent.Vector Int) (Persistent.Vector.empty))
          v1 (Persistent.Vector.push-back 1 &v0)
          v2 (Persistent.Vector.push-back 2 &v1)
          filtered (Persistent.Vector.filter &(fn [x] false) &v2)]
      (Persistent.Vector.empty? &filtered))
    "filter with always-false yields empty vector")

  (assert-equal test
    true
    (let [v0 (the (Persistent.Vector Int) (Persistent.Vector.empty))
          v1 (Persistent.Vector.push-back 1 &v0)
          v2 (Persistent.Vector.push-back 2 &v1)
          filtered (Persistent.Vector.filter &(fn [x] true) &v2)]
      (= &filtered &v2))
    "filter with always-true preserves all elements")

  (assert-equal test
    true
    (let [arr [10 20 30]
          v (Persistent.Vector.from-array &arr)
          back (Persistent.Vector.to-array &v)]
      (= &arr &back))
    "from-array round-trips through to-array")

  (assert-equal test
    true
    (let [v (Persistent.Vector.from-array &(the (Array Int) []))] (Persistent.Vector.empty? &v))
    "from-array on empty array yields empty vector")

  (assert-memory-balance test
                         vec-branch-lifecycle
                         0l
                         "persistent vector branch lifecycle is memory-balanced"))
