(load "Test.carp")
(use Test)
(load "../persistent.carp")
(load "test_harness.carp")

(TestHarness.configure-build)

(Persistent.define-vector IntVec Int)

(defn assert-memory-balance [state f expected-balance descr]
  (do
    (Debug.reset-memory-balance!)
    (f)
    (assert-equal state expected-balance (Debug.memory-balance) descr)))

(defn vec-branch-lifecycle []
  (let [v0 (IntVec.empty)
        v1 (IntVec.push-back 1 &v0)
        v2 (IntVec.push-back 2 &v1)
        v3 (IntVec.push-back 3 &v1)
        v4 (match (IntVec.assoc 0 9 &v2) (Maybe.Just v) v (Maybe.Nothing) v2)
        v5 (match (IntVec.pop-back &v4)
          (Maybe.Just p) @(Pair.b &p)
          (Maybe.Nothing) v4)]
    (do (ignore v3) (ignore v5))))

(deftest test
  (assert-equal test
    true
    (let [v (IntVec.empty)] (IntVec.empty? &v))
    "empty vector reports empty")

  (assert-equal test
    true
    (let [v0 (IntVec.empty)
          v1 (IntVec.push-back 10 &v0)
          v2 (IntVec.push-back 20 &v1)
          v3 (IntVec.push-back 30 &v2)]
      (and (= (IntVec.length &v3) 3l)
           (match (IntVec.get 0 &v3)
             (Maybe.Just v) (= v 10)
             (Maybe.Nothing) false)
           (match (IntVec.get 2 &v3)
             (Maybe.Just v) (= v 30)
             (Maybe.Nothing) false)))
    "push-back/get works")

  (assert-equal test
    true
    (let [v0 (IntVec.empty)
          v1 (IntVec.push-back 10 &v0)
          v2 (IntVec.push-back 20 &v1)
          assoc-res (IntVec.assoc 1 99 &v2)]
      (and
        (match assoc-res
          (Maybe.Just v)
            (match (IntVec.get 1 &v)
              (Maybe.Just x) (= x 99)
              (Maybe.Nothing) false)
          (Maybe.Nothing) false)
        (match (IntVec.get 1 &v2) (Maybe.Just v) (= v 20) (Maybe.Nothing) false)))
    "assoc updates index while preserving prior version")

  (assert-equal test
    true
    (let [v0 (IntVec.empty)
          v1 (IntVec.push-back 10 &v0)
          v2 (IntVec.push-back 20 &v1)
          v3 (IntVec.push-back 30 &v2)]
      (match (IntVec.pop-back &v3)
        (Maybe.Nothing) false
        (Maybe.Just p)
          (let [value @(Pair.a &p)
                v4 @(Pair.b &p)]
            (and (= value 30)
                 (= (IntVec.length &v4) 2l)
                 (Maybe.nothing? &(IntVec.get 2 &v4))))))
    "pop-back removes tail")

  (assert-equal test
    60
    (let [v0 (IntVec.empty)
          v1 (IntVec.push-back 10 &v0)
          v2 (IntVec.push-back 20 &v1)
          v3 (IntVec.push-back 30 &v2)]
      (IntVec.reduce &(fn [acc x] (+ acc x)) 0 &v3))
    "reduce folds in index order")

  (assert-equal test
    true
    (let [v0 (IntVec.empty)
          v1 (IntVec.push-back 1 &v0)
          v2 (IntVec.push-back 2 &v1)
          v3 (IntVec.push-back 3 &v2)
          arr (IntVec.to-array &v3)]
      (and (= (Array.length &arr) 3)
           (= @(Array.unsafe-nth &arr 0) 1)
           (= @(Array.unsafe-nth &arr 2) 3)))
    "to-array in index order")

  (assert-equal test
    true
    (let [a (IntVec.push-back 2 &(IntVec.push-back 1 &(IntVec.empty)))
          b (IntVec.push-back 2 &(IntVec.push-back 1 &(IntVec.empty)))
          c (IntVec.push-back 9 &(IntVec.push-back 1 &(IntVec.empty)))]
      (and (= &a &b) (not (= &a &c))))
    "= is pairwise on index-ordered values")

  (assert-equal test
    true
    (let [v (IntVec.push-back 3
                              &(IntVec.push-back 2
                                                 &(IntVec.push-back 1
                                                                    &(IntVec.empty))))]
      (IntVec.any? &(fn [x] (= x &3)) &v))
    "any? finds matching element")

  (assert-equal test
    false
    (let [v (IntVec.push-back 3
                              &(IntVec.push-back 2
                                                 &(IntVec.push-back 1
                                                                    &(IntVec.empty))))]
      (IntVec.any? &(fn [x] (= x &99)) &v))
    "any? returns false when none match")

  (assert-equal test
    true
    (let [v (IntVec.push-back 3
                              &(IntVec.push-back 2
                                                 &(IntVec.push-back 1
                                                                    &(IntVec.empty))))]
      (IntVec.all? &(fn [x] (> @x 0)) &v))
    "all? returns true when all match")

  (assert-equal test
    false
    (let [v (IntVec.push-back 3
                              &(IntVec.push-back 2
                                                 &(IntVec.push-back 1
                                                                    &(IntVec.empty))))]
      (IntVec.all? &(fn [x] (> @x 2)) &v))
    "all? returns false when not all match")

  (assert-equal test
    false
    (IntVec.any? &(fn [x] (= x &1)) &(IntVec.empty))
    "any? on empty returns false")

  (assert-equal test
    true
    (IntVec.all? &(fn [x] (= x &1)) &(IntVec.empty))
    "all? on empty returns true")

  (assert-equal test
    true
    (let [v0 (IntVec.empty)
          v1 (IntVec.push-back 1 &v0)
          v2 (IntVec.push-back 2 &v1)
          v3 (IntVec.push-back 3 &v2)
          mapped (IntVec.map &(fn [x] (+ x 10)) &v3)
          arr (IntVec.to-array &mapped)]
      (and (= (Array.length &arr) 3)
           (= @(Array.unsafe-nth &arr 0) 11)
           (= @(Array.unsafe-nth &arr 1) 12)
           (= @(Array.unsafe-nth &arr 2) 13)))
    "map applies function preserving index order")

  (assert-equal test
    true
    (let [v (IntVec.empty)
          m (IntVec.map &(fn [x] (+ x 1)) &v)]
      (IntVec.empty? &m))
    "map over empty vector yields empty")

  (assert-equal test
    true
    (let [v0 (IntVec.empty)
          v1 (IntVec.push-back 1 &v0)
          v2 (IntVec.push-back 2 &v1)
          v3 (IntVec.push-back 3 &v2)
          filtered (IntVec.filter &(fn [x] (> @x 1)) &v3)
          arr (IntVec.to-array &filtered)]
      (and (= (Array.length &arr) 2)
           (= @(Array.unsafe-nth &arr 0) 2)
           (= @(Array.unsafe-nth &arr 1) 3)))
    "filter keeps elements matching predicate in order")

  (assert-equal test
    true
    (let [v0 (IntVec.empty)
          v1 (IntVec.push-back 1 &v0)
          v2 (IntVec.push-back 2 &v1)
          filtered (IntVec.filter &(fn [x] false) &v2)]
      (IntVec.empty? &filtered))
    "filter with always-false yields empty vector")

  (assert-equal test
    true
    (let [v0 (IntVec.empty)
          v1 (IntVec.push-back 1 &v0)
          v2 (IntVec.push-back 2 &v1)
          filtered (IntVec.filter &(fn [x] true) &v2)]
      (= &filtered &v2))
    "filter with always-true preserves all elements")

  (assert-memory-balance test
                         vec-branch-lifecycle
                         0l
                         "persistent vector branch lifecycle is memory-balanced"))
